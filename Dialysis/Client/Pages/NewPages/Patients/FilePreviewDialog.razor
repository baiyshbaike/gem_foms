@inject HttpClient Http
@inject IJSRuntime JSRuntime
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public long FileId { get; set; }
    [Parameter] public string FileName { get; set; }

    private string? fileDataUrl;
    private string fileType;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"api/patient/download-file/{FileId}");
        if (response.IsSuccessStatusCode)
        {
            var base64Content = await response.Content.ReadAsStringAsync();
            fileType = GetMimeType(FileName);
            fileDataUrl = $"data:{fileType};base64,{base64Content}";
        }
    }

    private string GetMimeType(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLower();
        return ext switch
        {
            ".pdf" => "application/pdf",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            _ => "application/octet-stream"
        };
    }

    private void Close() => MudDialog?.Close();
}
        @if (fileDataUrl != null)
        {
            @if (fileType == "application/pdf")
            {
                <iframe src="@fileDataUrl" width="1000px" height="600px" style="border:none;" />

            }
            else if (fileType.StartsWith("image/"))
            {
                <img src="@fileDataUrl" alt="preview"
                     style=" max-height: 500px; object-fit: contain;" />
            }
            else
            {
                <MudText>Этот формат не поддерживается для предварительного просмотра.</MudText>
            }
        }
        else
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
