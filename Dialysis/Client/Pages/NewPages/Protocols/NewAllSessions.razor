@page "/NewAllSessions"
@using Dialysis.Client.Pages.NewPages.Protocols.SessionPages
@attribute [Authorize(Roles = "admin, hdsession, hdsession_add, identify, identify_list")]
<MudTabs
    Elevation="2"
    Rounded="true"
    Centered="true"
    Class="my-6"
    Color="Color.Primary">
    <AuthorizeView Roles="admin, hdsession, hdsession_add">
        <MudTabPanel
            Icon="@Icons.Material.Filled.AirlineSeatReclineExtra"
            Text="Все протоколы"
            BadgeData='@_sessionCount.All.ToString()'
            BadgeColor="Color.Dark"
            Style="width: 220px;justify-content: start">
            @if (_userCenters.Any())
            {
                <AllSessions 
                    IsAdmin="@IsAdmin" 
                    FilterModel="@FilterModel" 
                    UserCenters="@_userCenters" 
                    DateChanged="OnDateChanged"/>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" />
            }
        </MudTabPanel>
    </AuthorizeView>
    <AuthorizeView Roles="admin, identify, identify_list">
        <MudTabPanel
            Icon="@Icons.Material.Filled.AirlineSeatFlat"
            Text="Идентификационный"
            BadgeData='@_sessionCount.IdentificationCount.ToString()'
            Style="width: 250px;justify-content: start"
            BadgeColor="Color.Warning">
            @if (_userCenters.Any())
            {
                <IdentificationPage
                    IsAdmin="@IsAdmin"
                    FilterModel="@FilterModel"
                    UserCenters="@_userCenters"
                    DateChanged="OnDateChanged"/>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" />
            }
        </MudTabPanel>
    </AuthorizeView>
    <AuthorizeView Roles="admin, hdsession, hdsession_add">
        <MudTabPanel
            Icon="@Icons.Material.Filled.AirlineSeatFlat"
            Text="Активный"
            BadgeData='@_sessionCount.ActiveCount.ToString()'
            Style="width: 170px;justify-content: start"
            BadgeColor="Color.Success">
            @if (_userCenters.Any())
            {
                <StartedPage 
                    IsAdmin="@IsAdmin" 
                    FilterModel="@FilterModel" 
                    UserCenters="@_userCenters"
                    DateChanged="OnDateChanged"/>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" />
            }
        </MudTabPanel>
    </AuthorizeView>
    <AuthorizeView Roles="admin, hdsession, hdsession_add">
        <MudTabPanel
            Icon="@Icons.Material.Filled.AirlineSeatFlatAngled"
            Text="Завершенный"
            BadgeData="@_sessionCount.FinishedCount.ToString()"
            BadgeColor="Color.Error"
            Style="width: 180px;justify-content: start">
            @if (_userCenters.Any())
            {
                <FinishedPage 
                    IsAdmin="@IsAdmin" 
                    FilterModel="@FilterModel" 
                    UserCenters="@_userCenters"
                    DateChanged="OnDateChanged"/>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" />
            }
        </MudTabPanel>
    </AuthorizeView>
    <AuthorizeView Roles="admin, hdsession, hdsession_add">
        <MudTabPanel
            Icon="@Icons.Material.Filled.PriceCheck"
            Text="Завершение идент."
            BadgeIcon="@Icons.Material.Filled.Check"
            BadgeData='@_sessionCount.PayedCount.ToString()'
            Style="width: 220px;justify-content: start"
            BadgeColor="Color.Tertiary">
            @if (_userCenters.Any())
            {
                <EndIdentificationPage 
                    IsAdmin="@IsAdmin" 
                    FilterModel="@FilterModel" 
                    UserCenters="@_userCenters"
                    DateChanged="OnDateChanged"/>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" />
            }
        </MudTabPanel>
    </AuthorizeView>
    <AuthorizeView Roles="admin, hdsession, hdsession_add">
        <MudTabPanel
            Icon="@Icons.Material.Filled.MoneyOff"
            Text="К оплате"
            BadgeData="@_sessionCount.SendToPayCount.ToString()"
            Style="width: 220px;justify-content: start"
            BadgeColor="Color.Default">
            @if (_userCenters.Any())
            {
                <SendToPayPage 
                    IsAdmin="@IsAdmin" 
                    FilterModel="@FilterModel" 
                    UserCenters="@_userCenters"
                    DateChanged="OnDateChanged"/>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" />
            }
        </MudTabPanel>
    </AuthorizeView>
</MudTabs>
<style>
    .mud-tooltip-root.mud-tooltip-inline{
        max-width: 250px;
    }
</style>
@code {
    [CascadingParameter] 
    private Task<AuthenticationState> AuthenticationStateTask { get; set; }
    private SessionCountDto _sessionCount = new SessionCountDto();
    private IEnumerable<MedCenter> _userCenters = new List<MedCenter>();
    private SessionFilterDto FilterModel { get; set; } = new SessionFilterDto();
    private bool IsAdmin { get; set; }
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        var user = authState.User;

        IsAdmin = user.IsInRole("admin");
        await LoadUserCentersAsync();
        StateHasChanged();
    }
    private async Task LoadUserCentersAsync()
    {
        _userCenters = await _commonService.LoadRelMedcentersAsync();
        if (_userCenters.Count() > 1)
        {
            FilterModel.MedCenterId = 0;
        }
        else
        {
            FilterModel.MedCenterId = _userCenters.Select(t => t.Id).FirstOrDefault();
        }
        
    }
    private async Task OnDateChanged(SessionCountDto sessionCount)
    {
        _sessionCount = sessionCount;
    }
}