@page "/analysesall"
@using System.Net.Http.Json
@inject HttpClient Http


<MudContainer MaxWidth="MaxWidth.Large">
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField For="@(() => searchModel.Inn)" @bind-Value="searchModel.Inn" Label="ИНН" />
            </MudItem>
            <MudItem xs="12" md="3">
                
            </MudItem>
            <MudItem xs="12" md="3">
               
            </MudItem>
            <MudItem xs="6" md="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchAnalysesAsync" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Поиск</MudButton>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>


<MudTable Items="@Elements" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" RowsPerPage=100 Filter="new Func<Analysis,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6"> Анализы</MudText>
        &nbsp;&nbsp;
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
            <MudTh>ФИО</MudTh>
            <MudTh>ИНН</MudTh>
            <MudTh>Анализ</MudTh>
            <MudTh>Резултат</MudTh>
            <MudTh>Дата Анализа</MudTh>
            <MudTh>Следующая дата Анализа</MudTh>
         
        <MudTh>&nbsp;</MudTh>
    </HeaderContent>
    <RowTemplate>
            <MudTd>
              @AnalysisResults.FirstOrDefault().Patient.LastName  @AnalysisResults.FirstOrDefault().Patient.FirstName                      
            </MudTd>
            <MudTd>
               
                            <span>@AnalysisResults.FirstOrDefault().Patient.Inn</span>
                      
            </MudTd>
            <MudTd>@context.Title</MudTd>          
            <MudTd>
                @{
                    foreach (var fio in AnalysisResults)
                    {
                        if (fio.AnalysisResult.AnalysisId == context.Id)
                        {
                            <span>@fio.AnalysisResult.Result @fio.Analysis.AnalysisExt </span>
                        }
                    }
                }
            </MudTd>
            <MudTd>@GetAnalysisDate(context.Id)</MudTd>
            <MudTd Style="@(IsDatePast(context.Id, (long)context.NextDays,(DateTime)(AnalysisResults.FirstOrDefault().MedCard.CreatedOn)) ? "background-color:red;":"")"><b>@GetNextAnalysisDate(context.Id, (long)context.NextDays, (DateTime)(AnalysisResults.FirstOrDefault().MedCard.CreatedOn)) </b></MudTd>
          
        <MudTd>           
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
</MudContainer>
@code {

    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private bool tableLoading = false;

    [Parameter]
    public long MedCardId { get; set; }
    private long IsCard { get; set; }
    private MedCard ownCard { get; set; }

    private Analysis selectedItem1 = null;
    private HashSet<Analysis> selectedItems = new HashSet<Analysis>();

    public MedCardSearch searchModel = new MedCardSearch();
    private bool showTable = false;
    private DateTime? dateFrom = DateTime.Today.AddDays(-30);
    private DateTime? dateTo = DateTime.Today;
    private IEnumerable<Analysis> Elements = new List<Analysis>();
    private IEnumerable<AnalysisResultsDto> AnalysisResults = new List<AnalysisResultsDto>();
    public Patient PatientModel { get; set; }

    private DateTime todayDate = DateTime.Today;


    protected override async Task OnInitializedAsync()
    {


        //await LoadPatientAsync();
        //await LoadMCardDataAsync();

    }
    private bool IsDatePast(long analysesId, long nextDate,DateTime cardTime)
    {
        DateTime dateTimeNow = DateTime.Now.Date;
        var selItem = AnalysisResults.Where(t => t.AnalysisResult.AnalysisId == analysesId).OrderByDescending(p => p.AnalysisResult.AnalysisDate).FirstOrDefault();
        if (selItem != null)
        {
            var nextDateVar = ((DateTime)selItem.AnalysisResult.AnalysisDate).AddDays(nextDate);
            if (dateTimeNow > nextDateVar)
            {
                return true;
            }
        }
        else
        {
            if (dateTimeNow > cardTime)
            {
                return true;
            }
        }
        return false;
    }

    private string GetAnalysisDate(long analysesId)
    {
        var retVal = "";
        var selItem = AnalysisResults.Where(t => t.AnalysisResult.AnalysisId == analysesId).OrderByDescending(p=>p.AnalysisResult.AnalysisDate).FirstOrDefault();
        if (selItem != null)
        {
            retVal = selItem.AnalysisResult.AnalysisDate?.ToString("dd.MM.yyyy");
        }
        return retVal;
    } 

    private string GetNextAnalysisDate(long analysesId, long nextDate, DateTime mCardDate)
    {
        var retVal = "";
        var selItem = AnalysisResults.Where(t => t.AnalysisResult.AnalysisId == analysesId).OrderByDescending(p => p.AnalysisResult.AnalysisDate).FirstOrDefault();
        if (selItem != null)
        {
            var nextDateVar = ((DateTime)selItem.AnalysisResult.AnalysisDate).AddDays(nextDate);
            if (todayDate > nextDateVar){
                retVal = nextDateVar.ToString("dd.MM.yyyy");
            }
            else
            {
                retVal = nextDateVar.ToString("dd.MM.yyyy");
            }

        }
        else
        {
            if (todayDate > mCardDate)
            {
                retVal = mCardDate.ToString("dd.MM.yyyy");
            }
            else
            {
                retVal = mCardDate.ToString("dd.MM.yyyy");
            }
            /*if (nextDate > 0)
            {
                var startDate = DateTime.Today;
                if (startDate != null)
                {
                    retVal = ((DateTime)startDate).AddDays(nextDate).ToString("dd.MM.yyyy");
                }
                else
                {
                    retVal = ((DateTime)startDate).AddDays(nextDate).ToString("dd.MM.yyyy");
                }
            }*/
        }
        return retVal;
    }

   
    private async Task LoadDataAsync()
    {
        tableLoading = true;
        var response = await Http.GetAsync("api/status/allanalysis");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<Analysis>>();
        Elements = mappedData.Data;
        tableLoading = false;
    }

    private bool FilterFunc1(Analysis element) => FilterFunc(element, searchString1);

    private bool FilterFunc(Analysis element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        /*if (element.Adress.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;*/
        return false;
    }

    private async Task SearchAnalysesAsync()
    {
        await LoadDataAsync();

        var response = await Http.GetAsync("api/medcard/analysesbyinn?inn=" + searchModel.Inn);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<AnalysisResultsDto>>();
        AnalysisResults = mappedData.Data;
    }

}

