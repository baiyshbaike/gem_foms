@page "/mcardadd6"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime


<MudContainer MaxWidth="MaxWidth.Large">


        <MudGrid>           
             <MudItem xs="12" md="12">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.MapsHomeWork" Class="mr-3 mb-n1" />
                Добавить мед. карта -> Эндокринная система
                </MudText>
        </MudItem>           
        </MudGrid>
    <MudForm @ref="form" Model="@AddEditModel" @bind-IsValid="@IsValid">
            <MudGrid>
                <MudItem xs="12" md="4">
                <MudTextField @bind-Value="AddEditModel.Shitovidnaia" Required="true" Label="Шитовидная железа" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="AddEditModel.Glaznaia" Required="true" Label="Глазные симптомы" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="AddEditModel.Potootdelenie" Required="true" Label="Потоотделение" Lines="3" Variant="Variant.Outlined" />
                </MudItem>                
                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="12">
                <MudTextField @bind-Value="AddEditModel.Prochee" Label="Прочее" />
                </MudItem>

                <MudItem xs="12" md="12">
                </MudItem>
            <MudItem xs="12" md="12">
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Назад</MudButton>
                <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())"Disabled="@(IsValid==false)" Color="Color.Success">Далее</MudButton>
            </MudItem>
            </MudGrid>
        
</MudForm>
</MudContainer>
@code {
    
