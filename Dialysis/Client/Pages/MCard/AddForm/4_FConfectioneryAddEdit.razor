                <MudItem xs="12" md="12">
                    <MudText Typo="Typo.h6">
                        Пальпация и перкуссия других органов
                    </MudText>
                </MudItem>
                <MudItem xs="12" md="4">
                <MudTextField @bind-Value="AddEditModel.Jelchniy" Required="true" Label="Желчный пузырь" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
