                <MudTextField @bind-Value="AddEditModel.Stul" Required="true" Label="Стул со слов пациента" Lines="2" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="12">
                <MudTextField @bind-Value="AddEditModel.Prochee2"  Label="Прочее" Lines="2" Variant="Variant.Outlined" />
            </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
            <MudItem xs="12" md="12">
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Назад</MudButton>
                <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Disabled="@(IsValid==false)" Color="Color.Success">Далее</MudButton>
            </MudItem>
            </MudGrid>
           
</MudForm>
</MudContainer>
