@page "/mcardadd7"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime


<MudContainer MaxWidth="MaxWidth.Large">


        <MudGrid>           
             <MudItem xs="12" md="12">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.MapsHomeWork" Class="mr-3 mb-n1" />
                Добавить мед. карта -> Нервно-психическая система
                </MudText>
        </MudItem>           
        </MudGrid>
 <MudForm @ref="form" Model="@AddEditModel" @bind-IsValid="@IsValid">
            <MudGrid>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Soznanye" Required="true" Label="Сознаные" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Rech" Required="true" Label="Речь" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Pohodka" Required="true" Label="Походка" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Golovokrujenie" Required="true" Label="Головокружение" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Litso" Required="true" Label="Лицо(выражение, симметрия)" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                <MudTextField @bind-Value="AddEditModel.Glaznye" Required="true" Label="Глазные шели" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Zrachki" Required="true" Label="Зрачки" Lines="2" Variant="Variant.Outlined"/>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Dvijenie" Required="true" Label="Движение глазных яблок" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
               
                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Glotochnyi" Required="true" Label="Глоточный и небный рефлексы" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                <MudTextField @bind-Value="AddEditModel.Yazyk" Required="true" Label="Язык при высовывании" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                <MudTextField @bind-Value="AddEditModel.Poverhnostnye" Required="true" Label="Поверхностные и глубокие рефлексы" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="AddEditModel.Potologicheskie" Required="true" Label="Патологические рефлексы" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="4">
                   <MudDatePicker Label="Дата" @bind-Date="date"  Required="true" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                <MudTextField @bind-Value="AddEditModel.Sindrom" Required="true" Label="Синдром Паркинсонизма" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField @bind-Value="AddEditModel.Meningealnye" Required="true" Label="Менингеальные симптомы"  Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField @bind-Value="AddEditModel.Kerniga" Required="true" Label="Симптом Кернига" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                <MudTextField @bind-Value="AddEditModel.Romberga" Required="true" Label="Симптом Ромберга" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
                 <MudItem xs="12" md="4">
                    
                    <MudDatePicker Label="Дата" @bind-Date="date1" Required="true" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField @bind-Value="AddEditModel.Intellect" Required="true" Label="Интелект" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField @bind-Value="AddEditModel.Pamiat" Required="true" Label="Память" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField @bind-Value="AddEditModel.Mnitelnost" Required="true" Label="Мнительность"  Lines="3" Variant="Variant.Outlined"/>
                </MudItem>
                <MudItem xs="12" md="2">
                <MudTextField @bind-Value="AddEditModel.Vnushaemost" Required="true" Label="Внушаемость" Lines="3" Variant="Variant.Outlined" />
                </MudItem>               
                <MudItem xs="12" md="12">
                <MudTextField @bind-Value="AddEditModel.StatusOfArteriovenous" Required="true" Label="Состояние артерио-венозной фистулы (локальный статус)" Lines="4" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                </MudItem>
            <MudItem xs="12" md="2">
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Назад</MudButton>
                 <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Disabled="@(IsValid==false)" Color="Color.Success">Далее</MudButton>
            </MudItem>
            </MudGrid>

</MudForm>
</MudContainer>

