@page "/mcardadd5"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime


<MudContainer MaxWidth="MaxWidth.Large">


        <MudGrid>           
             <MudItem xs="12" md="12">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.MapsHomeWork" Class="mr-3 mb-n1" />
                Добавить мед. карта -> Мочеполовая система
                </MudText>
        </MudItem>           
        </MudGrid>

 <MudForm @ref="form" Model="@AddEditModel" @bind-IsValid="@IsValid">
            <MudGrid>
            <MudItem xs="12" md="12">
                <MudText Typo="Typo.h4">Мочеиспускание</MudText>
            </MudItem>
                <MudItem xs="12" md="2">
                <MudTextField @bind-Value="AddEditModel.Chastota" Required="true" Label="Частотат(днем, ноч.)" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField @bind-Value="AddEditModel.Sutochnoe" Required="true" Label="Суточное кол-во" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                <MudTextField @bind-Value="AddEditModel.Rezi" Required="true" Label="Рези, жжение, боль" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                <MudTextField @bind-Value="AddEditModel.Nederjanie" Required="true" Label="Недержание" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="2">
                <MudTextField @bind-Value="AddEditModel.SvetMochi" Required="true" Label="Цвет мочи" Lines="3" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="12">
                <MudText Typo="Typo.h4">Почки</MudText>
                </MudItem>
                <MudItem xs="12" md="4">
                <MudTextField @bind-Value="AddEditModel.PochkiPalpatsia" Required="true" Label="Пальпация" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                <MudTextField @bind-Value="AddEditModel.PochkiSimptom" Required="true" Label="Симптом поколачивания" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                <MudTextField @bind-Value="AddEditModel.PochkiProchee"  Label="Прочее" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="12">
                <MudText Typo="Typo.h4">Мочевой пузырь</MudText>
                </MudItem>
                <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="AddEditModel.MochevoiPalpatsia" Required="true" Label="Пальпация" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="AddEditModel.MochevoiPerkissia" Required="true" Label="Перкуссия" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="AddEditModel.MochevoiProchee"  Label="Прочее" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="12">
                <MudTextField @bind-Value="AddEditModel.Prochee"  Label="Прочее" />
                </MudItem>

                <MudItem xs="12" md="12">
                </MudItem>
            <MudItem xs="12" md="12">
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Назад</MudButton>
                <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Disabled="@(IsValid==false)" Color="Color.Success">Далее</MudButton>
            </MudItem>
            </MudGrid>
            
</MudForm>
</MudContainer>
@code {
    

    public FirstUrogenital AddEditModel { get; set; } = new FirstUrogenital();
    MudForm form;

        private bool IsDisabled = true;
        private bool IsValid;

    protected override async Task OnInitializedAsync()
    {
        var local = await _commonService.LocalMedCard5Async(null);
        if (local != null) AddEditModel = local;
        StateHasChanged();
    }

        public void Cancel()
        {
        JSRuntime.InvokeVoidAsync("history.back");
        }

    private async Task SaveAsync()
    {
        await _commonService.LocalMedCard5Async(AddEditModel);
        _navigationManager.NavigateTo("/mcardadd6");

