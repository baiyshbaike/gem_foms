                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="12"> <MudText Typo="Typo.h6">Аускультация</MudText> </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="AddEditModel.Ton" Required="true" Label="Тоны серца" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="AddEditModel.Shum" Required="true" Label="Шумы сердца" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                <MudTextField @bind-Value="AddEditModel.Prochee4" Label="Прочее" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
                <MudItem xs="12" md="12"> <MudText Typo="Typo.h6">Артериальное давление, пульс</MudText> </MudItem>
                <MudItem xs="4" md="2">
                <MudTextField @bind-Value="AddEditModel.Ad" Required="true" Label="АД, мм.рт.ст" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="4" md="2">
                    <MudTextField @bind-Value="AddEditModel.AdChastota" Required="true" Label="Частота" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="4" md="2">
                    <MudTextField @bind-Value="AddEditModel.AdRitm" Required="true" Label="Ритм" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="4" md="2">
                    <MudTextField @bind-Value="AddEditModel.AdDefisit" Required="true" Label="Дефисит" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                <MudTextField @bind-Value="AddEditModel.Prochee5" Label="Прочее" Lines="3" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="12">
                </MudItem>
            <MudItem xs="12" md="12">
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Назад</MudButton>
                <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Disabled="@(IsValid==false)" Color="Color.Success">Далее</MudButton>
            </MudItem>
            </MudGrid>
            
</MudForm>
</MudContainer>
