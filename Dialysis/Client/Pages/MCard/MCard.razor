@page "/mcarddetail/{MedCardId:long}"
@using System.Net.Http.Json
@inject HttpClient Http

<MudTabs Color="@Color.Info" Outlined="true" @bind-ActivePanelIndex="activeTab">

    @if (IsCard > 0)
    {
        <MudTabPanel Text="Протоколы сеансов гемодиализа" />
        <MudTabPanel Text="Мед. карта" />
        <MudTabPanel Text="Анализы и результаты" />
        <MudTabPanel Text="Этапный эпикриз" />
    }
    else
    {
        <MudTabPanel Text="Протоколы сеансов гемодиализа" />
        <MudTabPanel Text="Анализы и результаты" />
    }


</MudTabs>
@{
    if (activeTab == 0)
    {
        <Dialysis.Client.Pages.PageComponents.PatientSessions MedCardId=MedCardId />
    }
    else if (activeTab == 1)
    {
        
       <Dialysis.Client.Pages.PageComponents.PatientMCard MedCardId=MedCardId />
       
    }
    else if (activeTab == 2)
    {
        <Dialysis.Client.Pages.PageComponents.PatientAnalysisPage MedCardId=MedCardId />
    }
    else
    {
        <Dialysis.Client.Pages.PageComponents.Epicrisis MedCardId=MedCardId />
    }
}

@code {

    [Parameter]
    public long MedCardId { get; set; }

    public long IsCard { get; set; } = 0;
    int activeTab = 0;
    protected override async Task OnInitializedAsync()
    {
        if (MedCardId > 0)
        {
            await LoadMCardAsync();
        }
        else
        {
            _navigationManager.NavigateTo("/medcardlist");
        }
        //Elements = await Http.GetFromJsonAsync<ProcessDto[]>("temp_data/process.json");
    }

    public async Task LoadMCardAsync()
    {
        var response = await Http.GetAsync("api/medcard/isaccesscard?medcardId=" + MedCardId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<long>();
        IsCard = mappedData.Data;
    }

}
