@page "/tunduk"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Large">
    <EditForm Model="@searchModel">
        <MudGrid>   
            <MudItem xs="6" md="4">
                <MudTextField For="@(() => searchModel.Inn)" @bind-Value="searchModel.Inn" Label="ИНН" />
            </MudItem>
            <MudItem xs="12" md="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchAsync" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Поиск пациент</MudButton>
            </MudItem>           
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>
    <MudTable Items="@Sessions" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@patientName </MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Номер</MudTh>
            <MudTh>Мед центр</MudTh>
            <MudTh>Дата</MudTh>
            <MudTh>Время сеанса (начало и конец)</MudTh>
            <MudTh>Эффективная время сеанса</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Номер">@context.Id</MudTd>
            <MudTd DataLabel="Медцентр">@context.MedCenterTitle</MudTd>
            <MudTd DataLabel="Дата">@context.SessionStart?.ToString("dd.MM.yyyy")</MudTd>
            <MudTd DataLabel="Время сеанса (начало и конец)">@context.SessionStart?.ToString("HH:mm") - @context.SessionEnd?.ToString("HH:mm")</MudTd>
            <MudTd DataLabel="Эффективная время сеанса">@MinutsTohHours((double)context.EffectDate)</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private bool dense = true;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = true;
    private string searchString1 = "";
    private string patientName = "";
    private PatientSessionsSearchModelDto searchModel = new PatientSessionsSearchModelDto();
    private IEnumerable<PatientSessionsDto> Sessions = new List<PatientSessionsDto>();
    protected override async Task OnInitializedAsync()
    {
    }
    private async Task SearchAsync()
    {
        var getresponse = await Http.GetAsync("api/medcard/getpatinentsessions?Inn=" + searchModel.Inn);
        var getdata = await getresponse.ToResult<List<PatientSessionsDto>>();
        Sessions = getdata.Data;
        patientName = Sessions.Select(t => t.Fio).FirstOrDefault();
    }
    private string MinutsTohHours(double totalMinutes)
    {
        int hours = (int)(totalMinutes / 60);
        int minutes = (int)(totalMinutes % 60);
        var time = $"{hours}:{minutes:00}";
        return time;
    }
    public class PatientSessionsSearchModelDto
    {
        public string Inn { get; set; }
    }
}
