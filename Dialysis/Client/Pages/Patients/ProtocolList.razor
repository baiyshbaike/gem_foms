@page "/protocol"
@using System.Net.Http.Json
@inject HttpClient Http

<AuthorizeView Roles="admin">
    @{
        hasEditRight = true;
    }
</AuthorizeView>
<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge">
    <MudGrid>
        <MudItem xs="4" md="4">
            <MudDatePicker Label="Дата от" @bind-Date="dateFrom" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
        </MudItem>
        <MudItem xs="4" md="4">
            <MudDatePicker Label="Дата до" @bind-Date="dateTo" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
        </MudItem>
        <MudItem xs="4" md="4">
            <br />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async() => await LoadDataAsync())">Обновить</MudButton>
        </MudItem>
        <MudItem xs="12" md="12">
            <MudCardActions>
            </MudCardActions>
        </MudItem>
    </MudGrid>
</MudContainer>
<MudTable Items="@Elements" 
          Loading="@tableLoading" 
          Dense="@dense" 
          Hover="@hover" 
          Bordered="@bordered" 
          Striped="@striped" 
          Filter="new Func<PatientGroupActDto,bool>(FilterFunc1)">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Протокол комиссии</MudText>
        <AuthorizeView Roles="admin, protocol_add">
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.AddCard"
                       @onclick="@(() => AddEditGroupProtocol(0))"
                       Size="Size.Small"
                       Color="Color.Info">
                Добавить протокол
            </MudButton>
         </AuthorizeView>            
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Immediate="true" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>No:</MudTh>
        <MudTh>Дата</MudTh>
        @foreach (var item in GroupList)
        {
            <MudTh>Выбывшие из @item.Title</MudTh>
        }
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PatientGroupTitle.Id</MudTd>
        <MudTd>@context.PatientGroupTitle.CreatedOn.ToString("dd.MM.yyyy")</MudTd>
        @foreach (var item in GroupList)
        {
            var totalOut = context.PatientHistory.Where(p => p.GroupFromId.Equals(item.Id)).Count();
            <MudTh>@totalOut</MudTh>
        }
        @*<MudTd>
            @{
                if (hasEditRight)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Редактировать" @onclick="@(async() => await AddEditGroupProtocol(context.PatientGroupTitle.Id))" Size="Size.Small" Color="Color.Warning"></MudIconButton>
                }
            }
        </MudTd>*@
        <MudTd>
            <MudButton Variant="Variant.Filled"
                       @onclick="@(async() => await DetailPage(context.PatientGroupTitle.Id, context.PatientGroupTitle.CreatedOn))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                Подробности
            </MudButton> 
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private DateTime? dateFrom = DateTime.Today.AddMonths(-1);
    private DateTime? dateTo = DateTime.Today.AddHours(23).AddMinutes(59).AddSeconds(59);
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private string quickString = "";
    private bool hasEditRight = false;

    private bool tableLoading = false;

    private IEnumerable<PatientGroup> GroupList = new List<PatientGroup>();
    private IEnumerable<PatientGroupActDto> Elements = new List<PatientGroupActDto>();

    private List<Patient> Data { get; set; }


    protected override async Task OnInitializedAsync()
    {
        tableLoading = true;
        await LoadGroupDataAsync();
        await LoadDataAsync();
    }
    private bool FilterFunc1(PatientGroupActDto element) => FilterFunc(element, searchString1);

    private bool FilterFunc(PatientGroupActDto element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        searchString = searchString.Trim().ToLower();

        return element.PatientHistory.Any(history =>
            history.Inn?.ToLower().Contains(searchString) == true ||
            history.FirstName?.ToLower().Contains(searchString) == true ||
            history.LastName?.ToLower().Contains(searchString) == true ||
            history.MiddleName?.ToLower().Contains(searchString) == true);
    }
    private async Task LoadGroupDataAsync()
    {
        var response = await Http.GetAsync("api/status/allgroups");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<PatientGroup>>();
        GroupList = mappedData.Data;
    }

    private async Task LoadDataAsync()
    {
        if (dateFrom.HasValue && dateTo.HasValue)
        {
            var dateRange = new DateRangeParams
            {
                FromDate = dateFrom.Value,
                ToDate = dateTo.Value
            };
            
            var response = await Http.PostAsJsonAsync("api/patient/allprotocol", dateRange);
            
            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await _authenticationManager.Logout();
                _navigationManager.NavigateTo("/login");
            }
            
            var mappedData = await response.ToResult<List<PatientGroupActDto>>();
            Elements = mappedData.Data;
            tableLoading = false;
        }
    }
    private async Task AddEditGroupProtocol(long id = 0)
    {
        if (id != 0)
        {
            _navigationManager.NavigateTo("/protocoladdedit");
        }
        else
        {
            _navigationManager.NavigateTo("/protocoladdedit");
        }
    }

    private async Task DetailPage(long id,DateTime itemDate)
    {
        string formattedDate = itemDate.ToString("dd-MM-yyyy HH:mm:ss");
        _navigationManager.NavigateTo($"/protocoldetail/{id}?date={formattedDate}");
    }

}
