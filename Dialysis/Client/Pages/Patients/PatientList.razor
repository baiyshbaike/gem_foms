@page "/patient"
@using System.Net.Http.Json
@inject HttpClient Http
@inject AuthenticationStateProvider GetAuthenticationStateAsync

 <AuthorizeView Roles="admin, patient">
@{
        hasEditRight = true;
 }
</AuthorizeView>


<MudTable Items="@Elements" 
         Loading="@tableLoading" 
         Dense="@dense" 
         Hover="@hover" 
         Bordered="@bordered" 
         Striped="@striped"
         MultiSort="true"
         SortLabel="Sort By"
         Filter="new Func<Patient,bool>(FilterFunc1)" 
         @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Пациенты</MudText>
        &nbsp;&nbsp;
        <AuthorizeView Roles="admin, patient">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PersonAdd" @onclick="@(() => AddEditModal(0))" Size="Size.Small" Color="Color.Info">Добавить</MudButton>
        </AuthorizeView>
        <MudSpacer></MudSpacer>
        <AuthorizeView Roles="admin, patient">
            <MudSelect T="long" Label="Статус пациента"
                       MultiSelection="true"
                       SelectedValuesChanged="OnSelectionChanged"
                       SelectedValues="_selectedStateIds"
                       SelectAll="true"
                       Clearable="true"
                       SelectAllText="Выбрать все"
                       SelectedValuePresenter="@((IEnumerable<long> values) =>
                                                   PatientGroupList != null ? string.Join(", ", PatientGroupList
                                                       .Where(g => values != null && values.Contains(g.Id))
                                                       .Select(g => g.Title)) : "Yükleniyor...")">
                @if (PatientGroupList != null)
                {
                    @foreach (var group in PatientGroupList)
                    {
                        <MudSelectItem T="long" Value="@group.Id">@group.Title</MudSelectItem>
                    }
                }
            </MudSelect>
        </AuthorizeView>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Immediate="true" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel InitialDirection="SortDirection.Ascending" SortBy="new Func<Patient, object>(x => x.LastName)">ФИО</MudTableSortLabel>
            <MudTextField @bind-Value="@_filterName" Placeholder="Поиск..." Immediate="true" Class="mt-0"></MudTextField>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Patient, object>(x => x.Inn)">ИНН</MudTableSortLabel>
            <MudTextField @bind-Value="@_filterInn" Placeholder="Поиск..." Immediate="true" Class="mt-0"></MudTextField>
        </MudTh>
        @*<MudTh>Фото</MudTh>*@
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Patient, object>(x => x.Address)">Адрес</MudTableSortLabel>
            <MudTextField @bind-Value="@_filterAddress" Placeholder="Поиск..." Immediate="true" Class="mt-0"></MudTextField>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Patient, object>(x => x.Phone)">Телефон</MudTableSortLabel>
            <MudTextField @bind-Value="@_filterPhone" Placeholder="Поиск..." Immediate="true" Class="mt-0"></MudTextField>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Patient, object>(x => x.BirthDate)">Дата рожд.</MudTableSortLabel>
            <MudTextField @bind-Value="@_filterBirthDate" Placeholder="дд.мм.гггг" Immediate="true" Class="mt-0"></MudTextField>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Patient, object>(x => x.GroupId)">Статус</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Patient, object>(x => x.CreatedOn)">Дата рег.</MudTableSortLabel>
            <MudTextField @bind-Value="@_filterCreatedOn" Placeholder="дд.мм.гггг" Immediate="true" Class="mt-0"></MudTextField>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Patient, object>(x => x.DeletedOn)">Дата выб.</MudTableSortLabel>
            <MudTextField @bind-Value="@_filterDeletedOn" Placeholder="дд.мм.гггг" Immediate="true" Class="mt-0"></MudTextField>
        </MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.LastName  @context.FirstName</MudTd>
        
        <MudTd>@context.Inn</MudTd>
        @*<MudTd>
            @{
                if (!String.IsNullOrEmpty(context.Image))
                {
                    <img src="/UploadImages/@context.Image" height="90" />
                }
            }
        </MudTd>*@
        <MudTd>@context.Address <br />@context.Address2</MudTd>
        <MudTd>@context.Phone <br />@context.Phone2</MudTd>
        <MudTd>@context.BirthDate?.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>
            @{
                foreach (var item in PatientGroupList)
                {
                    if (context.GroupId == item.Id)
                    {
                        <MudText>@item.Title</MudText>
                    }
                }                
            }
         </MudTd>
        <MudTd>@context.CreatedOn.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>@context.DeletedOn?.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>
            @{
                if (viewButton)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Удалить" @onclick="@(async() => await DeleteModel(context.Id))" Size="Size.Small" Color="Color.Warning"></MudIconButton>
                }
            }
        </MudTd>
        <MudTd>  
            @{
                if (hasEditRight)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Редактировать" @onclick="@(async() => await AddEditModal(context.Id))" Size="Size.Small" Color="Color.Warning"></MudIconButton>
                }
            }        
        </MudTd>
       

    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private string _filterName;
    private string _filterInn;
    private string _filterAddress;
    private string _filterPhone;
    private string _filterBirthDate;
    private string _filterCreatedOn;
    private string _filterDeletedOn;


    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private string quickString = "";
    private Patient selectedItem1 = null;
    private bool hasEditRight = false;
    private bool viewButton = false;
    private bool tableLoading = false;
    private HashSet<Patient> selectedItems = new HashSet<Patient>();

    private List<PatientGroup> PatientGroupList { get; set; }

    private IEnumerable<Patient> Elements = new List<Patient>();

    private List<Patient> Data { get; set; }
    private string _value = "Nothing selected";
    private IEnumerable<string> _options = new HashSet<string> {};
    public class StateItem
    {
        public int Id { get; set; }
        public string Name { get; set; }
    }

    private IEnumerable<long> _selectedStateIds = new List<long>();

    // Обновите метод GetSelectedStateNames
    private string GetSelectedStateNames() 
    {
        if (PatientGroupList == null) return "Загрузка...";
    
        var names = PatientGroupList
            .Where(g => _selectedStateIds.Contains(g.Id))
            .Select(g => g.Title);
    
        return names.Any() ? string.Join(", ", names) : "Ничего не выбрано";
    }

    // Обновите обработчик выбора
    private async Task OnSelectionChanged(IEnumerable<long> selectedIds) { // Изменено на long
        _selectedStateIds = selectedIds;
        StateHasChanged();
        await FilterButton();
    }

// Replace your existing FilterButton method
    private async Task FilterButton() 
    {
        await LoadDataAsync();
        if (_selectedStateIds != null && _selectedStateIds.Any()) 
        {
            // Явное преобразование GroupId (long?) в long
            Elements = Data.Where(p => 
                    p.GroupId.HasValue && 
                    _selectedStateIds.Contains(p.GroupId.Value) // Используем .Value для long?
            );
        } 
        else 
        {
            Elements = Data;
        }
    }
    
    protected override async Task OnInitializedAsync()
    {
        var authstate = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
        var user = authstate.User;
        viewButton = user.IsInRole("admin");
        //var locService = new WeatherForecastService();
        //Data = locService.GetForecast().ToList();
        //Console.WriteLine(Data);
        tableLoading = true;
        await LoadGroupDataAsync();
        await FilterButton();
    }
    private DateTime? GenerateBirthDateFromInn(string inn)
    {
        if (inn.Length > 14)
        {
            // Geçersiz INN formatı
            return  null;
        }

        try
        {
            // Günü belirlemek için ilk üç harfi alıyoruz
            int day = int.Parse(inn.Substring(1, 2));

            // Ayı belirlemek için dördüncü ve beşinci harfleri alıyoruz
            int month = int.Parse(inn.Substring(3, 2));

            // Yılı belirlemek için altıncı, yedinci, sekizinci ve dokuzuncu harfleri alıyoruz
            int year = int.Parse(inn.Substring(5, 4));

            // Geçerli bir doğum tarihi oluşturuyoruz
            return new DateTime(year, month, day);
        }
        catch (Exception)
        {
            // Doğum tarihi oluşturulamadı
            return null;
        }
    }
    private async Task LoadDataAsync()
    {

        var response = await Http.GetAsync("api/patient/allpatients");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<Patient>>();
        Elements = mappedData.Data;
        Data = mappedData.Data;
        foreach (var element in Elements)
        {
            if (element.BirthDate == null)
            {
                var date = GenerateBirthDateFromInn(element.Inn);
                if (date != null)
                {
                    element.BirthDate = date;
                }
                else
                {
                    element.BirthDate = DateTime.Now;
                }
                var res = await _httpClient.PostAsJsonAsync("api/patient/addpatient", element);
                var result = await res.ToResult();
                if (!result.Succeeded)
                {
                    _snackBar.Add(result.Messages[0], Severity.Error);
                }
                else
                {
                    _snackBar.Add("Успешно", Severity.Success);
                }
            }
        }
        tableLoading = false;
    }

    private Func<Patient, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(quickString))
            return true;

        if (x.FirstName.Contains(quickString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.LastName.Contains(quickString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Inn.Contains(quickString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };


    private bool FilterFunc1(Patient element) => FilterFunc(element, searchString1);

    private bool FilterFunc(Patient element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString) && 
            string.IsNullOrWhiteSpace(_filterName) &&
            string.IsNullOrWhiteSpace(_filterInn) &&
            string.IsNullOrWhiteSpace(_filterAddress) &&
            string.IsNullOrWhiteSpace(_filterPhone) &&
            string.IsNullOrWhiteSpace(_filterBirthDate) &&
            string.IsNullOrWhiteSpace(_filterCreatedOn) &&
            string.IsNullOrWhiteSpace(_filterDeletedOn))
            return true;

        var matchesSearch = string.IsNullOrWhiteSpace(searchString) || 
            element.FirstName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
            element.LastName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
            element.Inn?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true;

        var matchesName = string.IsNullOrWhiteSpace(_filterName) ||
            $"{element.LastName} {element.FirstName}".Contains(_filterName, StringComparison.OrdinalIgnoreCase);

        var matchesInn = string.IsNullOrWhiteSpace(_filterInn) ||
            element.Inn?.Contains(_filterInn, StringComparison.OrdinalIgnoreCase) == true;

        var matchesAddress = string.IsNullOrWhiteSpace(_filterAddress) ||
            (element.Address?.Contains(_filterAddress, StringComparison.OrdinalIgnoreCase) == true ||
             element.Address2?.Contains(_filterAddress, StringComparison.OrdinalIgnoreCase) == true);

        var matchesPhone = string.IsNullOrWhiteSpace(_filterPhone) ||
            (element.Phone?.Contains(_filterPhone, StringComparison.OrdinalIgnoreCase) == true ||
             element.Phone2?.Contains(_filterPhone, StringComparison.OrdinalIgnoreCase) == true);

        var matchesBirthDate = string.IsNullOrWhiteSpace(_filterBirthDate) ||
            (element.BirthDate?.ToString("dd.MM.yyyy")?.Contains(_filterBirthDate) == true);

        var matchesCreatedOn = string.IsNullOrWhiteSpace(_filterCreatedOn) ||
            element.CreatedOn.ToString("dd.MM.yyyy").Contains(_filterCreatedOn);

        var matchesDeletedOn = string.IsNullOrWhiteSpace(_filterDeletedOn) ||
            (element.DeletedOn?.ToString("dd.MM.yyyy")?.Contains(_filterDeletedOn) == true);

        return matchesSearch && matchesName && matchesInn && matchesAddress && 
               matchesPhone && matchesBirthDate && matchesCreatedOn && matchesDeletedOn;
    }


    private async Task LoadGroupDataAsync()
    {
        var response = await Http.GetAsync("api/status/allgroups");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<PatientGroup>>();
        PatientGroupList = mappedData.Data;
    }


    private async Task AddEditModal(long id = 0)
    {
        var parameters = new DialogParameters();
        if (id != 0)
        {
            var selItem = Elements.Where(t => t.Id == id).FirstOrDefault();
            parameters.Add("AddEditModel", selItem);
        }
        else
        {
            var newModel = new Patient();
            parameters.Add("AddEditModel", newModel);
        }
        parameters.Add("id", id);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<PatientAddEdit>(id == 0 ? "Добавить Пациент" : "Редактировать Пациент", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync();
        }
    }
    private async Task DeleteModel(long id = 0)
    {
        var selItem = Elements.Where(t => t.Id == id).FirstOrDefault();
        var response = await _httpClient.PostAsJsonAsync("api/patient/deletepatient", selItem);
        var result = await response.ToResult();
        await LoadDataAsync();
    }


}
