@using Dialysis.Shared.Dto

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Детали действия #@Log?.Id</MudText>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 70vh; overflow-y: auto; overflow-x: hidden;">
        @if (Log != null)
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2">Основная информация</MudText>
            <MudSimpleTable Dense="true" Class="my-2">
                <tbody>
                    <tr><td><strong>Дата:</strong></td><td>@Log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td></tr>
                    <tr><td><strong>Пользователь:</strong></td><td>@Log.UserName</td></tr>
                    <tr><td><strong>Действие:</strong></td><td>@Log.ActionType</td></tr>
                    <tr><td><strong>Сущность:</strong></td><td>@Log.EntityType</td></tr>
                    <tr><td><strong>ID сущности:</strong></td><td>@Log.EntityId</td></tr>
                    <tr><td><strong>Описание:</strong></td><td>@Log.Description</td></tr>
                    <tr><td><strong>IP:</strong></td><td>@Log.UserIp</td></tr>
                </tbody>
            </MudSimpleTable>

            @if (!string.IsNullOrEmpty(Log.OldValues))
            {
                <MudText Typo="Typo.subtitle2" Class="mt-4">Старые значения</MudText>
                <MudExpansionPanel Text="Старые значения">
                    <MudTextField T="string" Variant="Variant.Outlined" ReadOnly="true"
                                  Rows="8" Lines="8"
                                  Text="@FormatJson(Log.OldValues)" />
                </MudExpansionPanel>
            }

            @if (!string.IsNullOrEmpty(Log.NewValues))
            {
                <MudText Typo="Typo.subtitle2" Class="mt-4">Новые значения</MudText>
                <MudExpansionPanel Text="Новые значения">
                    <MudTextField T="string" Variant="Variant.Outlined" ReadOnly="true"
                                  Rows="8" Lines="8"
                                  Text="@FormatJson(Log.NewValues)" />
                </MudExpansionPanel>
            }
        }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))">
            Закрыть
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; }

    [Parameter] public ActionLogDto? Log { get; set; }

    private string FormatJson(string? text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        try
        {
            var obj = System.Text.Json.JsonSerializer.Deserialize<object>(text);
            return System.Text.Json.JsonSerializer.Serialize(obj, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return text;
        }
    }
}
