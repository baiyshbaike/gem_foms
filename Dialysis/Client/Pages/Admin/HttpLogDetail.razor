@using Dialysis.Shared.Dto

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Детали HTTP запроса #@Log?.Id</MudText>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 70vh; overflow-y: auto; overflow-x: hidden;">
        @if (Log != null)
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2">Основная информация</MudText>
            <MudSimpleTable Dense="true" Class="my-2">
                <tbody>
                    <tr><td><strong>Дата:</strong></td><td>@Log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td></tr>
                    <tr><td><strong>Метод:</strong></td><td>@Log.HttpMethod</td></tr>
                    <tr><td><strong>Путь:</strong></td><td>@Log.Path</td></tr>
                    <tr><td><strong>Query:</strong></td><td>@Log.QueryString</td></tr>
                    <tr><td><strong>Статус:</strong></td><td>@Log.StatusCode</td></tr>
                    <tr><td><strong>Время:</strong></td><td>@Log.DurationMs ms</td></tr>
                    <tr><td><strong>IP:</strong></td><td>@Log.IpAddress</td></tr>
                    <tr><td><strong>Пользователь:</strong></td><td>@Log.UserName</td></tr>
                </tbody>
            </MudSimpleTable>

            <MudText Typo="Typo.subtitle2" Class="mt-4">Заголовки запроса</MudText>
            <MudExpansionPanel Text="Заголовки">
                <MudTextField T="string" Variant="Variant.Outlined" ReadOnly="true"
                              Rows="8" Lines="8"
                              Text="@FormatJson(Log.RequestHeaders)" />
            </MudExpansionPanel>

            <MudText Typo="Typo.subtitle2" Class="mt-4">Тело запроса</MudText>
            <MudExpansionPanel Text="Тело запроса">
                <MudTextField T="string" Variant="Variant.Outlined" ReadOnly="true"
                              Rows="8" Lines="8"
                              Text="@FormatJson(Log.RequestBody)" />
            </MudExpansionPanel>

            <MudText Typo="Typo.subtitle2" Class="mt-4">Заголовки ответа</MudText>
            <MudExpansionPanel Text="Заголовки ответа">
                <MudTextField T="string" Variant="Variant.Outlined" ReadOnly="true"
                              Rows="6" Lines="6"
                              Text="@FormatJson(Log.ResponseHeaders)" />
            </MudExpansionPanel>

            <MudText Typo="Typo.subtitle2" Class="mt-4">Тело ответа</MudText>
            <MudExpansionPanel Text="Тело ответа">
                <MudTextField T="string" Variant="Variant.Outlined" ReadOnly="true"
                              Rows="8" Lines="8"
                              Text="@FormatJson(Log.ResponseBody)" />
            </MudExpansionPanel>
        }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))">
            Закрыть
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; }

    [Parameter] public HttpLogDto? Log { get; set; }

    private string FormatJson(string? text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        try
        {
            var obj = System.Text.Json.JsonSerializer.Deserialize<object>(text);
            return System.Text.Json.JsonSerializer.Serialize(obj, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return text;
        }
    }
}
