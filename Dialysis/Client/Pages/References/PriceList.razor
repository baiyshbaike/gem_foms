@page "/activeprice"
@using System.Net.Http.Json
@inject HttpClient Http


<MudTable Items="@Elements" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" Filter="new Func<ActivePrice,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Цена</MudText>
        &nbsp;&nbsp;
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Hotel" Size="Size.Small" Color="Color.Info" @onclick="@(() => AddEditModal(0))">Добавить</MudButton>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Id</MudTh>        
        <MudTh>Цена(сом)</MudTh>
        <MudTh>Название</MudTh>
        <MudTh>Статус</MudTh>
        <MudTh>Дата</MudTh>     
        <MudTh>Дата до</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Id">@context.Id</MudTd>
        <MudTd>
            @{
                if (!context.IsDeleted)
                {
                    <b>@context.Price</b>
                }
                else
                {
                    @context.Price
                }
            }
        </MudTd>
        <MudTd>@context.Title</MudTd>
        <MudTd>
                @{
                    if(context.IsDeleted){
                        <MudText>Архив</MudText>
                    }else{
                        <MudText>Актив</MudText>
                    }
                }
        </MudTd>
        <MudTd DataLabel="Дата">@context.CreatedOn?.ToString("dd.MM.yyyy")</MudTd>
        <MudTd DataLabel="">
            @context.DeletedOn?.ToString("dd.MM.yyyy")
        </MudTd>


    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private bool tableLoading = false;
    private ActivePrice selectedItem1 = null;
    private HashSet<ActivePrice>
    selectedItems = new HashSet<ActivePrice>();

    private IEnumerable<ActivePrice> Elements = new List<ActivePrice>();

    protected override async Task OnInitializedAsync()
    {
        tableLoading = true;
        await LoadDataAsync();
    }

  

    private async Task LoadDataAsync()
    {
        var response = await Http.GetAsync("api/status/allprices");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<ActivePrice>>();
        Elements = mappedData.Data;
        tableLoading = false;
    }

    private bool FilterFunc1(ActivePrice element) => FilterFunc(element, searchString1);

    private bool FilterFunc(ActivePrice element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        /*if (element.Adress.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;*/
        return false;
    }

    private async Task AddEditModal(int id = 0)
    {
        var parameters = new DialogParameters();

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<PriceAddEdit>(id == 0 ? "Добавить Цена" : "Редактировать Цена", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync();
        }
    }

}
