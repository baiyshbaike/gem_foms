@page "/reportlist"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Large">
       
    @if (showTable)
    {
        <MudTable Items="@Elements" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped">
            <ToolBarContent>
            <MudText Typo="Typo.h6">Отчеты</MudText>
            &nbsp;&nbsp;
           
            <MudSpacer />
          </ToolBarContent>
       
        <RowTemplate>
                <MudTd>@context </MudTd>
             
            <MudTd>
                    <MudButton Variant="Variant.Filled" @onclick="@(()=> OpenReport(context))" StartIcon="@Icons.Material.Filled.MedicalInformation" Size="Size.Small" Color="Color.Info">Открыть</MudButton>
           </MudTd>
          
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
    }

</MudContainer>


@code {

    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private string quickString = "";
    private MedCardListDto selectedItem1 = null;
    private bool showTable = false;

    private bool tableLoading = false;


    //private HashSet<MedCardDto> selectedItems = new HashSet<MedCardDto>();
    private IEnumerable<string> Elements = new List<string>();


    protected override async Task OnInitializedAsync()
    {
        await SearchAsync();
        //await JSRuntime.InvokeVoidAsync("startVideo", "videoFeed");
        if (Elements != null)
        {
            if(Elements.Count() > 0)
            {
                showTable = true;
            }
        }

    }
    private async Task SearchAsync()
    {
        tableLoading = true;
        showTable = true;
        

        var response = await Http.GetAsync("api/report/allreports");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<string>>();
        Elements = mappedData.Data;
        if (Elements != null)
        {
            tableLoading = false;
        }
    }

    private async Task OpenReport(string repTitle)
    {
        if (repTitle!="")
        {
            _navigationManager.NavigateTo("/repview/" + repTitle);
        }
    }

   

}
