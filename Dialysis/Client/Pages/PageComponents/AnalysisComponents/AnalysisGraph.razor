@using System.Net.Http.Json
@inject HttpClient Http


<MudTable Items="@Elements" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" RowsPerPage=100 Filter="new Func<Analysis,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6"> Анализы</MudText>
        &nbsp;&nbsp;
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Название</MudTh>
        <MudTh>Ед. измерения</MudTh>
        <MudTh></MudTh>
        <MudTh>Повт. каждые(день)</MudTh>
        <MudTh>Пос.  дата Анализа</MudTh>
        <MudTh>Следующая дата Анализа</MudTh>
        <MudTh>&nbsp;</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Title</MudTd>
        <MudTd>@context.AnalysisExt</MudTd>
        <MudTd>@context.Note2</MudTd>
        <MudTd>@context.NextDays</MudTd>
        <MudTd>@GetAnalysisDate(context.Id)</MudTd>
        <MudTd Style="@(IsDatePast(context.Id, (long)context.NextDays) ? "background-color:red;":"")"><b>@GetNextAnalysisDate(context.Id, (long)context.NextDays) </b></MudTd>
        <MudTd>           
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>


@code {

    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private bool tableLoading = false;

    [Parameter]
    public long MedCardId { get; set; }
    private long IsCard { get; set; }
    private MedCard ownCard { get; set; }

    private Analysis selectedItem1 = null;
    private HashSet<Analysis>
    selectedItems = new HashSet<Analysis>();

    private IEnumerable<Analysis> Elements = new List<Analysis>();

    private IEnumerable<AnalysisResultsDto> AnalysisResults = new List<AnalysisResultsDto>();
    public Patient PatientModel { get; set; }

    private MedCardDto item { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (MedCardId > 0)
        {
            await LoadDataAsync();
            await LoadPatientAsync();
            await LoadMCardDataAsync();
        }
    }

    private string GetAnalysisDate(long analysesId)
    {
        var retVal = "";
        var selItem = AnalysisResults.Where(t => t.AnalysisResult.AnalysisId == analysesId).OrderByDescending(p=>p.AnalysisResult.AnalysisDate).FirstOrDefault();
        if (selItem != null)
        {
            retVal = selItem.AnalysisResult.AnalysisDate?.ToString("dd.MM.yyyy");
        }
        return retVal;
    } 

    private bool IsDatePast(long analysesId, long nextDate)
    {
        DateTime dateTimeNow = DateTime.Now.Date;
        var selItem = AnalysisResults.Where(t => t.AnalysisResult.AnalysisId == analysesId).OrderByDescending(p => p.AnalysisResult.AnalysisDate).FirstOrDefault();
        if(selItem != null)
        {
            var dateTime = ((DateTime)selItem.AnalysisResult.AnalysisDate).AddDays(nextDate);
            if (dateTimeNow > dateTime){
                return true;
            }
        }
        else
        {
            if (nextDate > 0)
            {
                var startDate = item.MedCard.ReceiptDate;
                if (startDate != null)
                {
                    var dateTime = ((DateTime)startDate).AddDays(nextDate);
                    if (dateTimeNow > dateTime)
                    {
                        return true;
                    }
                }
                else
                {
                    var dateTime = ((DateTime)item.MedCard.CreatedOn).AddDays(nextDate);
                    if (dateTimeNow > dateTime)
                    {
                        return true;
                    }
                }
            }
        }
        return false;
    }
    private string GetNextAnalysisDate(long analysesId, long nextDate)
    {
        var retVal = "";
        var selItem = AnalysisResults.Where(t => t.AnalysisResult.AnalysisId == analysesId).OrderByDescending(p => p.AnalysisResult.AnalysisDate).FirstOrDefault();
        if (selItem != null)
        {
            retVal = ((DateTime)selItem.AnalysisResult.AnalysisDate).AddDays(nextDate).ToString("dd.MM.yyyy");
        }
        else
        {
            if (nextDate > 0)
            {
                var startDate = item.MedCard.ReceiptDate;
                if (startDate != null)
                {
                    retVal = ((DateTime)startDate).AddDays(nextDate).ToString("dd.MM.yyyy");
                }
                else
                {
                    retVal = ((DateTime)item.MedCard.CreatedOn).AddDays(nextDate).ToString("dd.MM.yyyy");
                }
            }
        }
        return retVal;
    }

    private async Task LoadMCardDataAsync()
    {
        var response = await Http.GetAsync("api/medcard/carddetail?medcardId=" + MedCardId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        else
        {
            var mappedData = await response.ToResult<MedCardDto>();
            item = mappedData.Data;
        }
    }

    private async Task LoadDataAsync()
    {
        tableLoading = true;
        var response = await Http.GetAsync("api/status/allanalysis");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<Analysis>>();
        Elements = mappedData.Data;
        tableLoading = false;
    }

    private bool FilterFunc1(Analysis element) => FilterFunc(element, searchString1);

    private bool FilterFunc(Analysis element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        /*if (element.Adress.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;*/
        return false;
    }

    private async Task LoadPatientAsync()
    {
        var response = await Http.GetAsync("api/patient/getbymedcard?medcardId=" + MedCardId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }

        var mappedData = await response.ToResult<Patient>();
        PatientModel = mappedData.Data;
        if (PatientModel != null)
        {
            await LoadAnalysesAsync();
        }
    }

    private async Task LoadAnalysesAsync()
    {
        var response = await Http.GetAsync("api/medcard/analysesbyinn?inn=" + PatientModel.Inn);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<AnalysisResultsDto>>();
        AnalysisResults = mappedData.Data;
    }

}
