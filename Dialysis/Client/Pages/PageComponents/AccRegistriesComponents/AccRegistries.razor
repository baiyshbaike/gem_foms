@inject IJSRuntime jsRuntime
@inject HttpClient Http


<MudContainer MaxWidth="MaxWidth.Large">
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="long" Label="Мед. центр" @bind-Value="@searchModel.MedCenterId" AnchorOrigin="Origin.BottomCenter" Disabled="@IsOnlyCenter">
                    @{
                        if (!IsOnlyCenter)
                        {
                            <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                        }
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
             <MudItem xs="12" md="2">
                        <MudDatePicker Label="Дата от" @bind-Date="dateFrom" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
                    </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Дата до" @bind-Date="dateTo" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
            </MudItem>
            <MudItem xs="2" md="2">
                <MudSelect T="long" Label="Статус" @bind-Value="@searchModel.Status" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                    <MudSelectItem T="long" Value="5">К оплате</MudSelectItem>
                    <MudSelectItem T="long" Value="6">Оплачено</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="12">
                <MudCardActions>
                    <br />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async() => await LoadSessionsAsync())">Обновить</MudButton>
                </MudCardActions>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>


<MudTable Items="@Elements" Loading="@tableLoading" RowsPerPage=1000 Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped"
          Virtualize=false
          GroupBy="@_groupDefinition"        
          GroupFooterClass="mb-4">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Счет реестр </MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" @onclick="@(async()=> await PrintModal())" StartIcon="@Icons.Material.Filled.MapsHomeWork" Size="Size.Small" Color="Color.Info">Печать</MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>ФИО</MudTh>
        <MudTh>ИНН</MudTh>
        <MudTh>Сеансы</MudTh>
        <MudTh>Счет</MudTh>       
    </HeaderContent>
    <GroupHeaderTemplate>
        <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" Style="font-size:18px; font-weight:600;">@($"{context.GroupName}: {UserCenters.Where(u=>u.Id.Equals(context.Key)).FirstOrDefault().Title}")</MudTh>
        <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" Style="font-size:18px; font-weight:600; text-align:right !important;">Итого:</MudTh>
        <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" Style="font-size:18px; font-weight:600;"> @context.Items.Sum((e) => e.CountHd)</MudTh>
        <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" Style="font-size:18px; font-weight:600;"> @context.Items.Sum((e) => e.TotalPrice)</MudTh>
    </GroupHeaderTemplate>
    <RowTemplate>
        <MudTd>@context.Fio</MudTd>
        <MudTd>@context.Inn</MudTd>
        <MudTd>@context.CountHd</MudTd>
        <MudTd>@context.TotalPrice</MudTd>        
    </RowTemplate>
    <GroupFooterTemplate>
        
    </GroupFooterTemplate>
   
</MudTable>


@code {
    [Parameter]
    public UserDto userDto { get; set; }
    [Parameter]
    public long? Mid { get; set; }
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private IEnumerable<AccountRegistryDto> Elements = new List<AccountRegistryDto>();
    private AccountRegMedCenterDto BigElements = new AccountRegMedCenterDto();
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();

    private SearchtDto searchModel = new SearchtDto();
    private bool IsOnlyCenter = true;
    private bool tableLoading = true;

    private DateTime? dateFrom = DateTime.Today.AddMonths(-1);
    private DateTime? dateTo = DateTime.Today;
    private DateTime dateToLocal = DateTime.Today.AddDays(1);
    private bool role = true;
    private decimal itog;
    private int count50;
    private int count75;
    private int count100;
    private int countHd;

    private TableGroupDefinition<AccountRegistryDto> _groupDefinition = new()
        {
            GroupName = "Мед. центр",
            Indentation = false,
            Expandable = false,
            Selector = (e) => e.MedcenterId
        };

    protected override async Task OnInitializedAsync()
    {
        await LoadUserCentersAsync();
        if (Mid != null)
        {
            searchModel.MedCenterId = (long)Mid;
            await LoadSessionsAsync();
        }
        else
        {
            await LoadSessionsAsync();
        }       
        StateHasChanged();
    }
    private async Task LoadSessionsAsync()
    {
        tableLoading = true;

        string dFrom = "";
        string dTo = "";
        if (dateFrom != null)
        {
            dFrom = dateFrom?.ToString("yyyyMMdd");
        }
        var dateToLocal = DateTime.Today;
        if (dateTo != null)
        {
            var newToDate = Convert.ToDateTime(dateTo);
            dateToLocal = newToDate;
            dTo = dateToLocal.ToString("yyyyMMdd");
        }

        string searchParams = "&fromDate=" + dFrom + "&toDate=" + dTo +"&statusid=" + searchModel.Status;
        if (IsOnlyCenter && searchModel.MedCenterId == 0 && UserCenters.Count() == 1)
        {
            searchModel.MedCenterId = UserCenters.First().Id;
        }
        var response = await Http.GetAsync("api/excell/accregistries?medCenterId=" + searchModel.MedCenterId + "" + searchParams);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<AccountRegMedCenterDto>();
        if (mappedData?.Data != null)
        {
            BigElements = mappedData.Data;
            Elements = mappedData.Data.AccountRegistries;
            //totalCount = Elements.Count();
        }        
        tableLoading = false;
    }

    private async Task LoadSessions2Async()
    {
        string dFrom = "";
        string dTo = "";
        if (dateFrom != null)
        {
            dFrom = dateFrom?.ToString("yyyyMMdd");
        }
        var dateToLocal = DateTime.Today.AddDays(1);
        if (dateTo != null)
        {
            var newToDate = Convert.ToDateTime(dateTo);
            dateToLocal = newToDate.AddDays(1);
            dTo = dateToLocal.ToString("yyyyMMdd");
        }

        string searchParams = "&fromDate=" + dFrom + "&toDate=" + dTo;
        //string searchParams = "&fromDate=" + dateFrom + "&toDate=" + dateToLocal;
        var url = "api/excell/accregistriesdown?medCenterId=" + searchModel.MedCenterId + "" + searchParams;
        await jsRuntime.InvokeAsync<object>("open", url, "_blank");       
    }

    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                IsOnlyCenter = false;
                searchModel.MedCenterId = 0;
            }
            else if (UserCenters.Count() == 1)
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = UserCenters.First().Id;
            }
            else
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = 0;
            }
        }
    }


    public class SearchtDto
    {
        public long MedCenterId { get; set; }
        public string Inn { get; set; }
        public string Image { get; set; }
        public long Status { get; set; }
    }
    private async Task PrintModal()
    {
        string dFrom = "";
        string dTo = "";
        if (dateFrom != null)
        {
            dFrom = dateFrom?.ToString("yyyyMMdd");
        }
        var dateToLocal = DateTime.Today.AddDays(1);
        if (dateTo != null)
        {
            var newToDate = Convert.ToDateTime(dateTo);
            dateToLocal = newToDate.AddDays(1);
            dTo = dateToLocal.ToString("yyyyMMdd");
        }
        /*foreach (var item in Elements)
        {
            count50 += item.Count50 ?? 0;
            count75 += item.Count75 ?? 0;
            count100 += item.Count100 ?? 0;
            countHd += item.CountHd;
        }*/
        string searchParams = "&fromDate=" + dFrom + "&toDate=" + dTo;
        var url = searchModel.MedCenterId + "" + searchParams;
        var parameters = new DialogParameters();
        if (searchModel.MedCenterId == 0)
        {   
            parameters.Add("medcenter","Все медцентры");
        }
        else
        {
            parameters.Add("medcenter",UserCenters.FirstOrDefault(e=>e.Id.Equals(searchModel.MedCenterId)).Title);
        }
        parameters.Add("url", url);
        parameters.Add("dateFrom", dateFrom);
        parameters.Add("dateTo", dateTo);
        parameters.Add("BigElements", BigElements);
        parameters.Add("itog",BigElements.TotalPrice);
        parameters.Add("countHD", BigElements.AccountRegistries.Sum(e=>e.CountHd));

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<Dialysis.Client.Pages.GridReports.AccRegistriesPrint>("Подробности", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadSessionsAsync();
        }
    }

}

