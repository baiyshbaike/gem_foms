
<MudTabs Outlined="true"  Rounded="true" Border="true"
         ApplyEffectsToContainer="true" Class="mt-8" PanelClass="pa-6" @bind-ActivePanelIndex="activeSubTab">   
    <MudTabPanel Text="Анализы и результаты">

        @{
            if (activeSubTab == 0)
            {
                <Dialysis.Client.Pages.PageComponents.PatientAnalysis MedCardId=MedCardId />
            }
        }

    </MudTabPanel>
    <MudTabPanel Text="График анализа">

        @{
            if (activeSubTab == 1)
            {
                <Dialysis.Client.Pages.PageComponents.AnalysisComponents.AnalysisGraph MedCardId=MedCardId />
            }
        }

    </MudTabPanel>
</MudTabs>


@code {
    int activeSubTab = 0;
    [Parameter]
    public long MedCardId { get; set; }
}
