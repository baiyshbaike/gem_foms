@code {
    [Parameter]
    public long MedCardId { get; set; }


    private FirstCardiovascular item { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }
    private async Task LoadDataAsync()
    {
        var response = await Http.GetAsync("api/medcard/getcardio?medcardId=" + MedCardId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        else
        {
            var mappedData = await response.ToResult<FirstCardiovascular>();
            if (mappedData.Data != null)
            {
                item = mappedData.Data;
            }
        }
    }

    private async Task AddEditModal(long id = 0)
    {
        var locId = 0;
        var parameters = new DialogParameters();
        parameters.Add("MedCardId", id);
        if (item != null)
        {
            parameters.Add("AddEditModel", item);
        }
        else
        {
            parameters.Add("AddEditModel", new FirstCardiovascular());
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<FCardiovascularAddEdit>(locId == 0 ? "Добавить" : "Редактировать", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync();
        }
    }
}
