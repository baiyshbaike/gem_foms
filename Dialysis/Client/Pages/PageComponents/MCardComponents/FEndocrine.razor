@using System.Net.Http.Json
@inject HttpClient Http
@{
    <MudGrid>
    @if (item == null)
    {
            <MudItem xs="12" md="12">
                <MudButton @onclick="@(async() => await AddEditModal(MedCardId))"
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.MapsHomeWork"
                           Size="Size.Small" Color="Color.Info">
                    Добавить
                </MudButton>
            </MudItem>
    }
    else
    {
            <MudItem xs="12" md="12" Style="text-align:right;">
                <MudButton @onclick="@(async() => await AddEditModal(MedCardId))"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.MapsHomeWork"
                   Size="Size.Small" Color="Color.Info">
                    Редактировать
                </MudButton>
            </MudItem>
     <MudItem xs="12" md="12">
                <MudGrid>
    <MudItem xs="2" md="2" Class="fb600">
        Шитовидная железа
    </MudItem>
    <MudItem xs="10" md="10">
        @item.Shitovidnaia
    </MudItem>
    <MudItem xs="2" md="2" Class="fb600">
        Глазные симптомы
    </MudItem>
    <MudItem xs="10" md="10">
        @item.Glaznaia
    </MudItem>
    <MudItem xs="2" md="2" Class="fb600">
        Потоотделение
    </MudItem>
    <MudItem xs="10" md="10">
        @item.Potootdelenie
    </MudItem>
    <MudItem xs="12" md="12">
    </MudItem>
    <MudItem xs="2" md="2" Class="fb600">
        Прочее
    </MudItem>
    <MudItem xs="10" md="10">
        @item.Prochee
    </MudItem>

    <MudItem xs="12" md="12">
    </MudItem>
</MudGrid>
            </MudItem>
    }
    </MudGrid>

}




@code {
    [Parameter]
    public long MedCardId { get; set; }


    private FirstEndocrine item { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }
    private async Task LoadDataAsync()
    {
        var response = await Http.GetAsync("api/medcard/getendocrine?medcardId=" + MedCardId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        else
        {
            var mappedData = await response.ToResult<FirstEndocrine>();
            if (mappedData.Data != null)
            {
                item = mappedData.Data;
            }
        }
    }

    private async Task AddEditModal(long id = 0)
    {
        var locId = 0;
        var parameters = new DialogParameters();
        parameters.Add("MedCardId", id);
        if (item != null)
        {
            parameters.Add("AddEditModel", item);
        }
        else
        {
            parameters.Add("AddEditModel", new FirstEndocrine());
        }

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<FEndocrineAddEdit>(locId == 0 ? "Добавить" : "Редактировать", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync();
        }
    }
}
