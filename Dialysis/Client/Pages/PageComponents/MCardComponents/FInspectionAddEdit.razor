<MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 500px; overflow-y: scroll">
<MudForm Model="@AddEditModel" @ref="form">
    <MudDialog>
        <TitleContent>
            @{
                if (AddEditModel.Id == 0)
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                        Добавить
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                        Редактировать
                    </MudText>
                }
            }
        </TitleContent>
        <DialogContent>
            <MudContainer Style="max-height: 400px; overflow-y: scroll">

            <MudGrid>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Complaints" Required="true" Label="Жалобы" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Anamnez" Required="true" Label="Анамнез болезни" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.AnamnezLive" Required="true" Label="Анамнез жизни" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudText Typo="Typo.h5">Объективный статус</MudText>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.GeneralState" Required="true" Label="Общее состояние" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                        </MudItem>

                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Rost" Required="true" Label="Рост(см)" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Ves" Required="true" Label="Вес(кг)" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.BodyT" Required="true" Label="t тела" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Grudnoi" Required="true" Label="Антропометриче грудной клетки (см)" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Kozhnye" Required="true" Label="Кожные покровы" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Svet" Required="true" Label="Цвет" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Suhost" Required="true" Label="Сухость" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Uprugost" Required="true" Label="Упругость" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Syp" Required="true" Label="Наличие сыпи" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Pigmentation" Required="true" Label="Пигментаций" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Scars" Required="true" Label="Рубцов" />
                        </MudItem><MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Bedsores" Required="true" Label="Пролежней" />
                        </MudItem><MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Damage" Required="true" Label="Повреждений" />
                        </MudItem><MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Dermographism" Required="true" Label="Дермографизм" />
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="AddEditModel.Jivot" Required="true" Label="Окружность живота(см)" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Oteki" Required="true" Label="Отеки" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Limfaticheskiy" Required="true" Label="Лимфатические узлы" />
                        </MudItem>

                        <MudItem xs="12" md="12"> <MudText Typo="Typo.h5">Опорно-двигательный аппарат</MudText> </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.DeformationOfBones" Required="true" Label="Деформация костей, суставов" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.КednessOfJoints" Required="true" Label="Припухание, покраснение суставов" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.Musculature" Required="true" Label="Мускулатура, сила" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.PainMuscles" Required="true" Label="Боли в мышцах, костях, суставах" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Other"  Label="Прочее" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                        </MudItem>
            </MudGrid>

           </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</MudForm>
</MudContainer>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] 
    public long MedCardId { get; set; }

    [Parameter] public FirstInspection AddEditModel { get; set; }

    //public FirstInspection AddEditModel { get; set; } = new FirstInspection();
    MudForm form;

    protected override async Task OnInitializedAsync()
    {

    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveAsync()
    {
        AddEditModel.MedCardId = MedCardId;
        var response = await _httpClient.PostAsJsonAsync("api/medcard/addinspection", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}
