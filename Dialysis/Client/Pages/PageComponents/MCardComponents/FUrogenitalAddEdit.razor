<MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 500px; overflow-y: scroll">
<MudForm Model="@AddEditModel" @ref="form">
    <MudDialog>
        <TitleContent>
            @{
                if (AddEditModel.Id == 0)
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                        Добавить
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                        Редактировать
                    </MudText>
                }
            }
        </TitleContent>
        <DialogContent>
             <MudContainer Style="max-height: 400px; overflow-y: scroll">
            <MudGrid>
                        <MudItem xs="12" md="12">
                            <MudText Typo="Typo.h4">Мочеиспускание</MudText>
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudTextField @bind-Value="AddEditModel.Chastota" Required="true" Label="Частотат(днем, ноч.)" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudTextField @bind-Value="AddEditModel.Sutochnoe" Required="true" Label="Суточное кол-во" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudTextField @bind-Value="AddEditModel.Rezi" Required="true" Label="Рези, жжение, боль" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudTextField @bind-Value="AddEditModel.Nederjanie" Required="true" Label="Недержание" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudTextField @bind-Value="AddEditModel.SvetMochi" Required="true" Label="Цвет мочи" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12" md="12">
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudText Typo="Typo.h4">Почки</MudText>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="AddEditModel.PochkiPalpatsia" Required="true" Label="Пальпация" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="AddEditModel.PochkiSimptom" Required="true" Label="Симптом поколачивания" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="AddEditModel.PochkiProchee" Required="true" Label="Прочее" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudText Typo="Typo.h4">Мочевой пузырь</MudText>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="AddEditModel.MochevoiPalpatsia" Required="true" Label="Пальпация" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="AddEditModel.MochevoiPerkissia" Required="true" Label="Перкуссия" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="AddEditModel.MochevoiProchee" Required="true" Label="Прочее" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Prochee" Required="true" Label="Прочее" />
                        </MudItem>

                        <MudItem xs="12" md="12">
                        </MudItem>
            </MudGrid>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</MudForm>
</MudContainer>
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public long MedCardId { get; set; }
    [Parameter] public FirstUrogenital AddEditModel { get; set; }

   
    //public FirstUrogenital AddEditModel { get; set; } = new FirstUrogenital();
    MudForm form;

    protected override async Task OnInitializedAsync()
    {

    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveAsync()
    {
        AddEditModel.MedCardId = MedCardId;
        var response = await _httpClient.PostAsJsonAsync("api/medcard/addurogen", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}
