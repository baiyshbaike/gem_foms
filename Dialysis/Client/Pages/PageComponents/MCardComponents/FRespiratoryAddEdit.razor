<MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 500px; overflow-y: scroll">
<MudForm Model="@AddEditModel" @ref="form">
    <MudDialog>
        <TitleContent>
            @{
                if (AddEditModel.Id == 0)
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                        Добавить
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                        Редактировать
                    </MudText>
                }
            }
        </TitleContent>
        <DialogContent>
             <MudContainer Style="max-height: 400px; overflow-y: scroll">
            <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.Nosovoe" Required="true" Label="Носовое дыхание" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.Grudnoi" Required="true" Label="Грудная клетка" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.Tip" Required="true" Label="Тип дыхания" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.Glubina" Required="true" Label="Глубина и ритм дыхания" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.Chastota" Required="true" Label="Частота дыхания" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="AddEditModel.Golosovoe" Required="true" Label="Голосовое дрожание" Lines="2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                        </MudItem>

                        <MudItem xs="12" md="12"> <MudText Typo="Typo.h5">Перкуссия</MudText> </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Sravnitelnaia" Required="true" Label="Сравнительная" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Topograficheskaia" Required="true" Label="Топографическая" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                        </MudItem>
                        <MudItem xs="12" md="12"> <MudText Typo="Typo.h5">Аускультация</MudText> </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Dyhatelnye" Required="true" Label="Дыхательные шумы" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Hrip" Required="true" Label="Хрипы" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="AddEditModel.Prochee" Required="true" Label="Прочее" Lines="3" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                        </MudItem>
            </MudGrid>

            </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</MudForm>
</MudContainer>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public long MedCardId { get; set; }
    [Parameter] public FirstRespiratory AddEditModel { get; set; }
    //public FirstRespiratory AddEditModel { get; set; } = new FirstRespiratory();
    MudForm form;

    protected override async Task OnInitializedAsync()
    {

    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveAsync()
    {
        AddEditModel.MedCardId = MedCardId;
        var response = await _httpClient.PostAsJsonAsync("api/medcard/addrespiratory", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}
