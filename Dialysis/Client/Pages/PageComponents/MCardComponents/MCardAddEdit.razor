                @code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    MudForm form;
    public bool Basic_CheckBox1 { get; set; } = false;
    public bool Basic_CheckBox2 { get; set; } = false;
    public bool Basic_CheckBox3 { get; set; } = false;
    public bool Basic_CheckBox4 { get; set; } = false;
    public bool Basic_CheckBox5 { get; set; } = false;
    public bool Basic_CheckBox6 { get; set; } = false;

    public string blood { get; set; } = "";
    public string resus { get; set; } = "";
    public string outTreatment { get; set; } = "";
    public TimeSpan? time1 = new TimeSpan(00, 00, 00);
    public TimeSpan? time2 = new TimeSpan(00, 00, 00);
    public TimeSpan? time3 = new TimeSpan(00, 00, 00);
    public TimeSpan? time4 = new TimeSpan(00, 00, 00);
    public TimeSpan? time5 = new TimeSpan(00, 00, 00);
    public TimeSpan? time6 = new TimeSpan(00, 00, 00);
    public TimeSpan? time7 = new TimeSpan(00, 00, 00);
    public TimeSpan? time8 = new TimeSpan(00, 00, 00);
    public TimeSpan? time9 = new TimeSpan(00, 00, 00);
    public TimeSpan? time10 = new TimeSpan(00, 00, 00);
    public MedCardSearch searchModel = new MedCardSearch();
    private Patient patient { get; set; } = new();
    public string Fio = "";
    public string pol = "";
    public DateTime? date_of_birth = DateTime.Today;
    public int age = 0;
    public string phoneNum1 = "";
    public string address = "";
    [Parameter] public MedCard AddEditModel { get; set; }
    [Parameter] public long? MedCardId { get; set; }
    private IEnumerable<District> Elements = new List<District>();
    private IEnumerable<Region> RegionList = new List<Region>();
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();
    private IEnumerable<CodeMKB> Codes = new List<CodeMKB>();
    private bool IsOnlyCenter = true;
    private bool IsDisabled = true;
    private bool IsValid;
    DateTime? date = null;
    DateTime? date1 = null;
    DateTime? date2 = null;
    DateTime? date3 = null;
    DateTime? date4 = null;
    DateTime? DiagnosisDate1 = null;
    DateTime? DiagnosisDate2 = null;
    DateTime? DiagnosisDate3 = null;
    DateTime? DiagnosisDate4 = null;
    DateTime? DiagnosisDate5 = null;
    DateTime? DiagnosisDate6 = null;
    DateTime? DiagnosisDate7 = null;
    DateTime? DiagnosisDate8 = null;
    private bool GetDisable()
    {
        if (IsDisabled == false && IsValid == true)
        {
            return false;
        }
        else
        {
            return true;
        }
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadCodeMKBAsync();
        await LoadUserCentersAsync();
        var local = await _commonService.LocalMedCard0Async(null);
        if (local != null)
        {
            AddEditModel = local;
            date = AddEditModel.DirectionDate;//Дата выписки
            date1 = AddEditModel.ReceiptDate;
            date2 = AddEditModel.VgvDate;
            date3 = AddEditModel.VgsDate;
            date4 = AddEditModel.VichDate;
            blood = AddEditModel.Blood;
            resus = AddEditModel.Resus;
            outTreatment = AddEditModel.OutTreatment;
            Basic_CheckBox1 = (AddEditModel.Pedikulez == "да") ? true : false;
            Basic_CheckBox2 = (AddEditModel.Chesotka == "да") ? true : false;
            Basic_CheckBox3 = (AddEditModel.Vassermana == "да") ? true : false;
            Basic_CheckBox4 = (AddEditModel.Fluorografia == "да") ? true : false;
            Basic_CheckBox5 = (AddEditModel.Alchohol == "да") ? true : false;
            Basic_CheckBox6 = (AddEditModel.Familiarized == "да") ? true : false;
            searchModel.Inn = AddEditModel.Inn;

            DiagnosisDate1 = AddEditModel.MainDiagnosisDate;
            DiagnosisDate2 = AddEditModel.Complication1Date;
