@using System.Net.Http.Json
@inject HttpClient Http
<MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 500px; overflow-y: scroll">
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="12" md="12">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.MapsHomeWork" Class="mr-3 mb-n1" />
                    Добавить мед. карта
                </MudText>
            </MudItem>
            <MudItem xs="6" md="4">
                <MudTextField For="@(() => searchModel.Inn)" @bind-Value="searchModel.Inn" Label="ИНН" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchAsync" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Поиск пациента</MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>
    <MudForm @ref="form" Model="@AddEditModel" @bind-IsValid="@IsValid">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField For="@(() => AddEditModel.Inn)" Required="true" @bind-Value="AddEditModel.Inn" Label="ИНН" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField For="@(() => Fio)" Required="true" @bind-Value="Fio" Label="ФИО" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField For="@(() => pol)" Required="true" @bind-Value="pol" Label="Пол" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker PickerVariant="PickerVariant.Dialog" Label="Дата рож." @bind-Date="date_of_birth" DateFormat="dd.MM.yyyy" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField For="@(() => age)" Required="true" @bind-Value="age" Label="Возраст" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField For="@(() => phoneNum1)" Required="true" @bind-Value="phoneNum1" Label="Контакты" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField For="@(() => AddEditModel.PassportNum)" Required="true" @bind-Value="AddEditModel.PassportNum" Label="Нормер паспорта" />
            </MudItem>
            <MudItem xs="12" md="9">
                <MudTextField For="@(() => address)" Required="true" @bind-Value="address" Label="Область/район/село или город проживания" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="long" Label="Мед. центр" Required="true" @bind-Value="@AddEditModel.MedCenterId" AnchorOrigin="Origin.BottomCenter">
                    @{
                        if (IsOnlyCenter == false)
                        {
                            <MudSelectItem T="long" Value="0">-------</MudSelectItem>

                        }
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">

            </MudItem>
            <MudItem xs="12" md="5">
                <MudDatePicker Label="Дата поступления" Required="true" @bind-Date="date1" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTimePicker Label="Время поступления" @bind-Time="time1" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect For="@(() => blood)" Required="true" @bind-Value="blood" Label="Группа крови" AdornmentColor="Color.Primary">
                    <MudSelectItem Value="@("нет")">нет</MudSelectItem>
                    <MudSelectItem Value="@("1")">1</MudSelectItem>
                    <MudSelectItem Value="@("2")">2</MudSelectItem>
                    <MudSelectItem Value="@("3")">3</MudSelectItem>
                    <MudSelectItem Value="@("4")">4</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="5">
