
<MudTabs Outlined="true"  Rounded="true" Border="true" Position="Position.Left"
         ApplyEffectsToContainer="true" Class="mt-8" PanelClass="pa-6" @bind-ActivePanelIndex="activeSubTab">
    <MudTabPanel Text="Мед. карта">
  
            @{
                if (activeSubTab == 0)
                {
                    <Dialysis.Client.Pages.PageComponents.MCardComponents.MCardDetail MedCardId=MedCardId />
                }
            }            
      
    </MudTabPanel>
    <MudTabPanel Text="Перв. осмотр при поступлении">   
  
            @{
                if (activeSubTab == 1)
                {
                    <Dialysis.Client.Pages.PageComponents.MCardComponents.FInspection MedCardId=MedCardId />
                }
            }            
    
    </MudTabPanel>
    <MudTabPanel Text="Система дыхания">    
      
            @{
                if (activeSubTab == 2)
                {
                <Dialysis.Client.Pages.PageComponents.MCardComponents.FRespiratory MedCardId=MedCardId />
                }
            }            
       
    </MudTabPanel>
    <MudTabPanel Text="ССердечно-сосудистая система">        
       
            @{
                if (activeSubTab == 3)
                {
                <Dialysis.Client.Pages.PageComponents.MCardComponents.FCardiovascular MedCardId=MedCardId />
                }
            }
       
    </MudTabPanel>
    <MudTabPanel Text="Система пишеварения">    
       
            @{
                if (activeSubTab == 4)
                {
                <Dialysis.Client.Pages.PageComponents.MCardComponents.FConfectionery MedCardId=MedCardId />
                }
            }
       
    </MudTabPanel>
    <MudTabPanel Text="Мочеполовая система">
       
            @{
                if (activeSubTab == 5)
                {
                <Dialysis.Client.Pages.PageComponents.MCardComponents.FUrogenital MedCardId=MedCardId />
                }
            }
       
    </MudTabPanel>
    <MudTabPanel Text="Эндокринная система">
        
            @{
                if (activeSubTab == 6)
                {
                <Dialysis.Client.Pages.PageComponents.MCardComponents.FEndocrine MedCardId=MedCardId />
                }
            }
       
    </MudTabPanel>
    <MudTabPanel Text="Нервно-психическая система">   
            @{
                if (activeSubTab == 7)
                {
                <Dialysis.Client.Pages.PageComponents.MCardComponents.FNeuro MedCardId=MedCardId />
                }
            }        
    </MudTabPanel>
    <MudTabPanel Text="Лаб-Инструменталных обследований про поступлении">
        @{
            if (activeSubTab == 8)
            {
                <Dialysis.Client.Pages.PageComponents.MCardComponents.FAnalysis MedCardId=MedCardId />
            }
        }
    </MudTabPanel>

    
</MudTabs>


@code {
    int activeSubTab = 0;
    [Parameter]
    public long MedCardId { get; set; } 
}
