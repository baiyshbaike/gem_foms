@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime js
<MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 600px; overflow-y: scroll">
    <MudItem xs="12" md="4">
        <MudButton Variant="Variant.Filled"
        @onclick="@(async() =>  await js.InvokeVoidAsync("printDiv"))" StartIcon="@Icons.Material.Filled.Print"
                    Size="Size.Small" Color="Color.Info">
            Печать pdf
        </MudButton>
        <MudButton Variant="Variant.Filled"
        @onclick="@(async() =>  await js.InvokeVoidAsync("printDivWord", "Epicrisis"))" StartIcon="@Icons.Material.Filled.Print"
                   Size="Size.Small" Color="Color.Info">
            Скачать word
        </MudButton>
    </MudItem>
    <div id="dvPrint" style="line-height:108%;font-family:Calibri;font-size:11pt;">
        <p style="margin:0pt 0pt 8pt; margin-bottom:0pt; text-align:center; line-height:normal; widows:0; orphans:0; font-size:14pt;">
            <strong>
                <span style="font-family:'Times New Roman';">Этапный эпикриз</span>
            </strong>
        </p>
        <p style="margin:0pt 0pt 8pt; margin-bottom:0pt; text-align:center; line-height:normal; widows:0; orphans:0; font-size:12pt;">
            <span style="font-family:'Times New Roman';">За @element.Epicrisis.Started?.ToString("MMM") месяц @element.Epicrisis.Started?.ToString("yyyy") года</span>
        </p>
        <p style="margin:0pt 0pt 8pt; margin-bottom:0pt; line-height:normal; widows:0; orphans:0; font-size:12pt;">
            <span style="font-family:'Times New Roman';">Ф.И.О.  @element.Patient?.LastName @element.Patient?.FirstName @element.Patient?.MiddleName;</span>
        </p>
        <p style="margin:0pt 0pt 8pt; margin-bottom:0pt; line-height:normal; widows:0; orphans:0; font-size:12pt;">
            <span style="font-family:'Times New Roman';">Дата рождения (число, месяц, год)  @element.Patient?.BirthDate?.ToString("dd.MM.yyyy")</span>
        </p>
        <p style="margin:0pt 0pt 8pt; margin-bottom:0pt; line-height:normal; widows:0; orphans:0; font-size:12pt;">
            <span style="font-family:'Times New Roman';">Основной диагноз  @element.Epicrisis.Osn</span>
            </p>
