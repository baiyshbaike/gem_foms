    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public long EpicrisisId { get; set; }
    [Parameter] public EpicrisisDto AddEditModel { get; set; }
    public EpicrisisDto element { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (EpicrisisId > 0)
        {

            await LoadDetailAsync();
        }
    }

    public async Task LoadDetailAsync()
    {
        var response = await Http.GetAsync("api/medcard/getepicrisisdetail?Id=" + EpicrisisId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<EpicrisisDto>();
        element = mappedData.Data;       
    }

    private async Task PrintPdf()
    {
        await js.InvokeVoidAsync("printDiv");
    }
    private async Task PrintWord()
    {
        await js.InvokeVoidAsync("printDivWord", "Epicrisis");
    }

    public void Cancel()
    {
         MudDialog.Cancel();
    }

    
}

