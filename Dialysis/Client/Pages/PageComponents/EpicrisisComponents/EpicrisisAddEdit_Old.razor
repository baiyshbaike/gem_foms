                                <td><MudTextField @bind-Value="AddEditModel.AzotAfter" Label="ммоль/л" /></td>
                                <td class="label-td">Лейк-ты</td>
                                <td><MudTextField @bind-Value="AddEditModel.Leykty" Label="х10/л" /></td>
                            </tr>
                            <tr>
                                <td class="label-td">Креатинин</td>
                                <td><MudTextField @bind-Value="AddEditModel.KreatininDo" Label="мкмоль/л" /></td>
                                <td><MudTextField @bind-Value="AddEditModel.KreatininAfter" Label="мкмоль/л" /></td>
                                <td class="label-td">п/я</td>
                                <td><MudTextField @bind-Value="AddEditModel.Pya" Label="%" /></td>
                            </tr>
                            <tr>
                                <td class="label-td">Na</td>
                                <td><MudTextField @bind-Value="AddEditModel.NaDo" Label="ммоль/л" /></td>
                                <td><MudTextField @bind-Value="AddEditModel.NaAfter" Label="ммоль/л" /></td>
                                <td class="label-td">с/я</td>
                                <td><MudTextField @bind-Value="AddEditModel.Sya" Label="%" /></td>
                            </tr>
                            <tr>
                                <td class="label-td">Ca</td>
                                <td><MudTextField @bind-Value="AddEditModel.CaDo" Label="ммоль/л" /></td>
                                <td><MudTextField @bind-Value="AddEditModel.CaAfter" Label="ммоль/л" /></td>
                                <td class="label-td">M</td>
                                <td><MudTextField @bind-Value="AddEditModel.M" Label="%" /></td>
                            </tr>
                             <tr>
                                <td class="label-td">Фосфор</td>
                                <td colspan="2"><MudTextField @bind-Value="AddEditModel.Fosfor" Label="ммоль/л" /></td>                              
                                <td class="label-td">Л</td>
                                <td><MudTextField @bind-Value="AddEditModel.L" Label="%" /></td>
                            </tr>
                            <tr>
                                <td class="label-td">Fe</td>
                                <td colspan="2"><MudTextField @bind-Value="AddEditModel.Fe" Label="кмоль/л" /></td>                              
                                <td class="label-td">СОЭ</td>
