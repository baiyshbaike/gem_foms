                <MudItem xs="6" md="6">
                    <MudDatePicker Label="Дата выявления ВГС" @bind-Date="date2" DateFormat="dd.MM.yyyy" DisableToolbar="true" />                   
                </MudItem>
                
                <MudItem xs="12" md="12">
                    <table style="width:100%; font-size:13px;">
                        <thead>
                            <tr style="height:5px; font-weight:600; ">
                                <th></th>
                                <th>До/диализа</th>
                                <th>П/диализа</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="label-td">Кол-во сеансов/мес</td>
                                <td><MudTextField @bind-Value="AddEditModel.TotalHD" Label="HD" /></td>
                                <td><MudTextField @bind-Value="AddEditModel.TotalHDF" Label="HDF" /></td>
                                <td class="label-td">Нь</td>
                                <td><MudTextField @bind-Value="AddEditModel.Ng" Label="г/л" /></td>
                            </tr>
                            <tr>
                                <td class="label-td"></td>
                                <td class="label-td">До/диализа</td>
                                <td class="label-td">П/диализа</td>
                                <td class="label-td">Ht</td>
                                <td><MudTextField @bind-Value="AddEditModel.Ht" Label="%" /></td>
                            </tr>
                            <tr>
                                <td class="label-td"></td>
                                <td class="label-td"></td>
                                <td class="label-td"></td>
                                <td class="label-td">Эр-ты</td>
                                <td><MudTextField @bind-Value="AddEditModel.Erty" Label="х10/л" /></td>
                            </tr>
                            <tr>
                                <td class="label-td">Мочевина</td>
                                <td><MudTextField @bind-Value="AddEditModel.MochevinaDo" Label="ммоль/л" /></td>
                                <td><MudTextField @bind-Value="AddEditModel.MochevinaAfter" Label="ммоль/л" /></td>
                                <td class="label-td">Тромб</td>
                                <td><MudTextField @bind-Value="AddEditModel.Tromb" Label="х10/л" /></td>
                            </tr>
                            <tr>
