                                <td><MudTextField @bind-Value="AddEditModel.RazmerFiltra" Label="" /></td>
                            </tr>
                        </tbody>
                        </table>
                </MudItem>
                <MudItem xs="12" md="12">
                    За период у пациента во время проведения сеансов ГД наблюдались осложнения:
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.Gipotenzia" Label="Гипотензия" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.Gipertenzia" Label="Гипертензия" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.Sudorogi" Label="Судороги" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.Shok" Label="Шок" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.GolovnoiBol" Label="Головная боль" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.Toshnota" Label="Тошнота, рвота" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.Lihorodka" Label="Лихородка" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="6" md="6">
                    <MudTextField @bind-Value="AddEditModel.TrombABfist" Label="Тромб. А-В фист" Lines="2" Variant="Variant.Outlined" />
                </MudItem>                
                <MudItem xs="12" md="2">
                </MudItem>
            </MudGrid>
         </MudContainer> 
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</MudForm>
</MudContainer>
        @code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public long MedCardId { get; set; }

    public Epicrisis AddEditModel { get; set; } = new Epicrisis();
    MudForm form;
    DateTime? date = null;
    DateTime? date1 = null;
    DateTime? date2 = null;
    private Patient medCardPatient { get; set; } = new Patient();

    protected override async Task OnInitializedAsync()
    {
        if (MedCardId > 0)
        {
            await LoadPatientAsync();
        }
    }

    private async Task LoadPatientAsync()
    {
        var response = await Http.GetAsync("api/patient/getbymedcard?medcardId=" + MedCardId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }

        var mappedData = await response.ToResult<Patient>();
        medCardPatient = mappedData.Data;
        AddEditModel.PatientId = medCardPatient.Id;
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveAsync()
    {
        AddEditModel.MedCardId = MedCardId;
        AddEditModel.Started = date;
        AddEditModel.DateVgv = date1;
        AddEditModel.DateVgs = date2;

        var response = await _httpClient.PostAsJsonAsync("api/medcard/addepicrisis", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}
