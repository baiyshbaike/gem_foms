                                <td colspan="2"><MudTextField @bind-Value="AddEditModel.Ad" Label="мм рт. ст." /></td>
                                <td class="label-td">Сахар крови</td>
                                <td><MudTextField @bind-Value="AddEditModel.SaharKrovi" Label="мкмоль/л" /></td>
                            </tr>                           
                            <tr>
                                <td class="label-td">Сухой вес</td>
                                <td><MudTextField @bind-Value="AddEditModel.StartWeight" Label="Вес-кг" /></td>
                                <td><MudTextField @bind-Value="AddEditModel.StartHeight" Label="Рост-см" /></td>
                                <td class="label-td">АЛТ</td>
                                <td><MudTextField @bind-Value="AddEditModel.Alt" Label="IU/L" /></td>
                            </tr>
                            <tr>
                                <td class="label-td">RW</td>
                                <td colspan="2"><MudTextField @bind-Value="AddEditModel.Rw" Label="" /></td>
                                <td class="label-td">ACT</td>
                                <td><MudTextField @bind-Value="AddEditModel.Ast" Label="IU/L" /></td>
                            </tr>
                            <tr>
                                <td class="label-td">Группа крови</td>
                                <td colspan="2"><MudTextField @bind-Value="AddEditModel.GruppaKrovi" Label="Rh" /></td>
                                <td class="label-td">АЧТВ</td>
                                <td><MudTextField @bind-Value="AddEditModel.Achtv" Label="IU/L" /></td>
                            </tr>
                            <tr>
