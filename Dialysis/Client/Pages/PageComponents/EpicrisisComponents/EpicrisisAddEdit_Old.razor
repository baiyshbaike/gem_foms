                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Osn" Label="Осн:" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Osl" Label="Осл:" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Sop" Label="Соп:" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                 <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.MedHelpType" Label="Вид мед. помоши:" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Status" Label="Статус на гемоконтакные инфетции:" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6" md="6">
