    @using System.Net.Http.Json
    @inject HttpClient Http

    <MudTable Items="@Elements" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped"  @bind-SelectedItem="selectedItem1">
        <ToolBarContent>
            <AuthorizeView Roles="medcard_add">
                <MudButton
                    Variant="Variant.Filled"
                    StartIcon="@Icons.Material.Filled.MapsHomeWork"
                    Size="Size.Small"
                    Color="Color.Info"
                    @onclick="@(() => AddEditModal(0))">
                    Добавить
                </MudButton>
            </AuthorizeView>
             
            <MudSpacer />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>ФИО</MudTh>
                    <MudTh>ИНН</MudTh>
                    <MudTh>Дата</MudTh>
                    <MudTh></MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Patient.LastName  @context.Patient.FirstName</MudTd>
                    <MudTd>@context.Patient.Inn</MudTd>
                    <MudTd>@context.Epicrisis.Started?.ToString("dd.MM.yyyy")</MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Filled"
                                   @onclick="@(async () => await AddEditModal(context.Epicrisis.Id))"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small" Color="Color.Info">
                            Редактировать
                        </MudButton>
                    </MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Filled"
                                   @onclick="@(async() => await DetailModal(context.Epicrisis.Id))" 
                                   StartIcon="@Icons.Material.Filled.FileOpen"
                                   Size="Size.Small" Color="Color.Info">
                            Подробности
                        </MudButton>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
    </MudTable>


    @code {
        private bool dense = false;
        private bool hover = true;
        private bool striped = true;
        private bool bordered = false;
        private string searchString1 = "";
        private bool tableLoading = false;

        [Parameter]
        public long MedCardId { get; set; }
        private EpicrisisDto selectedItem1 = null;
        private IEnumerable<EpicrisisDto> Elements = new List<EpicrisisDto>();
        private Patient _patient = new Patient();
        protected override async Task OnInitializedAsync()
        {
            if (MedCardId > 0)
            {
                await LoadEpicrisisAsync();
                await LoadPatientAsync();
            }        
        }

        private async Task LoadPatientAsync()
        {
            var response = await Http.GetAsync("api/patient/getbymedcard?medcardId=" + MedCardId);
            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await _authenticationManager.Logout();
                _navigationManager.NavigateTo("/login");
            }

            var mappedData = await response.ToResult<Patient>();
            _patient = mappedData.Data;
        }
        private async Task LoadEpicrisisAsync()
        {
            var response = await Http.GetAsync("api/medcard/getepicrisislist?medcardId=" + MedCardId);
            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await _authenticationManager.Logout();
                _navigationManager.NavigateTo("/login");
            }

            var mappedData = await response.ToResult<List<EpicrisisDto>>();
            Elements = mappedData.Data;
        }

        private async Task AddEditModal(long id = 0)
        {
            var parameters = new DialogParameters();
            if (id != 0)
            {
                var selItem = Elements.FirstOrDefault(t => t.Epicrisis.Id == id)?.Epicrisis;
                parameters.Add("AddEditModel", selItem);
            }
            else
            {
                parameters.Add("AddEditModel", null);
            }
            parameters.Add("id", id);
            parameters.Add("MedCardId", MedCardId);
            parameters.Add("patient",_patient);
            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
            var dialog = _dialogService.Show<Dialysis.Client.Pages.PageComponents.EpicrisisComponents.EpicrisisAddEdit>(id == 0 ? "Добавить " : "Редактировать ", parameters, options);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                await LoadEpicrisisAsync();
            }
        }
        
        private async Task DetailModal(long id = 0)
        {
            var parameters = new DialogParameters();
            if (id != 0)
            {
                var selItem = Elements.Where(t => t.Epicrisis.Id == id).FirstOrDefault();
                parameters.Add("AddEditModel", selItem);
            }
            else
            {
                var newModel = new Epicrisis();
                parameters.Add("AddEditModel", newModel);
            }      
            parameters.Add("EpicrisisId", id);

            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
            var dialog = _dialogService.Show<Dialysis.Client.Pages.PageComponents.EpicrisisComponents.EpicrisisDetail>("Подробности", parameters, options);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                await LoadEpicrisisAsync();
            }
        }


    }
