            </MudItem>

            <MudItem xs="12" md="6">
            </MudItem>
            
                </MudGrid>
  
                </MudContainer>

@code {
    MudForm form;

    [Parameter]
    public long id { get; set; }
    [Parameter]
    public long? mid { get; set; }
    [Parameter]
    public string MCenterName { get; set; }

    private List<BreadcrumbItem> _items = new List<BreadcrumbItem>
    {
        new BreadcrumbItem("Мед. центр и гос. ОЗ", href: "/mcenters")
    };

    private IEnumerable<IndicatorReference> RefList = new List<IndicatorReference>();
    private List<IndicatorRow> RowList = new List<IndicatorRow>();
    public IndicatorPostArgs AddEditModel { get; set; } = new IndicatorPostArgs();

    protected override async Task OnInitializedAsync()
    {
        await LoadRefDataAsync();
        _items.Add(new BreadcrumbItem(MCenterName, href: "/indlist/" + mid + "/" + MCenterName));
        _items.Add(new BreadcrumbItem("Индикаторы", href:null ));
   
    }


    private async Task LoadRefDataAsync()
    {
        var response = await Http.GetAsync("api/status/allindref");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<IndicatorReference>>();
        RefList = mappedData.Data;
        await LoadRowListAsync();
    }

    private async Task LoadRowListAsync()
    {
        var response = await Http.GetAsync("api/medcenter/IndDetail?id="+id);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<IndicatorPostArgs>();
        AddEditModel = mappedData.Data;
        if (AddEditModel != null)
        {
            RowList = AddEditModel.IndicatorRows;
        }
    }

   

}

