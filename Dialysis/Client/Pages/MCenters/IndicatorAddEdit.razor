@page "/indadd/{mid:long}/{MCenterName}"
@using System.Net.Http.Json
@inject HttpClient Http
<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudForm Model="@AddEditModel" @ref="form">
            <MudGrid>
                <MudItem xs="12" md="12">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.MapsHomeWork" Class="mr-3 mb-n1" />
                    Добавить Индикаторы -> @MCenterName
 
                    </MudText>
                </MudItem>
            </MudGrid>

<MudGrid>
    <MudItem xs="4" md="4">
        <br/>
        Индикаторы мониторинга исполнения договора за
    </MudItem>
    <MudItem xs="4" md="4">
        <MudTextField For="@(() => AddEditModel.Title)" @bind-Value="AddEditModel.Title" Label="" />
    </MudItem>
    <MudItem xs="4"md="4"></MudItem>
    <MudItem xs="3" md="3">
        <MudDatePicker Label="Дата от" @bind-Date="dateFrom" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
    </MudItem>
    <MudItem xs="3" md="3">
        <MudDatePicker Label="Дата до" @bind-Date="dateTo" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
    </MudItem>
    <MudItem xs="3" md="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async() => await LoadSessionsAsync())">Обновить</MudButton>
    </MudItem>
    <MudItem xs="3" md="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async() => await Calculate())">Вычислить</MudButton>
    </MudItem>
         <MudItem xs="5" md="5">
                <MudText Typo="Typo.subtitle2" Style="font-weight:500;">Индикатор</MudText>
        </MudItem>
            <MudItem xs="1" md="1">
                План(абс)
            </MudItem>
            <MudItem xs="1" md="1">
               План(%)
            </MudItem>
             <MudItem xs="1" md="1">
                Факт(абс)
            </MudItem>
            <MudItem xs="1" md="1">
               Факт(%)
            </MudItem>
            <MudItem xs="1" md="1">
                Измен.(абс)
            </MudItem>
            <MudItem xs="1" md="1">
                Измен.(%)
            </MudItem>
             <MudItem xs="1" md="1">
                Порог(%)
             </MudItem>
  

            <MudItem xs="5" md="5">
                @item1.title
            </MudItem>
            <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item1.Plan1)" @bind-Value="item1.Plan1" Label="" />
            </MudItem>
            <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item1.Plan2)" @bind-Value="item1.Plan2" Label="" Disabled="true"/>
            </MudItem>
                <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item1.Fact1)" @bind-Value="item1.Fact1" Label="" Disabled="true" />
                </MudItem>
              <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item1.Fact2)" @bind-Value="item1.Fact2" Label="" Disabled="true"/>
                </MudItem>
                <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item1.Change1)" @bind-Value="item1.Change1" Label="" Disabled="true"/>
                </MudItem>
                 <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item1.Change2)" @bind-Value="item1.Change2" Label=""Disabled="true" />
                </MudItem>
                <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item1.Threshold)" @bind-Value="item1.Threshold" Label="" />
                </MudItem>
                <MudItem xs="5" md="5">
                @item2.title
            </MudItem>
            <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item2.Plan1)" @bind-Value="item2.Plan1" Label="" />
            </MudItem>
            <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item2.Plan2)" @bind-Value="item2.Plan2" Label="" Disabled="true"/>
            </MudItem>
                <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item2.Fact1)" @bind-Value="item2.Fact1" Label="" Disabled="true"/>
                </MudItem>
              <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item2.Fact2)" @bind-Value="item2.Fact2" Label="" Disabled="true" />
                </MudItem>
                <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item2.Change1)" @bind-Value="item2.Change1" Label="" Disabled="true"/>
                </MudItem>
                 <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item2.Change2)" @bind-Value="item2.Change2" Label="" Disabled="true"/>
                </MudItem>
                <MudItem xs="1" md="1">
                    <MudTextField For="@(() => item2.Threshold)" @bind-Value="item2.Threshold" Label="" />
                </MudItem>
            <MudItem xs="5" md="5">
                @item3.title
            </MudItem>
            <MudItem xs="1" md="1">
                <MudTextField For="@(() => item3.Plan1)" @bind-Value="item3.Plan1" Label="" />
            </MudItem>
            <MudItem xs="1" md="1">
                <MudTextField For="@(() => item3.Plan2)" @bind-Value="item3.Plan2" Label="" Disabled="true"/>
            </MudItem>
            <MudItem xs="1" md="1">
                <MudTextField For="@(() => item3.Fact1)" @bind-Value="item3.Fact1" Label="" Disabled="true"/>
            </MudItem>
            <MudItem xs="1" md="1">
                <MudTextField For="@(() => item3.Fact2)" @bind-Value="item3.Fact2" Label="" Disabled="true"/>
            </MudItem>
            <MudItem xs="1" md="1">
                <MudTextField For="@(() => item3.Change1)" @bind-Value="item3.Change1" Label="" Disabled="true"/>
            </MudItem>
            <MudItem xs="1" md="1">
                <MudTextField For="@(() => item3.Change2)" @bind-Value="item3.Change2" Label="" Disabled="true"/>
            </MudItem>
            <MudItem xs="1" md="1">
                <MudTextField For="@(() => item3.Threshold)" @bind-Value="item3.Threshold" Label="" />
            </MudItem>
                 
            <MudItem xs="12" md="6">
            </MudItem>
        <MudItem xs="12" md="12">
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Назад</MudButton>
            <MudButton Variant="Variant.Filled" @onclick="@(async() => await SaveAsync())" Color="Color.Success">Сохранить</MudButton>
            </MudItem>
</MudGrid>
    </MudForm>
        </MudContainer>

 @code {
    MudForm form;

    [Parameter]
    public long? mid { get; set; }
    [Parameter]
    public string MCenterName { get; set; }
    private DateTime? dateFrom = DateTime.Today.AddMonths(-1);
    private DateTime? dateTo = DateTime.Today;
    private IEnumerable<IndicatorReference> RefList = new List<IndicatorReference>();
    private List<IndicatorRow> RowList = new List<IndicatorRow>();
    private IndicatorRow item1 = new IndicatorRow();
    private IndicatorRow item2 = new IndicatorRow();
    private IndicatorRow item3 = new IndicatorRow();
    public IndicatorPostArgs AddEditModel { get; set; } = new IndicatorPostArgs();
    private IndicatorInfoDto Elements = new IndicatorInfoDto();
    public EpicrisisRepDto items = new();
    protected override async Task OnInitializedAsync()
    {
        
        item1.title = "Количество пациентов всего";
        item2.title = "Количество пациентов, получаюших программный гемодиализ не менее 3 раз в календарную неделю";
        item3.title = "Количество пациентов с показателем диализа sp Kt/v > 1.4 или eKtv > 1.2";
        await LoadSessionsAsync();
    }


    private async Task LoadSessionsAsync()
    {

        string dFrom = "";
        string dTo = "";
        dFrom = dateFrom?.ToString("yyyyMMdd");
        dTo = dateTo?.ToString("yyyyMMdd");
        string searchParams = "&fromDate=" + dFrom + "&toDate=" + dTo;
        var response1 = await Http.GetAsync("api/medcard/getpatientinfo?medCenterId=" + mid + "" + searchParams);
        if (response1.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData1 = await response1.ToResult<IndicatorInfoDto>();
        Elements = mappedData1.Data;
        item1.Plan1 = 0;
        item2.Plan1 = 0;
        item3.Plan1 = 0;
        item1.Threshold = 0;
        item2.Threshold = 0;
        item3.Threshold = 0;
        item1.Plan2 = 100;
        item2.Plan2 = 100;
        item3.Plan2 = 100;
        item1.Fact1 =Convert.ToDouble(Elements.Patients.Count());
        item2.Fact1 = Convert.ToDouble(Elements.PatientsOfWeek.Count());
        item3.Fact1 = 0;
        /*var response2 = await Http.GetAsync("api/medcard/epicrisisrep" + searchParams);
        if (response2.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData2 = await response2.ToResult<EpicrisisRepDto>();
        items = mappedData2.Data;
        item2.Fact1 = Convert.ToDouble(items.sp13);*/
    }
    private async Task Calculate()
    {
        item1.Change1 = item1.Plan1 - item1.Fact1;
        item2.Change1 = item2.Plan1 - item2.Fact1;
        item3.Change1 = item3.Plan1 - item3.Fact1;
        item1.Fact2 = (item1.Fact1*100)/item1.Plan1;
        item2.Fact2 = (item2.Fact1*100)/item2.Plan1;
        item3.Fact2 = (item3.Fact1*100)/item3.Plan1;
        item1.Change2 = item1.Plan2 - item1.Fact2;
        item2.Change2 = item2.Plan2 - item2.Fact2;
        item3.Change2 = item3.Plan2 - item3.Fact2;
    }

    private async Task LoadRowListAsync()
    {
        if (RefList != null)
        {
            foreach(var item in RefList){
                var newRow =new IndicatorRow{
                    ReferenceId = item.Id
                };
                RowList.Add(newRow);
            }
        }
    }

    public void Cancel()
    {
        _navigationManager.NavigateTo("/indlist/" + mid + "/" + MCenterName);
    }
    
    private async Task SaveAsync()
    {
        AddEditModel.startIndicator = dateFrom;
        AddEditModel.endIndicator = dateTo;
        AddEditModel.MedCenterId=(long)mid;
        AddEditModel.IndicatorRows.Add(item1);       
        AddEditModel.IndicatorRows.Add(item2);       
        AddEditModel.IndicatorRows.Add(item3);       
        
        var response = await _httpClient.PostAsJsonAsync("api/medcenter/addindicator", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            _navigationManager.NavigateTo("/indlist/" + mid+"/"+ MCenterName);
        }
    }

}

