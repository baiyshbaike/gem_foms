@page "/employeesList"
@page "/employeesList/{Mid:long?}"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "admin, employees")]
<MudContainer MaxWidth="MaxWidth.Large">
    <MudGrid>
        <MudItem xs="12" md="12">
            <MudButton Variant="Variant.Filled" @onclick="@(()=> AddEditModal(0))" StartIcon="@Icons.Material.Filled.MapsHomeWork" Size="Size.Small" Color="Color.Info">Добавить сотрудник</MudButton>
        </MudItem>
        <MudItem xs="12" md="12">
            &nbsp;
        </MudItem>
    </MudGrid>
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudSelect T="long" Label="Мед. центр" @bind-Value="@searchModel.MedCenterId" AnchorOrigin="Origin.BottomCenter" Disabled="@IsOnlyCenter">
                    @{
                        if (!IsOnlyCenter)
                        {
                            <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                        }
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDataAsync" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Поиск</MudButton>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>

    @if (showTable)
    {
        <MudTable Items="@Elements" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" Filter="new Func<MedCenterEmployee,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Сотрудники</MudText>
                &nbsp;&nbsp;
                <MudSpacer />
                <MudTextField @bind-Value="searchString1" Immediate="true" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Фамилия</MudTh>
                <MudTh>Имя</MudTh>
                <MudTh>Отчество</MudTh>
                <MudTh>Должность</MudTh>
                <MudTh>Телефон</MudTh>
                <MudTh>Дата создания</MudTh>
                <MudTh>&nbsp;</MudTh>
                <MudTh>&nbsp;</MudTh>
                <MudTh>&nbsp;</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.FirstName</MudTd>
                <MudTd>@context.LastName</MudTd>
                <MudTd>@context.MiddleName</MudTd>
                <MudTd>@context.JobTitle</MudTd>
                <MudTd>@context.PhoneNumber</MudTd>
                <MudTd>@context.CreatedOn?.ToString("dd.MM.yyyy")</MudTd>
                <MudTd>
                    @if (!string.IsNullOrEmpty(context.UpFile1))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Download" 
                                    Size="Size.Small"
                                    Color="Color.Primary"
                                    OnClick="@(() => DownloadFile(context.UpFile1))" />
                    }
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Удалить" @onclick="@(async() => await DeleteModel(context.Id))" Size="Size.Small" Color="Color.Error"></MudIconButton>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Редактировать" @onclick="@(async() => await AddEditModal(context.Id))" Size="Size.Small" Color="Color.Warning"></MudIconButton>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    }

</MudContainer>

@code {
    [Parameter]
    public long? Mid { get; set; }
    public SearchtDto searchModel = new SearchtDto();
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();
    private IEnumerable<MedCenterEmployee> Elements = new List<MedCenterEmployee>();
    private MedCenterEmployee selectedItem1 = null;
    private bool IsOnlyCenter = true;
    private string searchString1 = "";
    private bool showTable = false;
    private bool tableLoading = false;
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    protected override async Task OnInitializedAsync()
    {
        await LoadUserCentersAsync();
        if (Mid != null)
        {
            searchModel.MedCenterId = (long)Mid;
            await LoadDataAsync();
        }
        else
        {
            await LoadDataAsync();
        }
        StateHasChanged();
    }
    private async Task DownloadFile(string fileName)
    {
        try
        {
            var response = await Http.GetAsync($"api/medcenter/downloadfile/{fileName}");
            var fileBytes = await response.Content.ReadAsByteArrayAsync();
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, Convert.ToBase64String(fileBytes));
        }
        catch (Exception ex)
        {
            _snackBar.Add("Ошибка при скачивании файла", Severity.Error);
        }
    }
    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                IsOnlyCenter = false;
                searchModel.MedCenterId = 0;
            }
            else if (UserCenters.Count() == 1)
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = UserCenters.First().Id;
            }
            else
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = 0;
            }
        }
    }
    private async Task LoadDataAsync()
    {
        tableLoading = true;
        showTable = true;
        var response = await Http.GetAsync("api/medcenter/allempoyees?Id=" + searchModel.MedCenterId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<MedCenterEmployee>>();
        Elements = mappedData.Data;
        tableLoading = false;
    }
    private async Task AddEditModal(long id = 0)
    {
        var parameters = new DialogParameters();
        if (id != 0)
        {
            var userSel = Elements.Where(u => u.Id == id).FirstOrDefault();
            parameters.Add("AddEditModel", userSel);
        }
        else
        {
            var userSel = new MedCenterEmployee();
            parameters.Add("AddEditModel", userSel);
        }

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<EmployeeAddEdit>(id == 0 ? "Добавить сотрудник" : "Редактировать сотрудник", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync();
        }
    }
    private bool FilterFunc1(MedCenterEmployee element) => FilterFunc(element, searchString1);

    private bool FilterFunc(MedCenterEmployee element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (!string.IsNullOrWhiteSpace(element.FirstName))
        {
            if (element.FirstName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrWhiteSpace(element.LastName))
        {
            if (element.LastName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrWhiteSpace(element.MiddleName))
        {
            if (element.MiddleName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        return false;
    }
    private async Task DeleteModel(long id = 0)
    {
        var selItem = Elements.Where(t => t.Id == id).FirstOrDefault();
        var response = await _httpClient.PostAsJsonAsync("api/medcenter/deleteemployee", selItem);
        var result = await response.ToResult();
        await LoadDataAsync();
    }
}