@using System.IO

<EditForm Model="@AddEditModel" OnValidSubmit="SaveAsync">
    <MudDialog>
        <TitleContent>
            @{
                if (AddEditModel?.Id == 0)
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                        Добавить
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                        Редактировать
                    </MudText>
                }
            }            
        </TitleContent>
        <DialogContent>
            <MudGrid>
                @if (canEdit == false)
                {
                    <MudSelect T="long?" Label="Статус" @bind-Value="@AddEditModel.Status" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="long?" Value="1">Новый</MudSelectItem>
                        <MudSelectItem T="long?" Value="2">Замена</MudSelectItem>
                    </MudSelect>
                }
                <MudItem xs="6" md="2">
                    <MudTextField For="@(() => AddEditModel.Number)" @bind-Value="AddEditModel.Number" Label="Номер в Мед. центр" />
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudTextField For="@(() => AddEditModel.Manufacturer)" @bind-Value="AddEditModel.Manufacturer" Label="Производитель" />
                </MudItem>
                <MudItem xs="6" md="4">
                    <MudTextField For="@(() => AddEditModel.Model)" @bind-Value="AddEditModel.Model" Label="Модель" />
                </MudItem>
                 <MudItem xs="6" md="4">
                    <MudTextField For="@(() => AddEditModel.Name)" @bind-Value="AddEditModel.Name" Label="Название" />
                </MudItem>
                <MudItem xs="6" md="4">
                    <MudDatePicker Label="Год выпуска" @bind-Date="dateMan" DateFormat="dd.MM.yyyy" />
                </MudItem>
                <MudItem xs="6" md="4">
                    <MudTextField For="@(() => AddEditModel.ManCountry)" @bind-Value="AddEditModel.ManCountry" Label="Страна производства" />
                </MudItem>     
                
                <MudItem xs="6" md="3">
                    <MudTextField For="@(() => AddEditModel.CertificateHolder)" @bind-Value="AddEditModel.CertificateHolder" Label="Держатель свидетельства" />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudTextField For="@(() => AddEditModel.CertificateHolderCountry)" @bind-Value="AddEditModel.CertificateHolderCountry" Label="Страна держателя свидетельства" />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudTextField For="@(() => AddEditModel.CertificateNumber)" @bind-Value="AddEditModel.CertificateNumber" Label="Номер свидетельства" />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudDatePicker Label="Дата выдачи свидетельства" @bind-Date="dateCert" DateFormat="dd.MM.yyyy" />
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudTextField For="@(() => AddEditModel.PermitName)" @bind-Value="AddEditModel.PermitName" Label="Наименование(Разр. док)" />
                </MudItem>
                <MudItem xs="6" md="4">
                    <MudTextField For="@(() => AddEditModel.PermitNumber)" @bind-Value="AddEditModel.PermitNumber" Label="Номер(Разр. док)" />
                </MudItem>
                <MudItem xs="6" md="4">
                    <MudTextField For="@(() => AddEditModel.PermitSeria)" @bind-Value="AddEditModel.PermitSeria" Label="Серия(Разр. док)" />
                </MudItem>
                <MudItem xs="6" md="4">
                    <MudDatePicker Label="Срок действия(Разр. док)" @bind-Date="datePermit" DateFormat="dd.MM.yyyy" />
                </MudItem>              
               
                <MudItem xs="6" md="4">
                    <MudTextField For="@(() => AddEditModel.TotalSessions)" @bind-Value="AddEditModel.TotalSessions" Label="Нагрузка на один аппарат (сеансов в сутки)" />
                </MudItem>
                <MudItem xs="6" md="4">
                    <MudSelect T="bool" Label="Назн." @bind-Value="@AddEditModel.IsActive" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="bool" Value="true">Актив</MudSelectItem>
                        <MudSelectItem T="bool" Value="false">Архив</MudSelectItem>                       
                    </MudSelect>
                </MudItem>
                @if (canEdit == true && AddEditModel !=null)
                {
                    <MudSelect T="bool" Label="Подтверждение" @bind-Value="@AddEditModel.IsApproved" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="bool" Value="true">Да</MudSelectItem>
                        <MudSelectItem T="bool" Value="false">Нет</MudSelectItem>
                    </MudSelect>
                }
                
                 <MudItem xs="12" md="12">
                    <InputFile OnChange="OnInputFileChange" multiple/>
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</EditForm>

 @code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public MedCenterMachine AddEditModel { get; set; }
    [Parameter] public long mcenterid { get; set; }
    [Parameter] public long id { get; set; }
    [Parameter] public bool canEdit { get; set; }

    DateTime? dateMan = DateTime.Today;
    DateTime? dateCert = DateTime.Today;
    DateTime? datePermit = DateTime.Today;
    public  bool IsNew = false;

    IList<IBrowserFile> upFiles = new List<IBrowserFile>();
    IReadOnlyList<IBrowserFile> selectedFiles;

    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles();
    }

    protected override async Task OnInitializedAsync()
    {
        if (AddEditModel == null)
        {
            IsNew = true;
            AddEditModel = new MedCenterMachine();
            AddEditModel.MedCenterId = Convert.ToInt64(mcenterid);
        }
        else
        {
            dateMan = AddEditModel.ManDate!;
            dateCert = AddEditModel.CertificateDate!;
            datePermit = AddEditModel.PermitDate!;
        }
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveAsync()
    {
        //AddEditModel.MedCenterId = mcenterid;
        AddEditModel.ManDate = dateMan;
        AddEditModel.CertificateDate = dateCert;
        AddEditModel.PermitDate = datePermit;

        MachineAddParams sendModel = new MachineAddParams();
        if (selectedFiles != null)
        {
            if (selectedFiles.Count() > 0 )
            {
                foreach (var file in selectedFiles)
                {
                    if (file != null)
                    {
                        Stream stream = file.OpenReadStream();
                        MemoryStream ms = new MemoryStream();
                        await stream.CopyToAsync(ms);
                        stream.Close();
                        sendModel.FileName = file.Name;
                        sendModel.FileContent = ms.ToArray();
                        ms.Close();
                    }
                }
            }
        }

        /*if(canEdit==true && IsNew == true)
        {
            AddEditModel.IsApproved = true;
        }*/

        sendModel.MedCenterMachine = AddEditModel;

        var response = await _httpClient.PostAsJsonAsync("api/medcenter/addmachine", sendModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}