@page "/allmachines"
@using System.Net.Http.Json
@inject HttpClient Http
@attribute [Authorize]

<AuthorizeView Roles="medcenter">
@{
        canEdit = true;
    }
</AuthorizeView>
<AuthorizeView Roles="admin">
    @{
        isAdmin = true;
    }
</AuthorizeView>

<MudContainer MaxWidth="MaxWidth.Large">
      <EditForm Model="@searchModel">
        <MudGrid>   
            
            <MudItem xs="6" md="8">
                <MudSelect T="long" Label="Мед. центр" @bind-Value="@searchModel.MedCenterId" AnchorOrigin="Origin.BottomCenter" Disabled="@IsOnlyCenter">
                    @{
                        if (!IsOnlyCenter)
                        {
                            <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                        }
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="4">
                <br />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDataAsync" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Фильтр</MudButton>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>

<MudTable Items="@Elements" RowsPerPage=100 Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" Filter="new Func<MedCenterMachine,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>

        <MudText Typo="Typo.h6">Гемодиализные аппараты</MudText>
        &nbsp;&nbsp;
        <AuthorizeView Roles="admin">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Hotel" Size="Size.Small" Color="Color.Info" @onclick="@(() => AddEditModal(0))">Добавить</MudButton>
        </AuthorizeView>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Immediate="true" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>Подтвержденный</MudTh>
        <MudTh>Статус Назн.</MudTh>
        <MudTh>Номер в Мед. центр</MudTh>
        <MudTh>Производитель</MudTh>
        <MudTh>Модель</MudTh>
        <MudTh>Название</MudTh>
        <MudTh>Год выпуска</MudTh>
        <MudTh>Страна производства</MudTh>
        <MudTh>Держатель свидетельства</MudTh>
        <MudTh>Страна держателя свидетельства</MudTh>
        <MudTh>Номер свидетельства</MudTh>
        <MudTh>Дата выдачи свидетельства</MudTh>
        <MudTh>Наименование(Разр. док)</MudTh>
        <MudTh>Номер(Разр. док)</MudTh>
        <MudTh>Серия(Разр. док)</MudTh>
        <MudTh>Срок действия(Разр. док)</MudTh>
        <MudTh>Нагрузка на один аппарат (сеансов в сутки)</MudTh>
        <MudTh>Дата</MudTh>



    </HeaderContent>
    <RowTemplate>
        <MudTd>
            @if (isAdmin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Редактировать"
                               @onclick="@(async() => await AddEditModal(context.Id))"
                               Size="Size.Small"
                               Color="Color.Warning">
                </MudIconButton>
            }
               
        </MudTd>
        <MudTd>
            @if (isAdmin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Удалить"
                               @onclick="@(async () => await DeleteModal(context.Id))"
                               Size="Size.Small"
                               Color="Color.Error">

                </MudIconButton>
            }
        </MudTd>
        @* <MudTh> *@
        @*     @if (context.Status == 1) *@
        @*     { *@
        @*         <MudText>Новый</MudText> *@
        @*     } *@
        @*     else if (context.Status == 2) *@
        @*     { *@
        @*         <MudText>Замена</MudText> *@
        @*     }else *@
        @*     { *@
        @*         <MudText>Актив</MudText> *@
        @*     } *@
        @* </MudTh> *@
        <MudTh>
            @if (context.IsApproved == true)
            {
                <MudText>Да</MudText>
            }               
            else
            {
                <MudText>Нет</MudText>
            }
        </MudTh>
        <MudTh>
            @if (context.IsActive == true)
            {
                <MudText>Актив</MudText>
            }
            else
            {
                <MudText>Резерв</MudText>
            }
            </MudTh>
        <MudTd>@context.Number</MudTd>
        <MudTd>@context.Manufacturer</MudTd>
        <MudTd>@context.Model</MudTd>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.ManDate?.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>@context.ManCountry</MudTd>
        <MudTd>@context.CertificateHolder</MudTd>
        <MudTd>@context.CertificateHolderCountry</MudTd>
        <MudTd>@context.CertificateNumber</MudTd>
        <MudTd>@context.CertificateDate?.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>@context.PermitName</MudTd>
        <MudTd>@context.PermitNumber</MudTd>
        <MudTd>@context.PermitSeria</MudTd>
        <MudTd>@context.PermitDate?.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>@context.TotalSessions</MudTd>
        <MudTd>@context.CreatedOn?.ToString("dd.MM.yyyy")</MudTd>



    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>


    </MudContainer>
    @code {
    public SearchtDto searchModel = new SearchtDto();
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private bool tableLoading = false;
    private MedCenterMachine selectedItem1 = null;
    private HashSet<MedCenterMachine> selectedItems = new HashSet<MedCenterMachine>();

    private bool canEdit = false;
    private bool isAdmin = false;

    private IEnumerable<MedCenterMachine> Elements = new List<MedCenterMachine>();
    private IEnumerable<MedCenterMachine> Elements2 = new List<MedCenterMachine>();

   
        private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();
        private bool IsOnlyCenter = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserCentersAsync();
        tableLoading = true;
        await LoadDataAsync();
    }

public async Task LoadUserCentersAsync()
 {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                IsOnlyCenter = false;
                searchModel.MedCenterId = 0;
            }
            else if (UserCenters.Count() == 1)
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = UserCenters.First().Id;
            }
            else
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = 0;
            }
        }
  }

       

    private async Task LoadDataAsync()
    {
        if (IsOnlyCenter && searchModel.MedCenterId == 0 && UserCenters.Count() == 1)
        {
            searchModel.MedCenterId = UserCenters.First().Id;
        }
        var response = await Http.GetAsync("api/medcenter/allmachines?Id=" + searchModel.MedCenterId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<MedCenterMachine>>();
        Elements = mappedData.Data;

        if (Elements != null)
        {
            Elements2 = Elements.GroupBy(p => new { p.Model, p.Manufacturer, p.Name }).Select(group => new MedCenterMachine()
                {
                    Manufacturer = group.First().Manufacturer,
                    Model = group.First().Model,
                    Name = group.First().Name,
                    ManCountry = group.First().ManCountry,
                    CertificateHolder = group.First().CertificateHolder,
                    CertificateHolderCountry = group.First().CertificateHolderCountry,
                    CertificateNumber = group.First().CertificateNumber,
                    CertificateDate = group.First().CertificateDate,
                    PermitName = group.First().PermitName,
                    PermitNumber = group.First().PermitNumber,
                    PermitSeria = group.First().PermitSeria,
                    PermitDate = group.First().PermitDate,
                    TotalSessions = group.First().TotalSessions,
                    Id = group.Where(p => p.IsActive.Equals(true)).Count(),
                    Number = group.Where(p => p.IsActive.Equals(false)).Count().ToString(),

            }).ToList();
        }

        tableLoading = false;
    }

    private bool FilterFunc1(MedCenterMachine element) => FilterFunc(element, searchString1);

    private bool FilterFunc(MedCenterMachine element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (!string.IsNullOrWhiteSpace(element.Model))
        {
            if (element.Model.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrWhiteSpace(element.CertificateNumber))
        {
            if (element.CertificateNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrWhiteSpace(element.Name))
        {
            if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        
        return false;
    }
    private async Task DeleteModal(long id = 0)
    {
        var options = new DialogOptions{};
        var dialog = _dialogService.Show<ConfirmModal>("Вы действительно хотите его удалить?", options);
        var result = await dialog.Result;
        if (result.Data is bool b && b)
        {
            var response = await _httpClient.PostAsJsonAsync("api/medcenter/deletemashinebyid", id);
            var apiResult = await response.ToResult();
            if (!apiResult.Succeeded)
            {
                _snackBar.Add(apiResult.Messages[0], Severity.Error);
            }
            else
            {
                _snackBar.Add("Успешно", Severity.Success);
            }
            await LoadDataAsync();
        }
    }
    private async Task AddEditModal(long id = 0)
    {
        var parameters = new DialogParameters();
        if (id != 0)
        {
            var selItem = Elements.Where(t => t.Id == id).FirstOrDefault();
            parameters.Add("AddEditModel", selItem);
        }
        parameters.Add("mcenterid", searchModel.MedCenterId);
        parameters.Add("id", id);
        parameters.Add("canEdit", canEdit);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<MachineAddEdit>(id == 0 ? "Добавить" : "Редактировать", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync();
        }
    }


}

