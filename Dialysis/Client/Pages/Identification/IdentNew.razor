    protected override async Task OnInitializedAsync()
    {
        await LoadUserCentersAsync();
        await LoadStatusTunduk();
        await JSRuntime.InvokeVoidAsync("startVideo", "videoFeed");
        // SignalR bağlantısını kur
        hubConnection = new HubConnectionBuilder()
            .WithUrl(_navigationManager.ToAbsoluteUri("/verificationHub")) // HATASI: NavigationManager enjekte edildi.
            .Build();

        // Sunucudan "VerificationCompleted" mesajı gelince bu metot çalışacak
        hubConnection.On<bool>("VerificationCompleted", (isVerified) =>
        {
            InvokeAsync(() =>
            {
                if (isVerified)
                {
                    _snackBar.Add("Верификация прошла успешно!", Severity.Success);
                    IsQr = false; // Disable the QR button
                }
                else
                {
                    _snackBar.Add("Верификация не пройдена. Пожалуйста, создайте новый QR-код.", Severity.Error);
                    IsQr = true; // Keep the QR button enabled
                }
                IsShowTime = false; // Hide the timer
                StateHasChanged(); // Update the UI
            });
        });

        await hubConnection.StartAsync();

    }
    private async Task LoadStatusTunduk()
    {
        var response = await _httpClient.GetAsync("api/verify/tunduk_status");
        var mappedData = await response.ToResult<bool>();
        if (mappedData != null && mappedData.Succeeded)
        {
            TundukStatus = mappedData.Data;
        }
        else
        {
            TundukStatus = false; // Varsayılan değer
        }
    }
    private async Task GenerateQrCode()
    {
        if (countdownTimer != null)
        {
            countdownTimer.Stop();
            countdownTimer.Dispose();
            countdownTimer = null;
        }

        try
        {
            // 2. Sunucudan yeni bir doğrulama oturumu iste
            var response = await _httpClient.PostAsJsonAsync("api/verify/request", new RequestVerificationDto());
            var verificationData = await response.Content.ReadFromJsonAsync<RequestVerificationResponseDto>();

            if (verificationData == null)
            {
                _snackBar.Add("Запрос на проверку не удался.", Severity.Error);
                return;
            }

            // 3. Gelen verilerle QR kodunu oluştur
            QrSessionId = verificationData.SessionId;
            expiryTime = verificationData.Expires;

            var qrPayload = new
            {
                sessionId = QrSessionId,
                patientInn = patientModel.Inn,
                patientFullName = $"{patientModel.FirstName} {patientModel.LastName}",
                expires = expiryTime.ToString("o"),
            };
            
            // Kiril alfabesi (Rusça/Kırgızca) karakterleri için encoder ayarı
            var jsonOptions = new JsonSerializerOptions
            {
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false,
                DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.Never,
                Encoder = JavaScriptEncoder.Create(
                    UnicodeRanges.BasicLatin,
                    UnicodeRanges.Cyrillic,
                    UnicodeRanges.CyrillicSupplement
                )
            };
            var jsonString = JsonSerializer.Serialize(qrPayload, jsonOptions);
            
            // Debug için JSON içeriğini konsola yazdır
            Console.WriteLine($"QR Payload: {jsonString}");
            using var qrGenerator = new QRCodeGenerator();
            var qrCodeData = qrGenerator.CreateQrCode(jsonString, QRCodeGenerator.ECCLevel.Q);
            var qrCode = new PngByteQRCode(qrCodeData);
            var qrBytes = qrCode.GetGraphic(20);
            QrImageData = "data:image/png;base64," + Convert.ToBase64String(qrBytes);

            IsQr = true;
            IsVerification = false;
            IsShowTime = true;

            countdownTimer = new System.Timers.Timer(1000); // Her saniye güncelle
            countdownTimer.Elapsed += UpdateTimer;
            countdownTimer.AutoReset = true;
            countdownTimer.Start();

            if (hubConnection != null && !string.IsNullOrEmpty(QrSessionId))
            {
                await hubConnection.SendAsync("JoinVerificationGroup", QrSessionId);
            }
        }
        catch (Exception ex)
        {
            _snackBar.Add($"Не удалось сгенерировать QR-код: {ex.Message}", Severity.Error);
        }
        
        StateHasChanged();
    }
    private void UpdateTimer(object? sender, System.Timers.ElapsedEventArgs e)
    {
        if (countdownTimer == null)
            return;
        
        var timeLeft = expiryTime - DateTime.Now;

        if (timeLeft <= TimeSpan.Zero)
        {
            // Останавливаем и освобождаем ресурсы таймера
            countdownTimer.Stop();
            countdownTimer.Dispose();
            countdownTimer = null;
    
            // Обновляем UI через InvokeAsync
            InvokeAsync(() =>
            {
                // Показываем уведомление
                _snackBar.Add("Время действия QR-кода истекло. Пожалуйста, создайте новый.", Severity.Warning);

                timeRemaining = "Время вышло!";
                IsQr = true; // Разрешаем создание нового QR-кода
                IsShowTime = false; // Скрываем таймер
        
                StateHasChanged(); // Обновляем UI
            });
            return;
        }

        timeRemaining = $"{timeLeft.Minutes:D2}:{timeLeft.Seconds:D2}";
        InvokeAsync(StateHasChanged);
    }
    public async ValueTask DisposeAsync()
    {
        if (countdownTimer != null)
        {
            countdownTimer.Stop();
            countdownTimer.Dispose();
            countdownTimer = null;
        }
    
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
