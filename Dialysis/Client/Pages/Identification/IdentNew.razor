<MudContainer MaxWidth="MaxWidth.Large">
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="6" md="4">
                <MudTextField For="@(() => searchModel.Inn)" @bind-Value="searchModel.Inn" Label="ИНН" />
            </MudItem>
            <MudItem xs="6" md="4">
                @if (!string.IsNullOrEmpty(frameUri))
                {
                    <img src="@frameUri" />
                }
                <br />
                <MudText></MudText>
            </MudItem>
            <MudItem xs="12" md="1">
                &nbsp;
            </MudItem>
            <MudItem xs="6" md="3">
                <video id="videoFeed" width="240" height="180" />
                <canvas class="d-none" id="currentFrame" width="320" height="240" />
                <br />
                <MudFab Color="Color.Tertiary" @onclick="CaptureFrame" StartIcon="@Icons.Material.Filled.CameraAlt" DisableElevation="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchAsync" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Поиск пациент</MudButton>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudForm @ref="sendForm" Model="@sendModel" @bind-IsValid="@IsValid">
        <MudGrid>            
            <MudItem xs="12" md="4">
                <MudTextField Disabled="true" @bind-Value="sendModel.Inn" Required="true" Label="ИНН" />
            </MudItem>            
            <MudItem xs="12" md="4" Label="ФИО">
                <MudText> @patientModel?.LastName @patientModel?.FirstName</MudText>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText>@patientModel?.GroupText</MudText>
            </MudItem>
            <MudItem xs="12" md="12">
            @if (isLoadedCenter == true)
                {
                    <MudSelect T="MedCenter" Required="true" Label="Мед. центр" @bind-Value="@SelMedCenter" AnchorOrigin="Origin.BottomCenter">
                        @{
                            @foreach (var medItem in UserCenters)
                            {
                                <MudSelectItem T="MedCenter" Value="@medItem">@medItem.Title</MudSelectItem>
                            }
                        }
                    </MudSelect>
                }
            </MudItem>
            <MudItem xs="12" md="12">
                <MudButton 
                    StartIcon="@Icons.Material.Filled.QrCode"
                    Variant="Variant.Filled"
                    Color="Color.Success"
                    OnClick="GenerateQrCode">Верификация через Тундук (QR)</MudButton>
                @if (!string.IsNullOrEmpty(QrImageData))
                {
                    <img src="@QrImageData" width="350" />
                }
                @if (IsVerification)
                {
                    <p>
                        <MudText  Typo="Typo.h6" Style="color:red;">Пожалуйста просто нажми кнопку!</MudText>
                    </p>
                }
                @if (IsShowTime)
                {
                    <p>
                        <MudText Typo="Typo.body1">Оставшееся время: @timeRemaining</MudText>
                    </p>
                }
            </MudItem>
            <MudCardActions>
                <MudButton 
                    Disabled="IsButtonDisabled"
                    Variant="Variant.Filled"
                           OnClick="@(async () => await SaveAsync())"
                            Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send" Class="ml-auto">Сохранить</MudButton>
            </MudCardActions>
          
        </MudGrid>
    </MudForm>
</MudContainer>

