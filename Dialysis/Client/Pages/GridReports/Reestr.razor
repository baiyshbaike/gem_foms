@page "/reestr"

@using DevExpress.Blazor
@using DevExpress.Data.Filtering
@using DevExpress.Export
@using System.Net.Http.Json
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Large">
    <MudGrid>        
        <MudItem xs="12" md="12">
            <MudText Typo="Typo.h6">Изменение льготного реестра</MudText>
        </MudItem>
    </MudGrid>
   
</MudContainer>

&nbsp;&nbsp;&nbsp;&nbsp;
<DxButton Text="Выберите столбцы"
          RenderStyle="ButtonRenderStyle.Primary"
          CssClass="column-chooser-button"
          Click="OnClickColumns" />
&nbsp;&nbsp;
<DxButton Text="Скачать"
          RenderStyle="ButtonRenderStyle.Primary"
          CssClass="column-chooser-button"
          Click="@(async() => await ExportXlsx_Click())" />

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge">
    <DxGrid @ref="Grid"
            Data="@Data"
            ShowGroupPanel="false"
            ShowFilterRow="false"
            PageSizeSelectorVisible="true"
            PageSizeSelectorAllRowsItemVisible="true"
            PageSize=50
            PageSizeSelectorItems="@(new int[] { 50,100,500 })"
            CustomizeCellDisplayText="Grid_CustomizeCellDisplayText">
        <Columns>
            <DxGridDataColumn FieldName="Id" Caption="Код" Width="120px" />

            <DxGridDataColumn FieldName="CreatedOn" Caption="Дата" Width="180px" AllowGroup="false" TextAlignment="GridTextAlignment.Left">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="Before" Caption="Было" Width="100px" AllowGroup="false" TextAlignment="GridTextAlignment.Left">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="Come" Caption="Прибыло" Width="100px" MinWidth="50" TextAlignment="GridTextAlignment.Left" AllowGroup="false" AllowSort="true">                
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="Gone" Caption="Выбыло" Width="100px" MinWidth="50" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="After" Caption="Стало" Width="100px" MinWidth="50" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="Id" Caption=" " MinWidth="250" AllowGroup="false">
                <CellDisplayTemplate>
                    <MudButton Variant="Variant.Filled"
                               @onclick="@(async() => await DetailPage((long)context.Value))"
                               StartIcon="@Icons.Material.Filled.FileOpen"
                               Size="Size.Small" Color="Color.Info">
                        Подробности
                    </MudButton>                   
                </CellDisplayTemplate>   
            </DxGridDataColumn>
        </Columns>
        <TotalSummary>
            <DxGridSummaryItem FieldName="Id" SummaryType="GridSummaryItemType.Count" />
        </TotalSummary>
        <GroupSummary>
            <DxGridSummaryItem FieldName="Id" SummaryType="GridSummaryItemType.Count" />
        </GroupSummary>
    </DxGrid>

</MudContainer>

@code {
    IGrid Grid;
    private List<PatientChangesDto> Data { get; set; }

    private SearchtDto searchModel = new SearchtDto();

    private DateTime? dateFrom = DateTime.Today.AddDays(-30);
    private DateTime? dateTo = DateTime.Today;
    private DateTime dateToLocal = DateTime.Today.AddDays(1);
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();

    

    DataGridFilterMode _filterMode = DataGridFilterMode.Simple;
    DataGridFilterCaseSensitivity _caseSensitivity = DataGridFilterCaseSensitivity.Default;

    void Grid_CustomizeCellDisplayText(GridCustomizeCellDisplayTextEventArgs e)
    {
        if (e.FieldName == "CreatedOn")
        {
            e.DisplayText = (e.Value != null ? ((DateTime)e.Value).ToString("dd.MM.yyyy") : "");
        }
    }

    private async Task DetailPage(long id)
    {
        _navigationManager.NavigateTo("/reestrdetail/" + id);
    }

    void OnClickColumns()
    {
        Grid.ShowColumnChooser(".column-chooser-button");
    }


    async Task ExportXlsx_Click()
    {
        await Grid.ExportToXlsxAsync("Изменение_льготного_реестра", new GridXlExportOptions()
            {
                ExportSelectedRowsOnly = false
            });
    }


    protected override async Task OnInitializedAsync()
    {
        //await LoadUserCentersAsync();      
        await LoadDataAsync();
    }


    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                searchModel.MedCenterId = 0;
            }
            else
            {
                searchModel.MedCenterId = UserCenters.Select(t => t.Id).FirstOrDefault();
            }
        }
    }

    private async Task LoadDataAsync()
    {
        /*string dFrom = "";
        string dTo = "";
        if (dateFrom != null)
        {
            dFrom = dateFrom?.ToString("yyyyMMdd");
        }
        var dateToLocal = DateTime.Today.AddDays(1);
        if (dateTo != null)
        {
            var newToDate = Convert.ToDateTime(dateTo);
            dateToLocal = newToDate.AddDays(1);
            dTo = dateToLocal.ToString("yyyyMMdd");
        }*/

        var response = await Http.GetAsync("api/patient/allchanges");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<PatientChangesDto>>();

        Data = mappedData.Data;

    }


}
