@page "/gridmachines"

@using DevExpress.Blazor
@using DevExpress.Data.Filtering
@using DevExpress.Export
@using System.Net.Http.Json
@inject HttpClient Http

&nbsp;&nbsp;&nbsp;&nbsp;
<DxButton Text="Выберите столбцы"
          RenderStyle="ButtonRenderStyle.Primary"
          CssClass="column-chooser-button"
          Click="OnClickColumns" />
&nbsp;&nbsp;
<DxButton Text="Скачать"
          RenderStyle="ButtonRenderStyle.Primary"
          CssClass="column-chooser-button"
          Click="@(async() => await ExportXlsx_Click())" />

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge">
    <DxGrid @ref="Grid"
            Data="@Data"
            ShowGroupPanel="true"
            ShowFilterRow="true"
            PageSizeSelectorVisible="true"
            PageSizeSelectorAllRowsItemVisible="true"
            PageSizeSelectorItems="@(new int[] { 50,100,500 })"
            CustomizeCellDisplayText="Grid_CustomizeCellDisplayText">
        <Columns>
            <DxGridDataColumn FieldName="MedCenter.Id" Caption="No:" Width="120px" />
           
            <DxGridDataColumn FieldName="MedCenter.Title" Caption="Наименование организации здравоохранения" Width="180px" AllowGroup="true" TextAlignment="GridTextAlignment.Left">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.Name" Caption="Наименование, серия  и год выпуска аппарата (АИП)" Width="180px" MinWidth="100" TextAlignment="GridTextAlignment.Center" AllowGroup="false">                
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.Manufacturer" Caption="Предприятие – производитель" MinWidth="120" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.ManCountry" Caption="Страна производства" MinWidth="100" AllowGroup="false">
            </DxGridDataColumn>            
            <DxGridDataColumn FieldName="MedCenterMachine.CertificateHolder" Caption="Держатель свидетельства" Width="100px" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.CertificateHolderCountry" Caption="Страна держателя свидетельства" Width="100px" MinWidth="100" AllowGroup="false">
            </DxGridDataColumn>           
            <DxGridDataColumn FieldName="MedCenterMachine.CertificateNumber" Caption="Номер  и дата выдачи свидетельства" Width="100px" TextAlignment="GridTextAlignment.Left" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.PermitName" Caption="Данные разрешительных документов на АИП (наименование, серия, номер, срок действия)" Width="100px" TextAlignment="GridTextAlignment.Left" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.PermitNumber" Caption="Количество АИП" Width="100px" TextAlignment="GridTextAlignment.Left" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.Number" Caption="Количество резервных АИП" Width="100px" TextAlignment="GridTextAlignment.Left" AllowGroup="false">
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="MedCenterMachine.TotalSessions" Caption="Нагрузка на один АИП (сеансов в сутки)" Width="100px" TextAlignment="GridTextAlignment.Left" AllowGroup="false">
            </DxGridDataColumn>
        </Columns>
        <TotalSummary>
            <DxGridSummaryItem FieldName="Id" SummaryType="GridSummaryItemType.Count" />
        </TotalSummary>
        <GroupSummary>
            <DxGridSummaryItem FieldName="Id" SummaryType="GridSummaryItemType.Count" />
        </GroupSummary>
    </DxGrid>

</MudContainer>

@code {
    IGrid Grid;
    private List<MedCenterMachineDto> Data { get; set; }

    private List<PatientGroup> PatientGroupList { get; set; }

    DataGridFilterMode _filterMode = DataGridFilterMode.Simple;
    DataGridFilterCaseSensitivity _caseSensitivity = DataGridFilterCaseSensitivity.Default;

    void Grid_CustomizeCellDisplayText(GridCustomizeCellDisplayTextEventArgs e)
    {

    }


    void OnClickColumns()
    {
        Grid.ShowColumnChooser(".column-chooser-button");
    }


    async Task ExportXlsx_Click()
    {
        await Grid.ExportToXlsxAsync("Сводный_реестр_пациенты_xlsx", new GridXlExportOptions()
            {
                ExportSelectedRowsOnly = false
            });
    }


    protected override async Task OnInitializedAsync()
    {       
        await LoadDataAsync();
    }
       
    private async Task LoadDataAsync()
    {

        var response = await Http.GetAsync("api/medcenter/allmachinesdto");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<MedCenterMachineDto>>();

        Data = mappedData.Data;

    }

    


    record GenderState(bool? Value, string DisplayText);
    record AgeInterval(CriteriaOperator Criteria, string DisplayText)
    {
        public AgeInterval(string CriteriaText, string DisplayText)
            : this(CriteriaOperator.Parse(CriteriaText), DisplayText)
        {
        }
    }
    record IdTitle(long Id, string Title);

}
