@page "/gridpatients4"

@using DevExpress.Blazor
@using DevExpress.Data.Filtering
@using DevExpress.Export
@using System.Net.Http.Json
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Large">
    <MudGrid>        
        <MudItem xs="12" md="10">
            <MudText Typo="Typo.h6">Список отсутствовавших пациентов</MudText>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudSwitch @bind-Checked="checkPageType"
                T="bool"
                Color="Color.Primary"
                Label="@($"{(checkPageType ? "Активные" : "Отсутствующие")} пациенты")"
                ThumbIcon="@(checkPageType ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)"
                ThumbIconColor="@(checkPageType ? Color.Success : Color.Error)" />
        </MudItem>
    </MudGrid>
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudSelect T="long" Label="Мед. центр" @bind-Value="@searchModel.MedCenterId" AnchorOrigin="Origin.BottomCenter">
                    @{
                        <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            @{
                if (checkPageType == true)
                {
                    <MudItem xs="12" md="3">
                        <MudDatePicker Label="Дата от" @bind-Date="dateFrom" DateFormat="dd.MM.yyyy" DisableToolbar="true"/>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudDatePicker Label="Дата до" @bind-Date="dateTo" DateFormat="dd.MM.yyyy" DisableToolbar="true"/>
                    </MudItem>
                    <MudItem xs="2" md="3">
                        <br/>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async () => await LoadDataAsync())">Обновить</MudButton>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12" md="2">
                        <MudDatePicker Label="Дата от" @bind-Date="dateFrom" DateFormat="dd.MM.yyyy" DisableToolbar="true"/>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudDatePicker Label="Дата до" @bind-Date="dateTo" DateFormat="dd.MM.yyyy" DisableToolbar="true"/>
                    </MudItem>

                    <MudItem xs="12" md="3">
                        <MudSelect T="int" Label="Минимум дней отс." @bind-Value="@totalDays" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem T="int" Value="10">10</MudSelectItem>
                            <MudSelectItem T="int" Value="20">20</MudSelectItem>
                            <MudSelectItem T="int" Value="30">30</MudSelectItem>
                            <MudSelectItem T="int" Value="50">50</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="2" md="2">
                        <br/>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async () => await LoadDataAsync())">Обновить</MudButton>
                    </MudItem>
                }
            }
            <MudItem xs="12" md="12">
                <MudCardActions>
                </MudCardActions>
            </MudItem>

        </MudGrid>
    </EditForm>
</MudContainer>

&nbsp;&nbsp;&nbsp;&nbsp;
<DxButton Text="Выберите столбцы"
          RenderStyle="ButtonRenderStyle.Primary"
          CssClass="column-chooser-button"
          Click="OnClickColumns" />
&nbsp;&nbsp;
<DxButton Text="Скачать"
          RenderStyle="ButtonRenderStyle.Primary"
          CssClass="column-chooser-button"
          Click="@(async() => await ExportXlsx_Click())" />

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge">
        <DxGrid @ref="Grid"
                Data="@Data"
                ShowGroupPanel="true"
                ShowFilterRow="true"
                PageSizeSelectorVisible="true"
                PageSizeSelectorAllRowsItemVisible="true"
                PageSizeSelectorItems="@(new int[] { 50,100,500 })"
                CustomizeCellDisplayText="Grid_CustomizeCellDisplayText">
            <Columns>
                <DxGridDataColumn FieldName="Id" Caption="Код" Width="70px" />
                <DxGridDataColumn FieldName="Inn" Caption="ПИН" Width="130px" AllowGroup="true" TextAlignment="GridTextAlignment.Left">
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="Fio" Caption="Фио" Width="320px" MinWidth="300" TextAlignment="GridTextAlignment.Left" AllowGroup="false" AllowSort="true">
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="PhoneNumber1" Caption="Телефон" Width="90px"  TextAlignment="GridTextAlignment.Left" AllowGroup="false" AllowSort="true"/>
                <DxGridDataColumn FieldName="PhoneNumber2" Caption="Телефон" Width="90px"  TextAlignment="GridTextAlignment.Left" AllowGroup="false" AllowSort="true"/>
                <DxGridDataColumn FieldName="MedCenterTitle" Caption="Мед. центр" Width="250px"  TextAlignment="GridTextAlignment.Left" AllowGroup="false" AllowSort="true"/>
                
                @{
                    if (!checkPageType)
                    {
                        <DxGridDataColumn FieldName="LastDate" Caption="Последняя дата" MinWidth="120" AllowGroup="false">
                        </DxGridDataColumn>
                    }
                }
                @*<DxGridDataColumn FieldName="PhoneNumber2" Caption="Телефон" Width="180px"  TextAlignment="GridTextAlignment.Left" AllowGroup="false" AllowSort="true">
                </DxGridDataColumn>*@
            </Columns>
            <TotalSummary>
                <DxGridSummaryItem FieldName="Id" SummaryType="GridSummaryItemType.Count" />
            </TotalSummary>
            <GroupSummary>
                <DxGridSummaryItem FieldName="Id" SummaryType="GridSummaryItemType.Count" />
            </GroupSummary>
        </DxGrid>
</MudContainer>

@code {
    IGrid Grid;
    private List<PatientTotalHdDto> Data { get; set; }
    

    private SearchtDto searchModel = new SearchtDto();

    private DateTime? dateFrom = DateTime.Today.AddDays(-30);
    private DateTime? dateTo = DateTime.Today;
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();
    private int totalDays = 10;
    private bool _checkPageType;
    private bool checkPageType { get; set; } = false;
    


    DataGridFilterMode _filterMode = DataGridFilterMode.Simple;
    DataGridFilterCaseSensitivity _caseSensitivity = DataGridFilterCaseSensitivity.Default;

    void Grid_CustomizeCellDisplayText(GridCustomizeCellDisplayTextEventArgs e)
    {

       if (e.FieldName == "LastDate")
        {
            e.DisplayText = (e.Value != null ? ((DateTime)e.Value).ToString("dd.MM.yyyy") : "");
        }        
    }
    
    void OnClickColumns()
    {
        Grid.ShowColumnChooser(".column-chooser-button");
    }


    async Task ExportXlsx_Click()
    {
        await Grid.ExportToXlsxAsync("Список_список_отсутствовавших_пациентов", new GridXlExportOptions()
            {
                ExportSelectedRowsOnly = false
            });
    }


    protected override async Task OnInitializedAsync()
    {
        await LoadUserCentersAsync();       
        await LoadDataAsync();
    }


    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                searchModel.MedCenterId = 0;
            }
            else
            {
                searchModel.MedCenterId = UserCenters.Select(t => t.Id).FirstOrDefault();
            }
        }
    }
    private async Task LoadDataAsync()
    {
        string dFrom = "";
        string dTo = "";
        if (dateFrom != null)
        {
            dFrom = dateFrom?.ToString("yyyyMMdd");
        }
        if (dateTo != null)
        {
            dTo = dateTo?.ToString("yyyyMMdd");
        }

        string typePage = checkPageType ? "true" : "false";
        Console.WriteLine($"api/patient/allpatients4?MedCenterId={searchModel.MedCenterId}&totalDays={totalDays}&fromDate={dFrom}&toDate={dTo}&typePage={typePage}");
        var response = await Http.GetAsync($"api/patient/allpatients4?MedCenterId={searchModel.MedCenterId}&totalDays={totalDays}&fromDate={dFrom}&toDate={dTo}&typePage={typePage}");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<PatientTotalHdDto>>();
        Console.WriteLine(mappedData.Data);
        Data = mappedData.Data;

    }


}
