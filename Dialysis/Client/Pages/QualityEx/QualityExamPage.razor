@page "/qualityexam"
@using System.Net.Http.Json
@inject HttpClient Http
<style>
    .mud-tooltip-root.mud-tooltip-inline {
        max-width: 330px;
    }

</style>
<MudTabs Color="@Color.Info" Outlined="true" @bind-ActivePanelIndex="activeTab">

   
        <MudTabPanel Text="1. Акт медицинской экспертизы проведенных сеансов диализа
                форма №11 ОМС/у" />
    <MudTabPanel Text="2. Акт медицинской экспертизы проведенных  сеансов диализа без выявленных дефектов  форма №11-1 ОМС/у" />
    <MudTabPanel Text="3. Экспертиза качества проведенных сеансов ГД/ГДФ
                Форма №11 ОМС/о" />
</MudTabs>
@{
    if (activeTab == 0)
    {
        <Dialysis.Client.Pages.QualityEx.ExamPage1 MedCardId=MedCardId />
    }
    else if (activeTab == 1)
    {

        <Dialysis.Client.Pages.QualityEx.ExamPage2 MedCardId=MedCardId />
       
    }
    else 
    {
        <Dialysis.Client.Pages.QualityEx.ExamPage3 MedCardId=MedCardId />
    }
   
}

