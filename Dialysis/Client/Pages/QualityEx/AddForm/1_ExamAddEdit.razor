    DateTime? date2 = null;

    public bool labBool { get; set; }

    protected override async Task OnInitializedAsync()
    {

        StateHasChanged();
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }
    private async Task SaveAsync()
    {
        
            AddEditModel.IsDeleted = false;
            AddEditModel.AktDate = date;
            AddEditModel.FromDate = date1;
            AddEditModel.ToDate = date2;
            var response = await _httpClient.PostAsJsonAsync("api/status/addakt1", AddEditModel);
            var result = await response.ToResult();
            if (!result.Succeeded)
            {
                _snackBar.Add(result.Messages[0], Severity.Error);
                MudDialog.Close(DialogResult.Ok(false));
            }
            else
            {
                _snackBar.Add("Успешно", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
       
           
    }
}
