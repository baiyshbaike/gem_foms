@using System.Net.Http.Json
@inject HttpClient Http

<MudTable Items="@Elements" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped">
    <ToolBarContent>
        <AuthorizeView Roles="hdsession_add">
          
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.AddCard"
                       @onclick="@(() => AddEditModal(0))"
                               Size="Size.Small"
                               Color="Color.Info">
                        Добавить
                    </MudButton>
              
        </AuthorizeView>
         
        <MudSpacer />      
            </ToolBarContent>
            <HeaderContent>
                <MudTh>ID</MudTh>               
                <MudTh>Сотрудник</MudTh>
                <MudTh>Дата </MudTh>               
                <MudTh></MudTh>
               
            </HeaderContent>
            <RowTemplate>
        <MudTd>@context.Id</MudTd>
                <MudTd>@context.CreatedBy</MudTd>   
                <MudTd>@context.AktDate?.ToString("dd.MM.yyyy")</MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Filled"
                               @onclick="@(async() => await AddEditModal(context.Id))" StartIcon="@Icons.Material.Filled.FileOpen"
                               Size="Size.Small" Color="Color.Info">
                        Подробности
                    </MudButton>
                </MudTd>
              
       
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
</MudTable>


@code {
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private bool tableLoading = false;

    [Parameter]
    public long MedCardId { get; set; } = 0;


    private IEnumerable<QualityExam1> Elements = new List<QualityExam1>();

    protected override async Task OnInitializedAsync()
    {
        
           
            await LoadDataAsync();
               
    }
    private async Task LoadDataAsync()
    {
        var response = await Http.GetAsync("api/status/allakt1");
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<QualityExam1>>();
        Elements = mappedData.Data;
    }


    private async Task AddEditModal(long id = 0)
    {
        var parameters = new DialogParameters();
        //parameters.Add("HDSessionId", id);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<Dialysis.Client.Pages.QualityEx.AddForm._1_ExamAddEdit>("Добавить", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync(); 
        }
    }

}
