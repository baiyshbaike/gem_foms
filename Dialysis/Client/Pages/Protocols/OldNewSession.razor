
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime


<MudContainer MaxWidth="MaxWidth.Large">
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="6" md="4">
                <MudTextField For="@(() => searchModel.Inn)" @bind-Value="searchModel.Inn" Label="ИНН" />
            </MudItem>
            <MudItem xs="6" md="4">
                @if (!string.IsNullOrEmpty(frameUri))
                {
                    <img src="@frameUri" />
                }
            </MudItem>
            <MudItem xs="12" md="1">
                &nbsp;
            </MudItem>
            <MudItem xs="6" md="3">
                <video id="videoFeed" width="240" height="180" /><canvas class="d-none" id="currentFrame" width="320" height="240" />
                <br />
                <MudFab Color="Color.Tertiary" @onclick="CaptureFrame" StartIcon="@Icons.Material.Filled.CameraAlt" DisableElevation="true" />
            </MudItem>



            <MudItem xs="12" md="4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchAsync" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Поиск пациент</MudButton>

            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudForm @ref="form" Model="@sendModel" @bind-IsValid="@IsValid">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="sendModel.Inn" Required="true"  Label="ИНН" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText> @patientModel?.LastName @patientModel?.FirstName</MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="long" Label="Мед. центр" SelectedValuesChanged="LoadMachinesAsync" @bind-Value="@MedCenterId" AnchorOrigin="Origin.BottomCenter">
                    @{
                        if (IsOnlyCenter == false)
                        {
                            <MudSelectItem T="long" Value="0">-------</MudSelectItem>

                        }
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>

            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="long" Label="Апарат" Required="true" @bind-Value="@MachineId" AnchorOrigin="Origin.BottomCenter">
                    @{
                        <MudSelectItem T="long" Value="0">---</MudSelectItem>
                        @foreach (var selectReg in MachineList)
                        {
                            <MudSelectItem T="long" Value="@selectReg.Id">@selectReg.Number @selectReg.Name  @selectReg.Model</MudSelectItem>
                        }                       
                    }

                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="12">
                <MudTextField  @bind-Value="sendModel.Condition"  Required="true"  Label="Состояние пациента на момент под. к АИП" />
            </MudItem>
            <MudItem xs="12" md="12">
                <MudTextField @bind-Value="sendModel.Complaints" Required="true" Label="Жалобы на момент осмотра" />
            </MudItem>

            <MudItem xs="6" md="4">
                <MudTextField  @bind-Value="sendModel.Program"  Required="true" Label="Программа сеанса" />
            </MudItem>
            <MudItem xs="6" md="4">
                <MudTextField @bind-Value="sendModel.Dialyzer"  Required="true" Label="Диализатор промыт и зап. рествором" />
            </MudItem>
            <MudItem xs="6" md="4">
                <MudTextField  @bind-Value="sendModel.Correction"  Required="true"  Label="Коррекция электролитов по Na" />
            </MudItem>
            <MudItem xs="6" md="4">
                <MudTextField  @bind-Value="sendModel.Reinfusion"  Required="true"  Label="Реинфузия NaCI" />
            </MudItem>

            <MudItem xs="6" md="4">
                <MudTextField  @bind-Value="sendModel.Access"  Required="true"  Label="Доступ" />
            </MudItem>
            <MudItem xs="6" md="4">
                <MudTextField @bind-Value="sendModel.Anticoagulation"  Required="true" Label="Антикоагуляция" />
            </MudItem>
            <MudItem xs="6" md="4">
                <MudTextField  @bind-Value="sendModel.Uf"  Required="true"  Label="Обьем УФ" />
            </MudItem>
            <MudItem xs="6" md="4">
                <MudTextField  @bind-Value="sendModel.Speed"  Required="true"  Label="Скорость потока крови" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="sendModel.Durators" Required="true" Label="Длителность" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="sendModel.TypeDialyzer"  Required="true" Label="Тип диализатора" />
            </MudItem>

           
            <MudItem xs="12" md="4">
                <MudTextField  @bind-Value="sendModel.StartWeight"  Required="true" Label="Вес пациента" />
            </MudItem>           
            <MudItem xs="3" md="2">
                <MudTextField For="@(() => sendModel.Sys)" Required="true" @bind-Value="sendModel.Sys" Label="SYS" />
            </MudItem>
            <MudItem xs="3" md="2">
                <MudTextField For="@(() => sendModel.Dia)"  Required="true" @bind-Value="sendModel.Dia" Label="DIA" />
            </MudItem>
            <MudItem xs="3" md="2">
                <MudTextField For="@(() => sendModel.Ritm)"  Required="true" @bind-Value="sendModel.Ritm" Label="Частота" />
            </MudItem>
            <MudItem xs="3" md="2">
                <MudTextField For="@(() => sendModel.Temp)" Required="true" @bind-Value="sendModel.Temp" Label="Температура" />
            </MudItem>

            <MudCardActions>
                <MudButton 
                    Variant="Variant.Filled"
                           OnClick="@(async () => await SaveAsync())"
                           Disabled="@GetDisable()" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send" Class="ml-auto">Начать сеанс гемодиализа</MudButton>
            </MudCardActions>

        </MudGrid>
    </MudForm>
</MudContainer>

@code {

    [Parameter]
    public long MedCardId { get; set; } = 0;
    [Parameter]
    public string inn { get; set; }
    
    MudForm form;
    private SearchtDto searchModel = new SearchtDto();
    private string frameUri;

    private HDSession sendModel = new HDSession();

    private Patient patientModel = new Patient();
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();
    private bool IsOnlyCenter = true;
    private IEnumerable<MedCenterMachine> MachineList = new List<MedCenterMachine>();
    private bool IsDisabled = true;
    private bool IsValid;

    public long MedCenterId { get; set; }
    public long MachineId { get; set; }

    private bool GetDisable()
    {
        if(IsDisabled==false && IsValid==true){
            return false;
        }
        else
        {
            return true;
        }
    }

    

    protected override async Task OnInitializedAsync()
    {
        if (MedCardId > 0)
        {
            await JSRuntime.InvokeVoidAsync("startVideo", "videoFeed");            
            await LoadUserCentersAsync();
            sendModel.MedCardId = MedCardId;
            searchModel.Inn = inn;
        }
        else
        {
            _navigationManager.NavigateTo("/medcardlist");
        }
    }

    private async Task SearchAsync()
    {
        IsDisabled = true;
        var response = await Http.GetAsync("api/patient/searchpatient?Inn=" + searchModel.Inn);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<Patient>();
        patientModel = mappedData.Data;
        //tableLoading = false;
        if (patientModel != null)
        {
            sendModel.PatientId = patientModel.Id;
            sendModel.Inn = patientModel.Inn;
            sendModel.ImageStart = patientModel.LastName + " " + patientModel.FirstName;
            //sendModel.MedCardId = 0;
            IsDisabled = false;
        }
    }

    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                IsOnlyCenter = false;
                sendModel.MedCenterId = 0;
            }
            else
            {
                sendModel.MedCenterId = UserCenters.Select(t => t.Id).FirstOrDefault();
                await LoadMachinesAsync();
            }
        }
    }

    private async Task LoadMachinesAsync()
    {
        sendModel.MachineId = 0;
        if (sendModel.MedCenterId > 0)
        {
            var response = await Http.GetAsync("api/medcenter/allmachines?Id=" + sendModel.MedCenterId);
            var mappedData = await response.ToResult<List<MedCenterMachine>>();
            MachineList = mappedData.Data;
        }
    }


    private async Task SaveAsync()
    {
        if (IsValid)
        {
            sendModel.ImageStart = frameUri;
            sendModel.MedCardId = MedCardId;
            var response = await _httpClient.PostAsJsonAsync("api/medcard/addsession", sendModel);
            var result = await response.ToResult();
            if (!result.Succeeded)
            {
                _snackBar.Add(result.Messages[0], Severity.Error);
            }
            else
            {
                _snackBar.Add("Успешно", Severity.Success);
                _navigationManager.NavigateTo("/processing");
            }
        }
    }

    

    public class SearchtDto
    {
        public string Fio { get; set; }
        public string Inn { get; set; }
        public string Image { get; set; }

    }


    private async Task CaptureFrame()
    {
        await JSRuntime.InvokeAsync<String>("getImageFrame", "videoFeed", "currentFrame", DotNetObjectReference.Create(this));
    }


    [JSInvokable]
    public void ProcessImage(string imageString)
    {
        frameUri = imageString;
        //byte[] imageData = Convert.FromBase64String(imageString.Split(',')[1]);

        //Do image processing here


        //using (var image = Image.Load(imageData))
        //{
        //   frameUri = image.ToBase64String(JpegFormat.Instance);
        //}
    }

}
