@inject HttpClient Http
<MudForm @ref="form" Model="@AddEditModel" @bind-IsValid="@IsValid">
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                Пауза
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" md="12">
                    <MudTextField For="@(() => AddEditModel.Note)" @bind-Value="AddEditModel.Note" Label="Примечание" Required="true" />
                </MudItem>
                <MudItem xs="12" md="2">                    
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled"
                       OnClick="@(async () => await SaveAsync())"
                       Disabled="@(!IsValid)"
                       Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</MudForm>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public HDSessionPause AddEditModel { get; set; } = new();
    [Parameter] public string hour { get; set; } = "1";
    [Parameter] public long HDSessionId { get; set; }
    bool IsValid;
    MudForm form;


    protected override async Task OnInitializedAsync()
    {
        AddEditModel.HDSessionId = HDSessionId;       
    }

    private async Task SaveAsync()
    {
        AddEditModel.HDSessionId = HDSessionId;        
        var response = await _httpClient.PostAsJsonAsync("api/medcard/addpause", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }
}
