@page "/allprocess"
@page "/allprocess/{Mid:long}"
@using System.Net.Http.Json
@using Dialysis.Shared.Constants
@inject HttpClient Http
@inject AuthenticationStateProvider GetAuthenticationStateAsync

<MudContainer MaxWidth="MaxWidth.Large">
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="long" Label="Мед. центр" @bind-Value="@searchModel.MedCenterId" AnchorOrigin="Origin.BottomCenter" Disabled="@IsOnlyCenter">
                    @{
                        if (!IsOnlyCenter)
                        {
                            <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                        }
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
             <MudItem xs="12" md="2">
                <MudDatePicker Label="Дата от" @bind-Date="dateFrom" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Дата до" @bind-Date="dateTo" DateFormat="dd.MM.yyyy" DisableToolbar="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="long" 
                           Label="Час" 
                           @bind-Value="_selectedState"
                           AnchorOrigin="Origin.BottomCenter"
                >
                    <MudSelectItem T="long" Value="0">Выбрать все</MudSelectItem>
                    <MudSelectItem T="long" Value="1">До 3-х часов</MudSelectItem>
                    <MudSelectItem T="long" Value="2">До 4-х часов</MudSelectItem>
                    <MudSelectItem T="long" Value="3">Более 4-х часов</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="2" md="2">
                <MudSelect T="long" Label="Статус" @bind-Value="@searchModel.Status" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                    <MudSelectItem T="long" Value="4">Завершенный</MudSelectItem>
                    <MudSelectItem T="long" Value="5">К оплате</MudSelectItem>
                    <MudSelectItem T="long" Value="6">Оплачено</MudSelectItem>
                    <MudSelectItem T="long" Value="12">Архив</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="12">
                <MudCardActions>
                    <br />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async() => await LoadSessionsAsync())">Обновить</MudButton>
                </MudCardActions>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>


<MudTable Items="@Elements" RowStyleFunc="GetRowColor" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" Filter="new Func<HDSessionDto,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Все протоколы - @totalCount</MudText>
        @if (viewButton)
        {
        <MudButton Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.Send" Color="Color.Primary" OnClick="ChekToPayAll">К оплате</MudButton>
        }
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>ФИО</MudTh>
        <MudTh>ИНН</MudTh>
        <MudTh>Мед. Центр</MudTh>
        <MudTh>ГД Аппарат</MudTh>
        <MudTh>Дата Подключения</MudTh>
        <MudTh>Дата Отключения</MudTh>
        <MudTh>Дата Изменения</MudTh>
        <MudTh>Статус</MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Patient.LastName @context.Patient.FirstName</MudTd>
        <MudTd>@context.Patient.Inn</MudTd>
        <MudTd>@context.MedCenter.Title</MudTd>
        <MudTd>@context.MedCenterMachine.Number @context.MedCenterMachine.Name  @context.MedCenterMachine.Model</MudTd>
        <MudTd>@context.HDSession.SessionStart?.ToString("dd.MM.yyyy HH:mm")</MudTd>
        <MudTd>@context.HDSession.SessionEnd?.ToString("dd.MM.yyyy HH:mm")</MudTd>
        <MudTd>@context.HDSession.LastModifiedOn?.ToString("dd.MM.yyyy HH:mm")</MudTd>
        <MudTd>
            @{
                if (@context.HDSession.StatusId == (long)HDSessionEnum.SendToPay)
                {
                    <MudText>К оплате</MudText>
                }else if (@context.HDSession.StatusId == (long)HDSessionEnum.Payed)
                {
                    <MudText>Оплачено</MudText>
                }
                else if (context.HDSession.StatusId == (long)HDSessionEnum.Finished)
                {
                    <MudText>Завершенный</MudText>
                }
                else if (context.HDSession.StatusId == (long)HDSessionEnum.Ended)
                {
                    <MudText>Архив</MudText>
                }
                else if (@context.HDSession.StatusId == (long)HDSessionEnum.Failed)
                {
                    <MudText>Error</MudText>
                }
            }
        </MudTd>
        <MudTd>
            @{
                if (context.HDSession.TotalMinutes > 0)
                {
                    <MudText> @MinutsTohHours((double)context.HDSession.TotalMinutes) </MudText>
                }
            }
        </MudTd>
        <MudTd>
            @if (@context.HDSession.StatusId == (long)HDSessionEnum.SendToPay && @viewButton)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Check"
                            aria-label="Оплачено"
                            @onclick="@(async() => await CheckToPay(context.HDSession))"
                            Size="Size.Large"
                            Color="Color.Warning">
                </MudIconButton>
            }
            else if(@context.HDSession.StatusId == (long)HDSessionEnum.Payed)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Check"
                               aria-label="Оплачено"
                               Size="Size.Large"
                               Color="Color.Success">
                </MudIconButton>
            }
        </MudTd>
        <MudTd>
            <MudButton Variant="Variant.Filled"
                       @onclick="@(async() => await AddEditModal(context.HDSession.Id))" StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                Подробности
            </MudButton>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>


@code {
    [Parameter]
    public long? Mid { get; set; }
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private HDSessionDto selectedItem1 = null;
    private HashSet<HDSessionDto> selectedItems = new HashSet<HDSessionDto>();
    private List<HDSession> hDSessionsList = new List<HDSession>();
    private IEnumerable<HDSessionDto> Elements = new List<HDSessionDto>();
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();

    private SearchtDto searchModel = new SearchtDto();
    private bool IsOnlyCenter = true;
    private bool tableLoading = true;
    private bool viewButton = false;
    private DateTime? dateFrom = DateTime.Today;
    private DateTime? dateTo = DateTime.Today;
    private int totalCount = 0;
    private long _selectedState = 0;

    protected override async Task OnInitializedAsync()
    {
        var authstate = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
        var user = authstate.User;
        viewButton = user.IsInRole("admin");
        await LoadUserCentersAsync();
        if (Mid != null)
        {
            searchModel.MedCenterId = (long)Mid;
            await LoadSessionsAsync();
        }
        else
        {
            await LoadSessionsAsync();
        }
        //await LoadSessionsAsync();
        StateHasChanged();
    }
    private async Task CheckToPay(HDSession hDSession)
    {
        var response = await _httpClient.PostAsJsonAsync("api/medcard/checktopay", hDSession);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            await LoadSessionsAsync();
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            await LoadSessionsAsync();
        }
    }
    private async Task ChekToPayAll()
    {
        hDSessionsList = Elements
            .Where(item => item.HDSession.StatusId == (long)HDSessionEnum.SendToPay)
            .Select(item => item.HDSession)
            .ToList();
        var response =await _httpClient.PostAsJsonAsync("api/medcard/checktopayall", hDSessionsList);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            await LoadSessionsAsync();
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            await LoadSessionsAsync();
        }
    }
    private async Task LoadSessionsAsync()
    {
        tableLoading = true;
        string dFrom = "";
        string dTo = "";
        if (dateFrom != null)
        {
            dFrom = dateFrom?.ToString("yyyyMMdd");
        }
        var dateToLocal = DateTime.Today.AddDays(1);
        if (dateTo != null)
        {
            var newToDate = Convert.ToDateTime(dateTo);
            dateToLocal = newToDate;
            dTo = dateToLocal.ToString("yyyyMMdd");
        }

        string searchParams = "&statusid=" + searchModel.Status + "&fromDate=" + dFrom + "&toDate=" + dTo +"&hour="+_selectedState.ToString();

        if (IsOnlyCenter && searchModel.MedCenterId == 0 && UserCenters.Count() == 1)
        {
            searchModel.MedCenterId = UserCenters.First().Id;
        }

        var response = await Http.GetAsync("api/medcard/allsessions?medCenterId=" + searchModel.MedCenterId + "" + searchParams);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<HDSessionDto>>();
        Elements = mappedData.Data;
        totalCount = Elements.Count();
        tableLoading = false;
    }

    private  string MinutsTohHours(double totalMinutes)
    {
        int hours = (int)(totalMinutes / 60);
        //total minutes
        int minutes = (int)(totalMinutes % 60);
        //output is 1:10
        var time = $"{hours}:{minutes:00}";
        return time;
        /*TimeSpan t = TimeSpan.FromMinutes(totalMinutes);
        int hours = (int)t.TotalHours;
        int minutes = (int)t.TotalMinutes;
        return hours+":"+minutes;
        double totalHours = 0;
        totalHours = ((totalMinutes % 60) / 100);
        return Math.Floor(totalMinutes / 60) + totalHours;*/
    }

    private string GetRowColor(HDSessionDto hdItem, int index)
    {
        string retColor = "background-color:#FFF";
        if (hdItem.HDSession.StatusId == (long)HDSessionEnum.SendToPay)
        {
            retColor = "background-color:#FFF";
        }
        else if (hdItem.HDSession.StatusId == (long)HDSessionEnum.Payed)
        {
            retColor = "background-color:#8fc7f9";
        }
        else if (hdItem.HDSession.StatusId == (long)HDSessionEnum.Rejected)
        {
            retColor = "background-color:#FF0000";
        }
        else if (hdItem.HDSession.StatusId == (long)HDSessionEnum.Finished)
        {
            var nowDate = DateTime.Now;
            var totalHours = (int)((nowDate - (DateTime)hdItem.HDSession.SessionEnd).TotalHours);
            /*int hours = (int)((double)hdItem.HDSession.TotalMinutes / 60);
                if (hours > 4)
                {
                totalHours = totalHours + (hours - 4);
            }*/
            if (totalHours > 4.5)
            {
                retColor = "background-color:#E9967A";
            }
        }
        return retColor;
    }


    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                IsOnlyCenter = false;
                searchModel.MedCenterId = 0;
            }
            else if (UserCenters.Count() == 1)
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = UserCenters.First().Id;
            }
            else
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = 0;
            }
        }
    }

    private bool FilterFunc1(HDSessionDto element) => FilterFunc(element, searchString1);

    private bool FilterFunc(HDSessionDto element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (!string.IsNullOrEmpty(element.MedCenter.Title))
        {
            if (element.MedCenter.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrEmpty(element.Patient.Inn))
        {
            if (element.Patient.Inn.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrEmpty(element.Patient.FirstName))
        {
            if (element.Patient.FirstName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrEmpty(element.Patient.LastName))
        {
            if (element.Patient.LastName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        return false;
    }

    private async Task AddEditModal(long id = 0)
    {
        var parameters = new DialogParameters();
        parameters.Add("HDSessionId", id);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true,  DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<SessionDetail>("Подробности", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            //await LoadSessionsAsync();
        }
    }

    


}

