@using DevExpress.ClipboardSource.SpreadsheetML
@inject IJSRuntime js
<MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 500px; overflow-y: scroll">
    <EditForm Model="@AddEditModel" OnValidSubmit="SaveAsync">
        <MudDialog>
            <TitleContent>
                @{
                    if (AddEditModel.Id == 0)
                    {
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                            Добавить Пациент
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                            Редактировать Дата Отключения
                        </MudText>
                    }
                }
            </TitleContent>
            <DialogContent>
                <MudGrid>
                    <MudItem xs="12" md="12" Class="d-flex align-center flex-grow-1 gap-4">
                        <MudItem xs="12" md="6" Class="d-flex flex-1">
                            <MudDatePicker DateFormat="dd.MM.yyyy" Label="End date" @bind-Date="date" Editable="true"/>
                        </MudItem>
                        <MudItem xs="12" md="6" Class="d-flex flex-1" style="margin: 0.4rem 0;">
                            <InputDate Type="InputDateType.Time" @bind-Value="@TimeVar" />
                        </MudItem>
                    </MudItem>
                </MudGrid>
            </DialogContent>
            <DialogActions>
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
                 <MudButton Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success">Сохранить</MudButton>
             </DialogActions>
         </MudDialog>
     </EditForm>
 </MudContainer>
 @code {
    [Parameter] public HDSession AddEditModel { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    
    private DateTime? date = DateTime.Today;
    private TimeOnly TimeVar = TimeOnly.FromDateTime(DateTime.Now);
    public void Cancel()
    {
        MudDialog.Cancel();
    }
    public class TimeInfo
    {
        public int Hour { get; set; }
        public int Minute { get; set; }
    }
    private async Task SaveAsync()
    {
        
        AddEditModel.SessionEnd = date.Value.Add(TimeVar.ToTimeSpan());
        var response = await _httpClient.PostAsJsonAsync("api/medcard/sendtoend", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

}
