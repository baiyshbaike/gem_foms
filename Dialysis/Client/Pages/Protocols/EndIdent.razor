﻿@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 500px; overflow-y: scroll">
    <EditForm Model="@searchModel">
        <MudDialog>
            <TitleContent>
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                    Завершить сеанс(идентификация)
                </MudText>
            </TitleContent>
            <DialogContent>

                <MudGrid>
                    <MudItem xs="6" md="4">
                        <MudTextField For="@(() => searchModel.Inn)" @bind-Value="searchModel.Inn" Label="ИНН" />
                    </MudItem>
                    <MudItem xs="6" md="4">
                        @if (!string.IsNullOrEmpty(frameUri))
                        {
                            <img src="@frameUri" />
                        }
                    </MudItem>
                    <MudItem xs="12" md="1">
                        &nbsp;
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <video id="videoFeed" width="240" height="180" />
                        <canvas class="d-none" id="currentFrame" width="320" height="240" />
                        <br />
                        <MudFab Color="Color.Tertiary" @onclick="CaptureFrame" StartIcon="@Icons.Material.Filled.CameraAlt" DisableElevation="true" />
                    </MudItem>

                    <MudItem xs="12" md="12">
                        &nbsp;
                    </MudItem>
                    <MudItem xs="12" md="12">
                        &nbsp;
                    </MudItem>
                </MudGrid>
            </DialogContent>
            <DialogActions>
                <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>

                 <MudButton Variant="Variant.Filled"
                            OnClick="@(async () => await SaveAsync())"
                            Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send" Class="ml-auto">Сохранить</MudButton>

             </DialogActions>
         </MudDialog>
     </EditForm>
 </MudContainer>

 @code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public HDSession sendModel { get; set; }
    [Parameter] public long HDSessionId { get; set; }

    MudForm form;
    private SearchtDto searchModel = new SearchtDto();
    private string frameUri;

    private bool IsDisabled = true;
    private bool IsValid;

    private Patient patientModel = new Patient();
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();
    private bool IsOnlyCenter = true;
    private IEnumerable<MedCenterMachine> MachineList = new List<MedCenterMachine>();
    private bool IsOneCenter = true;


    private MedCenter SelMedCenter { get; set; }


    private bool GetDisable()
    {
        if (IsDisabled == false && IsValid == true)
        {
            return false;
        }
        else
        {
            return true;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (sendModel != null)
        {
            searchModel.Inn = sendModel.Inn;
        }
        //await LoadUserCentersAsync();
        await JSRuntime.InvokeVoidAsync("startVideo", "videoFeed");

    }

    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                IsOneCenter = false;
            }
            else
            {

                SelMedCenter = UserCenters.Select(t => t).FirstOrDefault();
            }
        }
        else
        {
            IsOneCenter = false;
        }
    }

    private async Task SearchAsync()
    {
        IsDisabled = true;
        //var response = await Http.GetAsync("api/patient/searchpatient?Inn=" + searchModel.Inn);
        var response = await Http.GetAsync("api/patient/searchpatient?Inn=" + searchModel.Inn);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<Patient>();
        patientModel = mappedData.Data;
        //tableLoading = false;
        if (patientModel != null)
        {
            sendModel.PatientId = patientModel.Id;
            sendModel.Inn = patientModel.Inn;
            searchModel.Fio = patientModel.LastName + " " + patientModel.FirstName;
            searchModel.InnResult = patientModel.Inn;
            //sendModel.MedCardId = 0;
            IsDisabled = false;
        }
    }

    private async Task SaveAsync()
    {
        //Console.WriteLine(sendModel);
        //Console.WriteLine(SelMedCenter);
        //Console.WriteLine("My debug output.");
        //var postModel = new HDSession();
        sendModel.ImageEnd = frameUri;
        //postModel.MedCenterId = SelMedCenter.Id;
        //postModel.Inn = sendModel.Inn;
        //postModel.PatientId = (long)sendModel.PatientId;

        var response = await _httpClient.PostAsJsonAsync("api/medcard/endidentify", sendModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    public class SearchtDto
    {
        public string Fio { get; set; }
        public string Inn { get; set; }
        public string Image { get; set; }
        public long? PatientId { get; set; }
        public string InnResult { get; set; }
        public MedCenter? MedCenter { get; set; }
    }


    private async Task CaptureFrame()
    {
        await JSRuntime.InvokeAsync<String>("getImageFrame", "videoFeed", "currentFrame", DotNetObjectReference.Create(this));
    }


    [JSInvokable]
    public void ProcessImage(string imageString)
    {
        frameUri = imageString;
        //byte[] imageData = Convert.FromBase64String(imageString.Split(',')[1]);

        //Do image processing here


        //using (var image = Image.Load(imageData))
        //{
        //   frameUri = image.ToBase64String(JpegFormat.Instance);
        //}
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }



}
