@inject HttpClient Http
<MudForm @ref="form" Model="@AddEditModel" @bind-IsValid="@IsValid">

    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1"/>
                Конец сеанса  @AddEditPatientModel.FirstName @AddEditPatientModel.LastName
            </MudText>
        </TitleContent>
        <DialogContent >
            <MudGrid Style="max-height: 500px; overflow-y: scroll">
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="AddEditModel.EndWeight" Required="true" MaxLength="5" Label="Вес пациента" />
                </MudItem>
                <MudItem xs="3" md="2">
                    <MudTextField Required="true" MaxLength="4" @bind-Value="AddEditModel.EndSys" Label="SYS" />
                </MudItem>
                <MudItem xs="3" md="2">
                    <MudTextField Required="true" MaxLength="4" @bind-Value="AddEditModel.EndDia" Label="DIA" />
                </MudItem>
                <MudItem xs="3" md="2">
                    <MudTextField Required="true" MaxLength="4" @bind-Value="AddEditModel.EndRitm" Label="Частота" />
                </MudItem>
                <MudItem xs="3" md="2">
                    <MudTextField Required="true" MaxLength="4" @bind-Value="AddEditModel.EndTemp" Label="Температура" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudText Typo="Typo.h5">Синдиализные осложнения:</MudText>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCheckBox  Required="false" Label="Гипотензия" @bind-Checked="@AddEditModel.Hd1Hypotension" Color="Color.Primary"></MudCheckBox>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCheckBox  Required="false"  Label="Гипертензия" @bind-Checked="@AddEditModel.Hd2Hypertension" Color="Color.Primary"></MudCheckBox>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCheckBox  Required="false" Label="Судороги мышц конечностей" @bind-Checked="@AddEditModel.Hd3MuscleCrampsOfTheLimbs" Color="Color.Primary"></MudCheckBox>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCheckBox  Required="false"  Label="Нарушения ритма сердца" @bind-Checked="@AddEditModel.Hd4HeartRhythmDisturbances" Color="Color.Primary"></MudCheckBox>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCheckBox  Required="false" Label="Головные боли" @bind-Checked="@AddEditModel.Hd5Headache" Color="Color.Primary"></MudCheckBox>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCheckBox  Required="false" Label="Приступы стенокардии" @bind-Checked="@AddEditModel.Hd6AnginaAttacks" Color="Color.Primary"></MudCheckBox>
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Hd7Other" Label="Или др" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Hd8CorrectionOfComplications" Label="Коррекция осложнений (ЛС во время сеанса):" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Hd9PlannedAppointments" Label="Плановые назначения:" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Hd10Recommendations" Label="Рекомендации:" Lines="2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Hd11EffectiveTime" Label="Эффективное время:" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="12">
                 </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="AddEditModel.Note2" Label="Описание" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Disabled="true"  @bind-Value="AddEditModel.FioDoctor" Label="ФИО лечащево врача" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudAutocomplete T="string"
                        Label="ФИО дежурной медсестры"
                        @bind-Value="AddEditModel.FioDepartmentHead"
                        SearchFunc="@Search"
                        ResetValueOnEmptyText="true"
                        CoerceText="true"
                        Required="true"
                        AdornmentIcon="@Icons.Material.Filled.Search"
                        AdornmentColor="Color.Primary"
                        Immediate="true"
                        Dense="true"
                        Placeholder="Поиск врача..."
                        Clearable="true" 
                        MaxItems="1000"/>
                </MudItem>
                <MudItem xs="12" md="12">
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled"
            OnClick="@(async () => await SaveAsync())"
            Disabled="@(!IsValid)" 
            Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</MudForm>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private IEnumerable<MedCenterEmployee> Employees = new List<MedCenterEmployee>();
    [Parameter] public HDSession AddEditModel { get; set; }
    [Parameter] public Patient AddEditPatientModel { get; set; }
    bool IsValid;
    MudForm form;
    private async Task<IEnumerable<string>> Search(string value)
    {
        if (string.IsNullOrEmpty(value))
            return Employees.Select(e => e.FullName);
        return Employees
            .Where(x => x.FullName.Contains(value, StringComparison.InvariantCultureIgnoreCase))
            .Select(e => e.FullName);
    }
    protected override async Task OnInitializedAsync()
    {
        AddEditModel.FioDoctor = await _localStorage.GetItemAsync<string>("fio");
        await LoadEmployeesAsync();
    }

    private async Task SaveAsync()
    {
        var response = await _httpClient.PostAsJsonAsync("api/medcard/endsession", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }
    private async Task LoadEmployeesAsync()
    {
        var response = await Http.GetAsync("api/medcenter/allempoyees?Id=" + AddEditModel.MedCenterId);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<MedCenterEmployee>>();
        Employees = mappedData.Data;
    }
}
