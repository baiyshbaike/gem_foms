@page "/finishedlist"
@using System.Net.Http.Json
@using Dialysis.Shared.Constants
@inject HttpClient Http


<MudContainer MaxWidth="MaxWidth.Large">

    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="8" md="4">
                <MudSelect T="long" Label="Мед. центр" @bind-Value="@searchModel.MedCenterId" AnchorOrigin="Origin.BottomCenter" Disabled="@IsOnlyCenter">
                    @{
                        if (!IsOnlyCenter)
                        {
                            <MudSelectItem T="long" Value="0">-------</MudSelectItem>
                        }
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="long" Value="@medItem.Id">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            
            <MudItem xs="4" md="2">
                <MudCardActions>
                    <br />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async() => await LoadSessionsAsync())">Обновить</MudButton>
                </MudCardActions>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h5" Style="color:red;">&nbsp;</MudText>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>


<MudTable Items="@Elements" RowsPerPage=100 RowStyleFunc="GetRowColor" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" Filter="new Func<HDSessionDto,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Все протоколы - @totalCount</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>ИНН/ФИО</MudTh>
        <MudTh>Мед. Центр Апарат</MudTh>
        <MudTh>Дата Подключения</MudTh>
        <MudTh>Дата Отключения</MudTh>
        <MudTh>Показатели</MudTh>
        <MudTh>Статус</MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd>@context.Patient.Inn <br />@context.Patient.LastName @context.Patient.FirstName</MudTd>
        <MudTd>@context.MedCenter.Title <br>@context.MedCenterMachine?.Number @context.MedCenterMachine?.Name  @context.MedCenterMachine?.Model</MudTd>
        <MudTd>@context.HDSession?.SessionStart?.ToString("dd.MM.yyyy HH:mm")</MudTd>
        <MudTd>@context.HDSession?.SessionEnd?.ToString("dd.MM.yyyy HH:mm")</MudTd>
        <MudTd>
            @{
                if (CheckIsStartFilled(context) == true)
                {
                    <MudButton Variant="Variant.Filled"
                               @onclick="@(()=> {_navigationManager.NavigateTo($"/sessionstartform/{context.HDSession.Id}");})"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                        Начало
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                               @onclick="@(()=> {_navigationManager.NavigateTo($"/sessionstartform/{context.HDSession.Id}");})"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                        Начало
                    </MudButton>
                }
            }
           
            <br />
            @{
                if (context.HDSession.StatusId == 3 || context.HDSession.StatusId == 2 || context.HDSession.StatusId == 11 || context.HDSession.StatusId == 12 || context.HDSession.StatusId == 4)
                {

                    if ( MinutsTohHours2((double)context.HDSession.TotalMinutes)> 0)
                    {
                        if (CheckIsHourFilled(context, "1") == true)
                        {
                            <MudButton Variant="Variant.Filled"
                            @onclick="@(() => HoursModal(context.HDSession.Id, 1, context.Patient.LastName,context.Patient.FirstName))"
                                       StartIcon="@Icons.Material.Filled.FileOpen"
                                       Size="Size.Small" Color="Color.Info">
                                1-й час
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                            @onclick="@(() => HoursModal(context.HDSession.Id, 1, context.Patient.LastName,context.Patient.FirstName))"
                                       StartIcon="@Icons.Material.Filled.FileOpen"
                                       Size="Size.Small" Color="Color.Warning">
                                1-й час
                            </MudButton>
                        }
                    }
                    if (MinutsTohHours2((double)context.HDSession.TotalMinutes) > 1)
                    {
                    if (CheckIsHourFilled(context, "2") == true)
                    {
                         <MudButton Variant="Variant.Filled"
                            @onclick="@(() => HoursModal(context.HDSession.Id, 2, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                            2-й час
                        </MudButton>
                    }
                    else
                    {
                          <MudButton Variant="Variant.Filled"
                            @onclick="@(() => HoursModal(context.HDSession.Id, 2, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                            2-й час
                        </MudButton>
                    }
                    }


                    
                       
                    if (MinutsTohHours2((double)context.HDSession.TotalMinutes) > 2)
                    {
                         if (CheckIsHourFilled(context, "3") == true)
                    {
                       <MudButton Variant="Variant.Filled"
                           @onclick="@(() => HoursModal(context.HDSession.Id, 3, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                            3-й час
                        </MudButton>
                    }
                    else
                    {
                         <MudButton Variant="Variant.Filled"
                            @onclick="@(() => HoursModal(context.HDSession.Id, 3, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                            3-й час
                        </MudButton>
                    }
                    }

                        
                    if (MinutsTohHours2((double)context.HDSession.TotalMinutes) > 3)
                        {
                        if (CheckIsHourFilled(context, "4") == true)
                            {
                                 <MudButton Variant="Variant.Filled"
                                   @onclick="@(() => HoursModal(context.HDSession.Id, 4, context.Patient.LastName,context.Patient.FirstName))"
                               StartIcon="@Icons.Material.Filled.FileOpen"
                               Size="Size.Small" Color="Color.Info">
                                    4-й час
                                </MudButton>
                            }
                        else
                            {
                                <MudButton Variant="Variant.Filled"
                                    @onclick="@(() => HoursModal(context.HDSession.Id, 4, context.Patient.LastName,context.Patient.FirstName))"
                               StartIcon="@Icons.Material.Filled.FileOpen"
                               Size="Size.Small" Color="Color.Warning">
                                    4-й час
                                </MudButton>
                            }
                        }
                }
            }
            @{
                if (CheckIsEndFilled(context) == true)
                {
                    <MudButton Variant="Variant.Filled"
                       @onclick="@(() => FinishModal(context.HDSession,context.Patient))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                Конец
            </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                           @onclick="@(() => FinishModal(context.HDSession,context.Patient))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                        Конец
                    </MudButton>
                }
            }
            

        </MudTd>

        <MudTd>

            @{
                if (@context.HDSession.StatusId == (long)HDSessionEnum.Finished || @context.HDSession.StatusId == (long)HDSessionEnum.Ended)
                {
                    if (DiffMinutes((DateTime)context.HDSession.SessionEnd) < 180)
                    {

                        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Security"
                           @onclick="@(() => EndIdentification(context.HDSession))"
                       Size="Size.Small" Color="Color.Info">
                            Идентификация (конец сеанса)
                        </MudButton>
                    }
                    else if(isAdmin)
                    {
                        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Security"
                                   @onclick="@(() => EndIdentification(context.HDSession))"
                                   Size="Size.Small" Color="Color.Error">
                            Идентификация (конец сеанса для админ) 
                        </MudButton>
                    }
                }
            }

            @{
                if ((@context.HDSession.StatusId == (long)HDSessionEnum.EndIdentification))
                {
                    if (CheckAllFilled(context) == true)
                    {
                        if (context.HDSession.TotalMinutes > 0)
                        {
                            if (TotalHours((DateTime)context.HDSession.SessionEnd) < 13)
                            {
                                <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Security"
                                   @onclick="@(() => SendToPay(context.HDSession))"
                               Size="Size.Small" Color="Color.Info">
                                    Отправить к оплате
                                </MudButton>
                            }
                            else if (isAdmin)
                            {
                                <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Security"
                                           @onclick="@(() => SendToPay(context.HDSession))"
                                           Size="Size.Small" Color="Color.Error">
                                    Отправить к оплате (для админ)
                                </MudButton>
                            }

                        }
                    }else if (TotalHours((DateTime)context.HDSession.SessionEnd) < 13){
                        <MudText>Заполните все необходимые поля</MudText>
                    }
                    else if (isAdmin)
                    {
                        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Security"
                                   @onclick="@(() => DeleteHDSession(context.HDSession))"
                                   Size="Size.Small" Color="Color.Error">
                            Удалить
                        </MudButton>
                    }
                }
                else
                {
                    <MudText>Необходимо пройти идентификацию в течении 3х часов</MudText>
                }
            }  

        </MudTd>
        <MudTd>
            @{
                if (context.HDSession.TotalMinutes > 0)
                {
                    <MudText> @MinutsTohHours((double)context.HDSession.TotalMinutes) </MudText>
                }
            }
        </MudTd>
        <MudTd>
            @{
                if (isAdmin)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Удалить" @onclick="@(async() => await DeleteModel(context.HDSession.Id))" Size="Size.Small" Color="Color.Error"></MudIconButton>
                    <MudIconButton Icon="@Icons.Material.Filled.Archive" aria-label="Архив" @onclick="@(async() => await ArchiveHdSession(context.HDSession.Id))" Size="Size.Small" Color="Color.Info"></MudIconButton>
                }
            }
        </MudTd>
        <MudTd>
            <MudButton Variant="Variant.Filled"
                       @onclick="@(async() => await AddEditModal(context.HDSession.Id))" StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                Подробности
            </MudButton>
        </MudTd>
    </RowTemplate>
   
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>


@code {
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private bool isAdmin = false;
    private HDSessionDto selectedItem1 = null;
    private HashSet<HDSessionDto> selectedItems = new HashSet<HDSessionDto>();
    private IEnumerable<HDSessionDto> Elements = new List<HDSessionDto>();
    private IEnumerable<MedCenter> UserCenters = new List<MedCenter>();

    private SearchtDto searchModel = new SearchtDto();
    private bool IsOnlyCenter = true;
    private bool tableLoading = true;

    private DateTime? dateFrom = null;
    private DateTime? dateTo = null;
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var authstate = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
        var user = authstate.User;
        isAdmin = user.IsInRole("admin");
        await LoadUserCentersAsync();
        await LoadSessionsAsync();
        StateHasChanged();
    }
    private async Task LoadSessionsAsync()
    {
        tableLoading = true;
        string HasOnlyCenter = "&isonly=0";
        if (IsOnlyCenter) HasOnlyCenter = "&isonly=1";

        var response = await Http.GetAsync("api/medcard/finishedsessions?medCenterId=" + searchModel.MedCenterId + "" + HasOnlyCenter);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authenticationManager.Logout();
            _navigationManager.NavigateTo("/login");
        }
        var mappedData = await response.ToResult<List<HDSessionDto>>();
        Elements = mappedData.Data;
        totalCount = Elements.Count();
        tableLoading = false;
    }

    private string MinutsTohHours(double totalMinutes)
    {
        int hours = (int)(totalMinutes / 60);
        //total minutes
        int minutes = (int)(totalMinutes % 60);
        //output is 1:10
        var time = $"{hours}:{minutes:00}";
        return time;
        /*TimeSpan t = TimeSpan.FromMinutes(totalMinutes);
            int hours = (int)t.TotalHours;
            int minutes = (int)t.TotalMinutes;
            return hours+":"+minutes;
            double totalHours = 0;
            totalHours = ((totalMinutes % 60) / 100);
            return Math.Floor(totalMinutes / 60) + totalHours;*/
    }
    private int MinutsTohHours2(double totalMinutes)
    {
        int hours = (int)(totalMinutes / 60);
        //total minutes
        int minutes = (int)(totalMinutes % 60);
        //output is 1:10
        var time = hours;
        return time;
        /*TimeSpan t = TimeSpan.FromMinutes(totalMinutes);
            int hours = (int)t.TotalHours;
            int minutes = (int)t.TotalMinutes;
            return hours+":"+minutes;
            double totalHours = 0;
            totalHours = ((totalMinutes % 60) / 100);
            return Math.Floor(totalMinutes / 60) + totalHours;*/
    }

    private int TotalHours(DateTime startDate)
    {
        var nowDate = DateTime.Now;
        var totalHours = (int)((nowDate - startDate).TotalHours);
        //int hours = (int)(totalMinutes / 60);
        return totalHours;
    }

    private int DiffMinutes(DateTime startDate)
    {
        var nowDate = DateTime.Now;
        var totalMins = (int)((nowDate - startDate).TotalMinutes);
        //int hours = (int)(totalMinutes / 60);
        return totalMins;
    }

    private string GetRowColor(HDSessionDto hdItem, int index)
    {
        string retColor = "background-color:#FFF";
        if (hdItem.HDSession.StatusId == (long)HDSessionEnum.SendToPay)
        {
            retColor = "background-color:#FFF";
        }
        else if (hdItem.HDSession.StatusId == (long)HDSessionEnum.Payed)
        {
            retColor = "background-color:#FFF";
        }
        else if (hdItem.HDSession.StatusId == (long)HDSessionEnum.Rejected)
        {
            retColor = "background-color:#FF0000";
        }
        else if (hdItem.HDSession.StatusId == (long)HDSessionEnum.Finished)
        {
            var nowDate = DateTime.Now;
            var totalHours = (int)((nowDate - (DateTime)hdItem.HDSession.SessionEnd).TotalHours);
            //int hours = (int)((double)hdItem.HDSession.TotalMinutes / 60);
            //if (hours > 4)
            //{
            //    totalHours = totalHours + (hours - 4);
            //}
            if (totalHours > 4.5)
            {
                retColor = "background-color:#E9967A";
            }
        }        
        return retColor;
    }


    public async Task LoadUserCentersAsync()
    {
        UserCenters = await _commonService.LoadRelMedcentersAsync();
        if (UserCenters != null)
        {
            if (UserCenters.Count() > 1)
            {
                IsOnlyCenter = false;
                searchModel.MedCenterId = 0;
            }
            else if (UserCenters.Count() == 1)
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = UserCenters.First().Id;
            }
            else
            {
                IsOnlyCenter = true;
                searchModel.MedCenterId = 0;
            }
        }
    }

    private bool FilterFunc1(HDSessionDto element) => FilterFunc(element, searchString1);

    private bool FilterFunc(HDSessionDto element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (!string.IsNullOrEmpty(element.MedCenter.Title))
        {
            if (element.MedCenter.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrEmpty(element.Patient.Inn))
        {
            if (element.Patient.Inn.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrEmpty(element.Patient.FirstName))
        {
            if (element.Patient.FirstName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (!string.IsNullOrEmpty(element.Patient.LastName))
        {
            if (element.Patient.LastName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        return false;
    }

    private async Task SendToPay(HDSession activeModal)
    {
        var response = await _httpClient.PostAsJsonAsync("api/medcard/sendtopay", activeModal);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);            
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);           
        }
        await LoadSessionsAsync();
    }
    private async Task DeleteHDSession(HDSession activeModal)
    {
        var response = await _httpClient.PostAsJsonAsync("api/medcard/deletehdsession", activeModal);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);            
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);           
        }
        await LoadSessionsAsync();
    }

    private async Task EndIdentification(HDSession activeModal)
    {
        var parameters = new DialogParameters();
        parameters.Add("HDSessionId", activeModal.Id);
        parameters.Add("sendModel", activeModal);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<EndIdent>("Идентификация", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadSessionsAsync();
        }
    }

    private async Task AddEditModal(long id = 0)
    {
        var parameters = new DialogParameters();
        parameters.Add("HDSessionId", id);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<SessionDetail>("Подробности", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            //await LoadSessionsAsync();
        }
    }

    private async Task StartModal(HDSession activeModel)
    {
        var parameters = new DialogParameters();
        parameters.Add("sendModel", activeModel);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<SessionStart>("Индикаторы сеанса", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadSessionsAsync();
        }
    }

    private int CalculateHours(DateTime startDate)
    {
        DateTime dtNow = DateTime.Now;
        if (startDate != null)
        {
            var hours = (dtNow - startDate).TotalHours;
            return (int)hours;
        }
        return 0;
    }
    private async Task HoursModal(long id = 0, int hour = 0, string lastName = "", string firstName = "")
    {
        var parameters = new DialogParameters();
        parameters.Add("hour", hour.ToString());
        parameters.Add("HDSessionId", id);
        parameters.Add("lastName", lastName);
        parameters.Add("firstName", firstName);
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<SessionIndicators>("Показатели", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadSessionsAsync();
        }
    }

    public bool CheckAllFilled(HDSessionDto item)
    {
        var retVal = false;
        if (CheckIsStartFilled(item) == true && CheckIsEndFilled(item) == true && CheckIsHourFilled(item, "1"))
        {
            retVal = true;
        }

        return retVal;
    }

    public bool CheckIsStartFilled(HDSessionDto item)
    {
        var retVal = false;
        if (item.HDSession != null)
        {

            if (item.HDSession.StartWeight > 0 && !String.IsNullOrEmpty(item.HDSession.Program) && !String.IsNullOrEmpty(item.HDSession.Temp))
            {
                retVal = true;
            }
        }

        return retVal;
    }
    public bool CheckIsEndFilled(HDSessionDto item)
    {
        var retVal = false;
        if (item.HDSession != null)
        {

            if (item.HDSession.EndWeight > 0 && !String.IsNullOrEmpty(item.HDSession.EndSys) && !String.IsNullOrEmpty(item.HDSession.EndTemp))
            {
                retVal = true;
            }
        }

        return retVal;
    }

    public bool CheckIsHourFilled(HDSessionDto item, string hour)
    {
        var retVal = false;
        if (item.HDSessionHours != null)
        {

            foreach (var ii in item.HDSessionHours)
            {
                if (ii?.Hour == hour)
                {
                    if (!String.IsNullOrEmpty(ii.Dia) && !String.IsNullOrEmpty(ii.Sys) && !String.IsNullOrEmpty(ii.Temp))
                    {
                        retVal = true;
                    }
                }
            }
        }

        return retVal;
    }
    private async Task DeleteModel(long id = 0)
    {
        var response = await _httpClient.PostAsJsonAsync("api/medcard/deletehdsessionbyid", id);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
        }
        await LoadUserCentersAsync();
        await LoadSessionsAsync();
    }
    private async Task ArchiveHdSession(long id=0)
    {
        var response = await _httpClient.PostAsJsonAsync("api/medcard/archivehdsessionbyid", id);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
        }
        await LoadUserCentersAsync();
        await LoadSessionsAsync();
    }
    private async Task FinishModal(HDSession activeModel, Patient acitvePatient)
    {
        var parameters = new DialogParameters();
        parameters.Add("AddEditModel", activeModel);
        parameters.Add("AddEditPatientModel", acitvePatient);

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<SessionFinish>("Индикаторы сеанса", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadSessionsAsync();
        }
    }

    public class SearchtDto
    {
        public long MedCenterId { get; set; }
        public string Inn { get; set; }
        public string Image { get; set; }
        public long Status { get; set; }
    }


}

