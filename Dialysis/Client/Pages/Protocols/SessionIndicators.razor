@inject HttpClient Http
<MudForm @ref="form" Model="@AddEditModel" @bind-IsValid="@IsValid">

    <MudDialog>
        <TitleContent>
    
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                        Показатели сеанса
                    </MudText>
                
        </TitleContent>
        <DialogContent>
            <MudGrid>
               <MudItem xs="12" md="12">
                   <MudText>
                       @lastName @firstName
                   </MudText>
               </MudItem>

                <MudItem xs="12" md="4">
                    @hour -й час
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField For="@(() => AddEditModel.Sys)" MaxLength="4" @bind-Value="AddEditModel.Sys" Label="SYS" Required="true"/>
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField For="@(() => AddEditModel.Dia)" MaxLength="4" @bind-Value="AddEditModel.Dia" Label="DIA" Required="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField For="@(() => AddEditModel.Ritm)" MaxLength="4" @bind-Value="AddEditModel.Ritm" Label="Частота" Required="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudTextField For="@(() => AddEditModel.Temp)" MaxLength="4" @bind-Value="AddEditModel.Temp" Label="Температура" Required="true" />
                </MudItem>


                <MudItem xs="12" md="12">

                </MudItem>

            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled"
            OnClick="@(async () => await SaveAsync())"
            Disabled="@(!IsValid)" 
            Color="Color.Success">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</MudForm>

 @code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public HDSessionHour AddEditModel { get; set; } = new();
    [Parameter] public string  hour { get; set; } = "1";
    [Parameter] public long  HDSessionId { get; set; }
    [Parameter] public string lastName { get; set; } = "";
    [Parameter] public string firstName { get; set; } = "";
    bool IsValid;
    MudForm form;


    protected override async Task OnInitializedAsync()
    {
        AddEditModel.HDSessionId = HDSessionId;
        AddEditModel.Hour = hour;
        await LoadSessionHourAsync();
    }

    private async Task LoadSessionHourAsync()
    {
        var response = await Http.GetAsync("api/medcard/getindicator?sessionId=" + HDSessionId + "&hour="+hour);
        var mappedData = await response.ToResult<HDSessionHour>();
        if (mappedData.Data != null)
        {
            AddEditModel = mappedData.Data;
            IsValid = true;
        }
    }

    private async Task SaveAsync()
    {
        AddEditModel.HDSessionId = HDSessionId;
        AddEditModel.Hour = hour;
        var url = "api/medcard/addindicator";
        if (AddEditModel.Id != null && AddEditModel.Id > 0)
        {
            url = "api/medcard/updateindicator";
        }  
        var response = await _httpClient.PostAsJsonAsync(url, AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
       
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }
}
