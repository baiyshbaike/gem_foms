@page "/processing"
@using System.Net.Http.Json
@inject HttpClient Http
@using System.Threading.Tasks;
@using System.Timers;    


<MudContainer MaxWidth="MaxWidth.Large">
   
    
    
    <EditForm Model="@searchModel">
        <MudGrid>
            <MudItem xs="8" md="4">
                <MudSelect T="MedCenter" Label="Мед. центр" @bind-Value="@searchModel.MedCenter" AnchorOrigin="Origin.BottomCenter">
                    @{
                        <MudSelectItem T="MedCenter" Value=selDefault Disabled="true">-------</MudSelectItem>
                        @foreach (var medItem in UserCenters)
                        {
                            <MudSelectItem T="MedCenter" Value="@medItem">@medItem.Title</MudSelectItem>
                        }
                    }
                </MudSelect>

            </MudItem>
            <MudItem xs="4" md="2">
                <MudCardActions>
                    <br />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" @onclick="@(async() => await LoadSessionsAsync())">Обновить</MudButton>
                </MudCardActions>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h5" Style="color:red;">&nbsp;</MudText>
            </MudItem>
            <MudItem xs="12" md="12">
                &nbsp;
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

<MudTable Items="@Elements" RowsPerPage=100 Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" Filter="new Func<HDSessionDto,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Активные протоколы - @totalCount</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>ФИО</MudTh>
        <MudTh>ИНН</MudTh>
        <MudTh>Мед. Центр</MudTh>
        <MudTh>ГД Аппарат</MudTh>
        <MudTh>Дата Подключения</MudTh>
        <MudTh>Показатели</MudTh>
        <MudTh>Пауза</MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
        <MudTh>&nbsp;</MudTh>
         
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Patient.LastName @context.Patient.FirstName</MudTd>
        <MudTd>@context.Patient.Inn</MudTd>
        <MudTd>@context.MedCenter.Title</MudTd>
        <MudTd>@context.MedCenterMachine.Number @context.MedCenterMachine.Name  @context.MedCenterMachine.Model</MudTd>
        <MudTd>@context.HDSession.SessionStart?.ToString("dd.MM.yyyy HH:mm")</MudTd>
        
        <MudTd>
            @{
                if (CheckIsStartFilled(context))
                        {
                    <MudButton Variant="Variant.Filled"
                               @onclick="@(()=> {_navigationManager.NavigateTo($"/sessionstartform/{context.HDSession.Id}");})"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                        Начало
                    </MudButton>
                        }
                        else
                        {
                    <MudButton Variant="Variant.Filled"
                               @onclick="@(()=> {_navigationManager.NavigateTo($"/sessionstartform/{context.HDSession.Id}");})"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                        Начало
                    </MudButton>
                        }
            }
            
            <br/>
            @{
                if (context.HDSession.StatusId == 1 || context.HDSession.StatusId == 2)
                {
                    if (CalculateHours((DateTime)context.HDSession.SessionStart) >= 0)
                    {
                        if (CheckIsFilled(context, "1") == true)
                        {
                                <MudButton Variant="Variant.Filled"
                            @onclick="@(() => AddEditModal(context.HDSession.Id, 1, context.Patient.LastName,context.Patient.FirstName))"
                           StartIcon="@Icons.Material.Filled.FileOpen"
                           Size="Size.Small" Color="Color.Info">
                                    1-й час
                                </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                            @onclick="@(() => AddEditModal(context.HDSession.Id, 1, context.Patient.LastName,context.Patient.FirstName))"
                                       StartIcon="@Icons.Material.Filled.FileOpen"
                                   Size="Size.Small" Color="Color.Warning">
                                1-й час
                            </MudButton>
                        }
                        
                    }
                    if (CalculateHours((DateTime)context.HDSession.SessionStart) >= 1)
                    {
                        if (CheckIsFilled(context, "2") == true)
                        {
                            <MudButton Variant="Variant.Filled"
                            @onclick="@(() => AddEditModal(context.HDSession.Id, 2, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                                2-й час
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                            @onclick="@(() => AddEditModal(context.HDSession.Id, 2, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                            2-й час
                        </MudButton>
                        }
                        
                    }
                    if (CalculateHours((DateTime)context.HDSession.SessionStart) >=2)
                    {
                        if (CheckIsFilled(context, "3") == true)
                        {
                            <MudButton Variant="Variant.Filled"
                           @onclick="@(() => AddEditModal(context.HDSession.Id, 3, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                            3-й час
                        </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                            @onclick="@(() => AddEditModal(context.HDSession.Id, 3, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                                3-й час
                            </MudButton>
                        }
                        
                    }
                    if (CalculateHours((DateTime)context.HDSession.SessionStart) >= 3)
                    {
                        if (CheckIsFilled(context, "4") == true)
                        {
                             <MudButton Variant="Variant.Filled"
                           @onclick="@(() => AddEditModal(context.HDSession.Id, 4, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Info">
                            4-й час
                        </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                            @onclick="@(() => AddEditModal(context.HDSession.Id, 4, context.Patient.LastName,context.Patient.FirstName))"
                       StartIcon="@Icons.Material.Filled.FileOpen"
                       Size="Size.Small" Color="Color.Warning">
                                4-й час
                            </MudButton>
                        }
                       
                    }
                }
           }
           
            </MudTd>
        <MudTd>
                   
                @{
                    if (context.HDSession.StatusId == 3)
                    {
                        <MudButton Variant="Variant.Filled"
                               @onclick="@(async() => await UnPauseAsync(context.HDSession.Id))" StartIcon="@Icons.Material.Filled.FileOpen"
                           Size="Size.Small" Color="Color.Info">
                            Продолжать
                        </MudButton>
                    }
                    else  {
                             <MudButton Variant="Variant.Filled"
                               @onclick="@(() => PauseModal(context.HDSession.Id))" StartIcon="@Icons.Material.Filled.FileOpen"
                                   Size="Size.Small" Color="Color.Info">
                            Пауза
                        </MudButton>
                        }
               }
            
          
          
        </MudTd>
        <MudTd>
            @{
                if (context.HDSession.StatusId == 2)
                {
                    if (CheckIsFilled(context, "1") == true)
                    {
                        <MudButton Variant="Variant.Filled" 
                                   StartIcon="@Icons.Material.Filled.Security"
                                   @onclick="@(() => SendToEnd(context.HDSession))"
                                   Size="Size.Small" Color="Color.Info">
                            Завершить
                        </MudButton>
                    }
                    else
                    {
                        <MudText>Заполните первый час для завершения сеанса</MudText>
                    }

                }               
            }            
        </MudTd>
        <MudTd>
            @{
                if (viewButton)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Удалить" @onclick="@(async() => await DeleteModel(context.HDSession.Id))" Size="Size.Small" Color="Color.Warning"></MudIconButton>
                }
            }
        </MudTd>
        <MudTd>
            <MudIconButton 
                Icon="@Icons.Material.Filled.Edit" 
                aria-label="Редактировать" 
                @onclick="@(async() => await AddEditModal(context.HDSession))" 
                Size="Size.Small" 
                Color="Color.Warning"
                Disabled="@context.HDSession.Сhanged">
            </MudIconButton>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
