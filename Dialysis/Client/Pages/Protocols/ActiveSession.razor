    private async Task SendToEnd(HDSession activeModal)
    {
        var parameters = new DialogParameters();
        if (activeModal != null)
        {
            Console.WriteLine("hdSession not null");
            parameters.Add("AddEditModel", activeModal);
        }
        else
        {
            Console.WriteLine("hdSession is null");
            var newModel = new HDSession();
            parameters.Add("AddEditModel", newModel);
        }

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<ToFinish>(activeModal == null ? "Добавить Пациент" : "Редактировать время", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadSessionsAsync();
        }


        
    }

    private int CalculateHours(DateTime startDate)
    {
        DateTime dtNow = DateTime.Now;
        if (startDate != null)
        {
            var hours = (dtNow - startDate).TotalHours;
            return (int)hours;
        }
        return 0;
    }
    private async Task AddEditModal(HDSession hDSession)
    {
        var parameters = new DialogParameters();
        if (hDSession !=null)
        {
            parameters.Add("AddEditModel", hDSession);
        }
        else
        {
            var newModel = new HDSession();
            parameters.Add("AddEditModel", newModel);
        }

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<ActiveSessionEdit>(hDSession ==null ? "Добавить Пациент" : "Редактировать Пациент", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadSessionsAsync();
        }
    }

