@inject HttpClient Http
<EditForm Model="@AddEditModel">

    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Security" Class="mr-3 mb-n1" />
                @AddEditModel.LastName @AddEditModel.FirstName @AddEditModel.MIddleName
                 
            </MudText>
        </TitleContent>
        <DialogContent>
            <div style="max-height: 400px; overflow-y: auto;">
            <MudGrid>
                <MudItem xs="12" md="12">
                    @{
                        if (Elements != null)
                        {
                            foreach (var item in Elements)
                            {

                                <input type="checkbox" checked="@checkIsChecked(item.Id)" @onchange="eventArgs => { CheckedChangedFunc(item.Id, eventArgs.Value); }" />  
                                   @item.Title 
                                <br/>                               
                            }
                        }
                    }                   
                </MudItem>          

            </MudGrid>
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Закрыть</MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public User AddEditModel { get; set; } = new();
    private IEnumerable<MedCenter> Elements = new List<MedCenter>();
    private IEnumerable<MedCenter> UserElements = new List<MedCenter>();


    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        await LoadUserDataAsync();
    }

    private async Task LoadDataAsync()
    {
        var response = await Http.GetAsync("api/medcenter/allmedcenters");
        var mappedData = await response.ToResult<List<MedCenter>>();
        Elements = mappedData.Data;        
    }
    public async Task LoadUserDataAsync()
    {
        var response = await Http.GetAsync("api/medcenter/usercenter?id=" + AddEditModel.Id);
        var mappedData = await response.ToResult<List<MedCenter>>();
        UserElements = mappedData.Data;
    }

    private bool checkIsChecked(long Id)
    {
        var varObj = UserElements.Where(u => u.Id == Id).FirstOrDefault();
        if (varObj != null)
        {
            return true;
        }
        else
        {
            return false;
        }
    }

    private async void CheckedChangedFunc(long Id, object selValue)
    {
        if ((bool)selValue)
        {
            await SaveMedCenterUserAsync(Id, AddEditModel.Id, 99);
        }
        else
        {
            await SaveMedCenterUserAsync(Id, AddEditModel.Id, 0);
        }
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveMedCenterUserAsync(long id, long userId, long status)
    {
        var response = await Http.GetAsync("api/medcenter/addremoveuser?id=" + id + "&userid=" + userId + "&status=" + status);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);            
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);            
        }
    }
}
