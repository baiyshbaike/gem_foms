@page "/profile"
@using System.Net.Http.Json
@inject HttpClient Http
@attribute [Authorize]



<MudTable Items="@Elements" Loading="@tableLoading" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="@striped" Filter="new Func<UserProfile,bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Профили</MudText>
        &nbsp;&nbsp;
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.SupervisorAccount" Size="Size.Small" Color="Color.Info" @onclick="@(() => AddEditModal(0))">Добавить</MudButton>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Поиск" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Id</MudTh>
        <MudTh>Название</MudTh>
        <MudTh>Дата</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Id">@context.Id</MudTd>
        <MudTd DataLabel="Название">@context.Title</MudTd>
        <MudTd DataLabel="Дата">@context.CreatedOn.ToString("dd.MM.yyyy")</MudTd>
        <MudTd DataLabel="">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Security" Size="Size.Small" Color="Color.Info" @onclick="@(()=> OpenRoles(context.Id, context.Title))">Роли</MudButton>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private bool dense = false;
    private bool hover = true;
    private bool striped = true;
    private bool bordered = false;
    private string searchString1 = "";
    private bool tableLoading = false;
    private UserProfile selectedItem1 = null;
    private HashSet<UserProfile> selectedItems = new HashSet<UserProfile>();

    private IEnumerable<UserProfile> Elements = new List<UserProfile>();

    protected override async Task OnInitializedAsync()
    {
        tableLoading = true;
        await LoadDataAsync();

        //Elements = await _httpClient.GetFromJsonAsync<List<PatientDto>>("webapi/periodictable");
        //Elements = await Http.GetFromJsonAsync<DializDto[]>("temp_data/dializ.json");
    }

    private async Task LoadDataAsync()
    {
        var response = await Http.GetAsync("api/profile/allprofiles");
        var mappedData = await response.ToResult<List<UserProfile>>();
        Elements = mappedData.Data;
        tableLoading = false;
    }

    private bool FilterFunc1(UserProfile element) => FilterFunc(element, searchString1);

    private bool FilterFunc(UserProfile element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        /*if (element.Adress.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;*/
        return false;
    }

    private async Task AddEditModal(int id = 0)
    {
        var parameters = new DialogParameters();

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<ProfileAddEdit>(id == 0 ? "New Profile" : "Edit", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadDataAsync();
        }
    }

    private async Task OpenRoles(long Id =0, string Fio = "")
    {
        var parameters = new DialogParameters();

        if (Id != 0)
        {
            var userSel = Elements.Where(u => u.Id == Id).FirstOrDefault();
            parameters.Add("AddEditModel", userSel);
        }

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, DisableBackdropClick = true, Position = DialogPosition.TopCenter };
        var dialog = _dialogService.Show<ProfileRoles>("Роли", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            //await LoadDataAsync();
        }
    }



}

