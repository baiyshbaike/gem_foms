@page "/login"
@using System.Net.Http.Json
@using Dialysis.Shared.Params
@using Dialysis.Shared.Responses
@using Microsoft.AspNetCore.Components.Authorization;
@using System.Security.Claims;
@attribute [AllowAnonymous]

<MudPaper Class="d-flex justify-center flex-grow-1 gap-4" Elevation="0">
    @if(isLoading==true){
        <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
    }
    else
    {
        <MudForm Model="@model" @ref="form" @bind-IsValid="@isValid">
            <MudGrid Style="width:400px;">
                <MudItem xs="12">
                    <MudCard>
                        <MudCardContent>
                            <MudTextField Label="Логин" HelperText="" Required="true" RequiredError=""
                                      @bind-Value="model.Email" For="@(() => model.Email)" />
                            <MudTextField Label="Пароль" HelperText="" Class="mt-3" Required="true" RequiredError=""
                                      @bind-Value="model.Password" For="@(() => model.Password)" InputType="InputType.Password" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(async () => await SubmitAsync())" Class="ml-auto">
                                Вход
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudForm>
    }
    
    
</MudPaper>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; }
    private LoginParams model = new LoginParams();
    bool isValid;
    MudForm form;
    bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await authenticationStateTask;
            var user = authState.User;

            if (user.Identity.IsAuthenticated)
            {
                Console.WriteLine($"{user.Identity.Name} is authenticated.");
                _navigationManager.NavigateTo("/");
            }
        }catch(Exception){}
    }

    private async Task SubmitAsync()
    {
        isLoading = true;
        var result = await _authenticationManager.Login(model);
        if (!result.Succeeded)
        {
            foreach (var message in result.Messages)
            {
                _snackBar.Add(message, Severity.Error);
            }
            isLoading = false;
        }
        else
        {
            isLoading = false;
            _navigationManager.NavigateTo("/");
        }
    }
    }

