@inject HttpClient Http
<EditForm Model="@AddEditModel" OnValidSubmit="SaveAsync">

    <MudDialog>
        <TitleContent>
            @{
                if (AddEditModel.Id == 0)
                {
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                            Добавить пользователя
                        </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                        Редактировать пользователя
                    </MudText>
                }
            }
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField For="@(() => AddEditModel.LastName)" @bind-Value="AddEditModel.LastName" Label="Фамилия" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField For="@(() => AddEditModel.FirstName)" @bind-Value="AddEditModel.FirstName" Label="Имя" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField For="@(() => AddEditModel.MIddleName)" @bind-Value="AddEditModel.MIddleName" Label="Отчество" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="long" Label="Профиль" @bind-Value="@AddEditModel.ProfileId" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="long" Value="0">---</MudSelectItem>
                        @foreach (var selectItem in ProfileList)
                        {
                            <MudSelectItem T="long" Value="@selectItem.Id">@selectItem.Title</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField For="@(() => AddEditModel.Username)" @bind-Value="AddEditModel.Username" Label="Логин" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField For="@(() => AddEditModel.Email)" @bind-Value="AddEditModel.Email" Label="Email" />
                </MudItem>               
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="passwordInput" Label="Пароль" InputType="InputType.Password"
                                  Immediate="true"
                                  HelperText="Мин 8 символов, заглавная буква, цифра, спецсимвол"
                                  Error="@(!string.IsNullOrEmpty(passwordInput) && !IsPasswordStrong)"
                                  ErrorText="Пароль не соответствует требованиям" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="passWord2" Label="Повтор пароля" InputType="InputType.Password"
                                  Immediate="true"
                                  Error="@(!string.IsNullOrEmpty(passWord2) && passWord2 != passwordInput)"
                                  ErrorText="Пароли не совпадают" />
                </MudItem>
                @if (!string.IsNullOrEmpty(passwordInput))
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="@(HasMinLength ? Color.Success : Color.Error)">
                            @(HasMinLength ? "✓" : "✗") Минимум 8 символов
                        </MudText>
                        <MudText Typo="Typo.caption" Color="@(HasUpperCase ? Color.Success : Color.Error)">
                            @(HasUpperCase ? "✓" : "✗") Заглавная буква
                        </MudText>
                        <MudText Typo="Typo.caption" Color="@(HasDigit ? Color.Success : Color.Error)">
                            @(HasDigit ? "✓" : "✗") Цифра
                        </MudText>
                        <MudText Typo="Typo.caption" Color="@(HasSpecialChar ? Color.Success : Color.Error)">
                            @(HasSpecialChar ? "✓" : "✗") Специальный символ (!@@#$%...)
                        </MudText>
                    </MudItem>
                }
                @if(AddEditModel.Id>0){
                    <MudItem xs="12" md="6">
                        <MudSelect T="bool" Label="Статус" @bind-Value="@AddEditModel.IsActive" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem T="bool" Value="true">Актив</MudSelectItem>
                            <MudSelectItem T="bool" Value="false">Не актив/Архив</MudSelectItem>
                        </MudSelect>
                        
                    </MudItem>
                }
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Отмена</MudButton>
            <MudButton Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success"
                       Disabled="@(!CanSave)">Сохранить</MudButton>

        </DialogActions>
    </MudDialog>
</EditForm>

        @code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public User AddEditModel { get; set; }
    [Parameter] public long id { get; set; }
    public string passWord2 = "";
    private string passwordInput = "";

    // Password validation flags
    private bool HasMinLength => !string.IsNullOrEmpty(passwordInput) && passwordInput.Length >= 8;
    private bool HasUpperCase => !string.IsNullOrEmpty(passwordInput) && passwordInput.Any(char.IsUpper);
    private bool HasDigit => !string.IsNullOrEmpty(passwordInput) && passwordInput.Any(char.IsDigit);
    private bool HasSpecialChar => !string.IsNullOrEmpty(passwordInput) && 
        System.Text.RegularExpressions.Regex.IsMatch(passwordInput, @"[!@@#$%^&*()_+\-=\[\]{};':""\\|,.<>\/?]");
    private bool IsPasswordStrong => HasMinLength && HasUpperCase && HasDigit && HasSpecialChar;
    private bool PasswordsMatch => passwordInput == passWord2;

    private bool CanSave
    {
        get
        {
            // Edit mode: password is optional (empty = no change)
            if (AddEditModel.Id > 0 && AddEditModel.CreatedOn != null)
            {
                if (string.IsNullOrEmpty(passwordInput) && string.IsNullOrEmpty(passWord2))
                    return true; // no password change
                return IsPasswordStrong && PasswordsMatch;
            }
            // New user: password is required
            return IsPasswordStrong && PasswordsMatch;
        }
    }

    private IEnumerable<UserProfile> ProfileList = new List<UserProfile>();

    protected override async Task OnInitializedAsync()
    {
        await LoadProfilesAsync();
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task LoadProfilesAsync()
    {
        var response = await Http.GetAsync("api/profile/allprofiles");
        var mappedData = await response.ToResult<List<UserProfile>>();
        ProfileList = mappedData.Data;
    }


    private async Task SaveAsync()
    {
        if (AddEditModel.Id != null &&  AddEditModel.CreatedOn !=null)
        {
            if (string.IsNullOrEmpty(passwordInput))
            {
                AddEditModel.Password = "";
            }
            else
            {
                AddEditModel.Password = passwordInput;
            }
        }
        else
        {
            AddEditModel.Password = passwordInput;
        }
        var response = await _httpClient.PostAsJsonAsync("api/user/adduser", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }       
    }
}
