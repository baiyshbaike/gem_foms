<EditForm Model="@AddEditModel" OnValidSubmit="SaveAsync">
    
    <MudDialog>
        <TitleContent>
            @{
                if (AddEditModel.Id == 0)
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                       Add Profile
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                        Update Profile
                    </MudText>
                }
            }
        </TitleContent>
        <DialogContent>
            <MudGrid>
                
                <MudItem xs="12" md="6">
                    <MudTextField For="@(() => AddEditModel.Title)" @bind-Value="AddEditModel.Title" Label="Name" />
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">Cancel</MudButton>            
            <MudButton Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success">Save</MudButton>

        </DialogActions>
    </MudDialog>
</EditForm>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    public UserProfile AddEditModel { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {

    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }

    private void SaveAsync3()
    {
        MudDialog.Cancel();
    }

    private void SaveAsync2()
    {
        var response =  _httpClient.PostAsJsonAsync("api/profile", AddEditModel);
        //return await response.ToResult<int>();
        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task SaveAsync()
    {
        var response = await _httpClient.PostAsJsonAsync("api/profile/addprofile", AddEditModel);
        var result = await response.ToResult();
        if (!result.Succeeded)
        {
            _snackBar.Add(result.Messages[0], Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
        else
        {
            _snackBar.Add("Успешно", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }



}

